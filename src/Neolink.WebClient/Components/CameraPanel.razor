@using System.Text.Json
@using System.Net.Http.Headers
@implements IDisposable
@inject HttpClient Http

@* Per-camera settings/control dialog. Everything shown is discovered from the
   camera: device info, encode profiles, and the controls the camera supports.
   Deliberately modal: only the ✕ button dismisses it, so a stray click can't
   close it mid-adjustment. *@

<div class="backdrop panel-backdrop"></div>
<aside class="campanel campanel-wide" role="dialog" aria-label="Camera settings">
    <div class="campanel-head">
        <span class="dot @(_caps?.Online == true ? "on" : "off")"></span>
        <span class="campanel-title">@CameraName</span>
        <button class="icon-btn" title="Close" @onclick="CloseAsync">✕</button>
    </div>

    @if (_error != null)
    {
        <div class="notice error">@_error</div>
    }

    @if (_loading)
    {
        <div class="notice">Querying camera…</div>
    }
    else if (_suspended == true)
    {
        @* A suspended camera reads offline — but the resume control must stay
           reachable, so it gets its own mini-panel instead of the offline notice. *@
        <div class="campanel-section">
            <div class="campanel-section-title">@UiIcon.Render("eye-off", 13) SUSPENDED <span class="beta-tag">BETA</span></div>
            <div class="notice small">
                This camera is <b>suspended in Neolink.NET</b> — no connection is held, so it
                isn't viewed or recorded here and its Home Assistant entities are unavailable.
            </div>
            <div class="control-row">
                <span>Suspended in Neolink.NET — on</span>
                @if (_suspendBusy)
                {
                    <span class="chip chip-off" aria-busy="true"><span class="btn-spinner"></span>Saving…</span>
                }
                else
                {
                    <button class="chip chip-active" disabled="@(!CanEditRecording)"
                            @onclick="() => SetSuspendAsync(false)">suspended — click to resume</button>
                }
            </div>
            <div class="notice warn small">
                ⚠ The camera itself keeps running: its own SD-card / cloud recording and any
                other system pulling it directly are unaffected. Suspend is not a privacy guarantee.
            </div>
        </div>
    }
    else
    {
        @* Identity strip: the address is known upfront and shows immediately; the
           camera's own vitals (model/firmware/serial, Wi-Fi, SD) fill in once it
           answers. Generic RTSP cameras report none, so the strip is just the
           address (or nothing). *@
        @if (_caps?.Version != null || !string.IsNullOrEmpty(Camera?.Address) || _http?.WifiSignal != null || _http?.SdCards is { Count: > 0 })
        {
        <div class="campanel-devbar">
            @if (!string.IsNullOrEmpty(_caps?.Version?.Model)) { <span class="devbar-item devbar-model" title="Model">@_caps!.Version!.Model</span> }
            @if (!string.IsNullOrEmpty(_caps?.Version?.Firmware)) { <span class="devbar-item"><span class="devbar-k">Firmware</span>@_caps!.Version!.Firmware</span> }
            @if (!string.IsNullOrEmpty(_caps?.Version?.Hardware)) { <span class="devbar-item"><span class="devbar-k">Hardware</span>@_caps!.Version!.Hardware</span> }
            @if (!string.IsNullOrEmpty(_caps?.Version?.Serial)) { <span class="devbar-item"><span class="devbar-k">Serial</span>@_caps!.Version!.Serial</span> }
            @if (!string.IsNullOrEmpty(Camera?.Address)) { <span class="devbar-item" title="Configured network address"><span class="devbar-k">Address</span>@Camera!.Address</span> }
            @if (Camera?.Udp == true) { <span class="devbar-item" title="Connected over UDP (Baichuan-over-UDP) — beta support for battery-only models"><span class="devbar-k">Transport</span>UDP <span class="beta-tag">BETA</span></span> }
            @if (_http?.WifiSignal is { } wifi) { <span class="devbar-item"><span class="devbar-k">Wi-Fi</span>@WifiLabel(wifi)</span> }
            @if (_http?.SdCards is { Count: > 0 } cards)
            {
                foreach (var card in cards)
                {
                    <span class="devbar-item"><span class="devbar-k">SD card</span>@SdLabel(card)</span>
                }
            }
            @if (_firmware is { UpdateAvailable: true } fw)
            {
                <span class="devbar-item devbar-model"
                      title="Reolink offers a newer firmware for this camera. Update it from the Reolink app or the camera's own web page — Neolink.NET never installs firmware.">
                    <span class="devbar-k">Update</span>@(fw.NewVersion ?? "available")
                </span>
            }
        </div>
        }

        @* The camera is still answering: the server-side recording settings are
           already usable above; device info and controls slot in when it replies. *@
        @if (_probing)
        {
            <div class="notice small campanel-probing">
                <span class="btn-spinner"></span> Querying the camera — device info and controls appear in a moment.
            </div>
        }
        else if (_caps is { Online: false } && _recording == null)
        {
            <div class="notice">Camera is offline (reconnecting). Controls appear when it comes back.</div>
        }

        <div class="settings-tabs campanel-tabs" role="tablist">
            @* Recording leads and is the default: it's the most-visited tab. *@
            @if (_recording != null)
            {
                <button class="settings-tab @(_camTab == "recording" ? "active" : "")" role="tab"
                        @onclick='() => _camTab = "recording"'>@UiIcon.Render("rec", 13) Recording</button>
            }
            @* A generic RTSP camera has no device controls at all — don't offer an
               empty tab when the recording one exists. The tab waits for the camera
               to answer (its body reads capabilities), so it appears once online. *@
            @if (_caps is { Online: true } && (HasDeviceControls || _recording == null))
            {
                <button class="settings-tab @(_camTab == "controls" ? "active" : "")" role="tab"
                        @onclick='() => _camTab = "controls"'>
                    @UiIcon.Render("gear", 13) Camera settings
                    @if (PendingCount > 0)
                    {
                        <span class="tab-dot" title="Unsaved changes">●</span>
                    }
                </button>
            }
        </div>

        @* Masonry body: sections flow into two columns on wide screens (one on
           mobile) — each card keeps its grouping and never splits across columns.
           The columns live on the inner wrapper so the body can scroll; the
           Recording tab is one big card and gets the full width. *@
        <div class="campanel-body">
        <div class="campanel-cols @(_camTab == "recording" ? "one-col" : "")">
        @* The controls body reads capabilities/features, so it only renders once
           the camera has answered (_caps != null) — the probing hint covers the wait. *@
        @if (_camTab == "controls" && _caps != null)
        {
        @if (_profiles is { Count: > 0 })
        {
            var canSetStream = _caps.Features?.StreamSettings == true;
            <div class="campanel-section">
                <div class="campanel-section-title">@UiIcon.Render("film", 13) STREAMS</div>
                @foreach (var group in _profiles.GroupBy(p => p.Type))
                {
                    @* The camera reports one encode table per selectable resolution;
                       identical duplicates are deduped. Resolution picks the table,
                       the selects offer that table's full fps/bitrate ranges. *@
                    var options = group
                        .DistinctBy(p => (p.Width, p.Height, p.DefaultFramerate, p.DefaultBitrate))
                        .ToList();
                    var kind = group.Key;
                    var sel = SelectedTable(kind, options);
                    var pending = _pendingStreams.GetValueOrDefault(kind);
                    <div class="stream-group">
                        <span class="stream-group-name">@group.First().Label @PendingMark(pending?.ToString())</span>
                        <div class="stream-options">
                            @foreach (var p in options)
                            {
                                @if (canSetStream)
                                {
                                    <button class="chip stream-chip clickable @(IsPendingTable(kind, p) ? "chip-pending" : IsActiveProfile(p) ? "chip-active" : "")"
                                            disabled="@_applying"
                                            title="Framerates: @string.Join(", ", p.Framerates) fps — Bitrates: @string.Join(", ", p.Bitrates) kbps"
                                            @onclick="() => StageResolution(kind, p, options)">
                                        @(p.Width)×@(p.Height)
                                    </button>
                                }
                                else
                                {
                                    <span class="chip stream-chip @(IsActiveProfile(p) ? "chip-active" : "")"
                                          title="Framerates: @string.Join(", ", p.Framerates) fps — Bitrates: @string.Join(", ", p.Bitrates) kbps">
                                        @(p.Width)×@(p.Height) · @p.DefaultFramerate fps · @p.DefaultBitrate kbps
                                    </span>
                                }
                            }
                            @if (canSetStream && sel != null)
                            {
                                var shownFps = pending?.Fps ?? CurrentFps(kind) ?? sel.DefaultFramerate;
                                var shownKbps = pending?.Kbps ?? CurrentKbps(kind) ?? sel.DefaultBitrate;
                                <label class="stream-tune @(pending != null ? "tune-pending" : "")">
                                    <select disabled="@_applying" value="@shownFps"
                                            @onchange="e => StageFps(kind, uint.Parse((string)e.Value!), options)">
                                        @foreach (var f in TableValues(sel.Framerates, shownFps))
                                        {
                                            <option value="@f">@f fps</option>
                                        }
                                    </select>
                                </label>
                                <label class="stream-tune @(pending != null ? "tune-pending" : "")">
                                    <select disabled="@_applying" value="@shownKbps"
                                            @onchange="e => StageKbps(kind, uint.Parse((string)e.Value!), options)">
                                        @foreach (var b in TableValues(sel.Bitrates, shownKbps))
                                        {
                                            <option value="@b">@b kbps</option>
                                        }
                                    </select>
                                </label>
                            }
                        </div>
                    </div>
                }
                <div class="notice small">
                    @(canSetStream
                        ? "Read from the camera; the highlighted resolution is live and the menus show its full framerate/bitrate tables. Changes stage — nothing is sent until you apply below."
                        : "Read from the camera; the highlighted profile is live. To change profiles from here, set the camera's \"http_address\" in the server config.")
                </div>
            </div>
        }

        @if (_caps.Features?.Battery == true && _battery != null)
        {
            <div class="campanel-section">
                <div class="campanel-section-title">@UiIcon.Render("battery", 13) BATTERY</div>
                <table class="kv">
                    @if (Num(_battery, "batteryPercent") is { } pct) { <tr><td>Charge</td><td>@pct%</td></tr> }
                    @if (Str(_battery, "chargeStatus") is { Length: > 0 } cs) { <tr><td>Status</td><td>@cs</td></tr> }
                    @if (Num(_battery, "temperature") is { } temp) { <tr><td>Temperature</td><td>@temp °C</td></tr> }
                </table>
            </div>
        }

        @if (_caps.Features?.Ptz == true)
        {
            <div class="campanel-section">
                <div class="campanel-section-title">@UiIcon.Render("move", 13) PAN / TILT</div>
                <div class="ptz-row">
                    <div class="ptz-pad">
                        <span></span>
                        <button class="tool-btn" title="Up (hold)"
                                @onpointerdown='() => PtzAsync("up")' @onpointerup="PtzStopAsync" @onpointerleave="PtzStopAsync">▲</button>
                        <span></span>
                        <button class="tool-btn" title="Left (hold)"
                                @onpointerdown='() => PtzAsync("left")' @onpointerup="PtzStopAsync" @onpointerleave="PtzStopAsync">◀</button>
                        <button class="tool-btn" title="Stop" @onclick="PtzStopAsync">■</button>
                        <button class="tool-btn" title="Right (hold)"
                                @onpointerdown='() => PtzAsync("right")' @onpointerup="PtzStopAsync" @onpointerleave="PtzStopAsync">▶</button>
                        <span></span>
                        <button class="tool-btn" title="Down (hold)"
                                @onpointerdown='() => PtzAsync("down")' @onpointerup="PtzStopAsync" @onpointerleave="PtzStopAsync">▼</button>
                        <span></span>
                    </div>
                    <label class="ptz-speed">
                        Speed @_ptzSpeed
                        <input type="range" min="1" max="64" @bind="_ptzSpeed" @bind:event="oninput" />
                    </label>
                </div>
                @if (_http?.PtzPresets is { } presets)
                {
                    var saved = presets.Where(p => p.Enabled).ToList();
                    <div class="campanel-divider"></div>
                    <div class="campanel-subtitle">@UiIcon.Render("move", 12) PRESETS <span class="beta-tag">BETA</span></div>
                    @if (saved.Count > 0)
                    {
                        <div class="stream-options">
                            @foreach (var p in saved)
                            {
                                <button class="chip" disabled="@_presetBusy"
                                        title="Move the camera to this saved position"
                                        @onclick="() => GoToPresetAsync(p.Id)">@p.Name</button>
                            }
                        </div>
                    }
                    <div class="control-row row-inline">
                        <input class="ret-input" style="width:14ch" type="text" maxlength="31"
                               placeholder="name this position" @bind="_newPresetName" />
                        <button class="chip" disabled="@(_presetBusy || string.IsNullOrWhiteSpace(_newPresetName))"
                                title="Saves where the camera points right now"
                                @onclick="SavePresetAsync">Save current</button>
                    </div>
                }
            </div>
        }

        @if (_caps.Features?.Zoom == true && _zoomFocus?.Zoom is { Max: > 0 } zr)
        {
            <div class="campanel-section">
                <div class="campanel-section-title">@UiIcon.Render("zoom", 13) ZOOM / FOCUS</div>
                @* Live controls like PTZ: the lens moves when you let go of the
                   slider — an absolute position, so there is nothing to stage. *@
                <div class="control-row">
                    <span>Optical zoom</span>
                    <input class="zf-slider" type="range" min="@zr.Min" max="@zr.Max" step="1"
                           disabled="@_zfBusy" value="@(_zoomShown ?? zr.Cur)"
                           @oninput="e => _zoomShown = long.Parse((string)e.Value!)"
                           @onchange="e => SetZoomFocusAsync(zoom: long.Parse((string)e.Value!))" />
                    <span class="zf-pos">@(_zoomShown ?? zr.Cur)/@zr.Max</span>
                </div>
                @if (_zoomFocus.Focus is { Max: > 0 } fr)
                {
                    <div class="control-row">
                        <span>Focus</span>
                        <input class="zf-slider" type="range" min="@fr.Min" max="@fr.Max" step="1"
                               disabled="@_zfBusy" value="@(_focusShown ?? fr.Cur)"
                               @oninput="e => _focusShown = long.Parse((string)e.Value!)"
                               @onchange="e => SetZoomFocusAsync(focus: long.Parse((string)e.Value!))" />
                        <span class="zf-pos">@(_focusShown ?? fr.Cur)/@fr.Max</span>
                    </div>
                    <div class="notice small">Most cameras refocus automatically after a zoom — move the focus slider only to override.</div>
                }
            </div>
        }

        @if (_caps.Features?.Led == true && _led != null)
        {
            <div class="campanel-section">
                <div class="campanel-section-title">@UiIcon.Render("sun", 13) LIGHTS</div>
                @* LedState semantics (per the BC protocol): "state" drives the IR
                   night-vision LEDs. "lightState" is the white spotlight on cameras
                   that have one (its on/off) and the little status LED on those that
                   don't — so it's labelled by the floodlight capability below. *@
                @if (Str(_led, "state") is { Length: > 0 } irState)
                {
                    <div class="control-row">
                        <span>Infrared night vision @PendingMark(_pendingIr)</span>
                        <select class="@(_pendingIr != null ? "input-pending" : "")" value="@(_pendingIr ?? irState)"
                                disabled="@_applying" @onchange='e => StageIr((string?)e.Value)'>
                            <option value="auto">auto</option>
                            <option value="open">on</option>
                            <option value="close">off</option>
                        </select>
                    </div>
                }
                @if (Str(_led, "lightState") is { Length: > 0 } lightState)
                {
                    var shownLed = _pendingStatusLed ?? lightState;
                    // lightState is the floodlight on/off on floodlight cams, otherwise
                    // the little status LED (the white spotlight is the HTTP white LED).
                    var lightLabel = _caps.Features?.Floodlight == true ? "Floodlight" : "Status LED";
                    <div class="control-row">
                        <span>@lightLabel @PendingMark(_pendingStatusLed)</span>
                        <button class="chip @(shownLed == "open" ? "" : "chip-off") @(_pendingStatusLed != null ? "chip-pending" : "")"
                                disabled="@_applying" @onclick="StageStatusLedToggle">
                            @(shownLed == "open" ? "on" : "off")
                        </button>
                    </div>
                }
                @if (_caps.Features?.Floodlight == true && _floodlight is { } flCur)
                {
                    @* The spotlight's BEHAVIOR (staged like other device settings);
                       the Floodlight on/off toggle above drives it directly. *@
                    <div class="control-row">
                        <span>Floodlight brightness @PendingMark(_pendingFlBrightness?.ToString())</span>
                        <input class="zf-slider @(_pendingFlBrightness != null ? "input-pending" : "")"
                               type="range" min="@flCur.BrightnessMin" max="@flCur.BrightnessMax" step="1"
                               disabled="@_applying" value="@(_pendingFlBrightness ?? flCur.Brightness)"
                               @oninput="e => StageFlBrightness(long.Parse((string)e.Value!))" />
                        <span class="zf-pos">@(_pendingFlBrightness ?? flCur.Brightness)</span>
                    </div>
                    <div class="control-row">
                        <span>Auto: on motion at night @PendingMark(_pendingFlAuto?.ToString())</span>
                        <button class="chip @((_pendingFlAuto ?? flCur.Auto) ? "" : "chip-off") @(_pendingFlAuto != null ? "chip-pending" : "")"
                                disabled="@_applying" @onclick="StageFlAutoToggle">
                            @((_pendingFlAuto ?? flCur.Auto) ? "on" : "off")
                        </button>
                    </div>
                }
                @* The white spotlight over the HTTP API (Elite, ...): its on/off is the
                   white-LED mode; brightness only matters (and only shows) while it's on. *@
                @if (_caps.Features?.WhiteLed == true && _whiteLed is { } wl)
                {
                    var spotOn = _pendingWlAuto ?? (wl.Mode != 0);
                    <div class="control-row">
                        <span>Spotlight @PendingMark(_pendingWlAuto?.ToString())</span>
                        <button class="chip @(spotOn ? "" : "chip-off") @(_pendingWlAuto != null ? "chip-pending" : "")"
                                disabled="@_applying" @onclick="StageWlAutoToggle">
                            @(spotOn ? "on" : "off")
                        </button>
                    </div>
                    @if (spotOn)
                    {
                        <div class="control-row">
                            <span>Spotlight brightness @PendingMark(_pendingWlBright?.ToString())</span>
                            <input class="zf-slider @(_pendingWlBright != null ? "input-pending" : "")"
                                   type="range" min="0" max="100" step="1"
                                   disabled="@_applying" value="@(_pendingWlBright ?? wl.Bright)"
                                   @oninput="e => StageWlBright(long.Parse((string)e.Value!))" />
                            <span class="zf-pos">@(_pendingWlBright ?? wl.Bright)</span>
                        </div>
                    }
                }
                @* Gated on real doorbell ability (Support doorbellVersion), not just the
                   field: the Elite WiFi line reports a doorbellLightState it doesn't have. *@
                @if (_caps.Features?.Doorbell == true && Str(_led, "doorbellLightState") is { Length: > 0 } dbLight)
                {
                    var shownDb = _pendingDoorbellLed ?? dbLight;
                    <div class="control-row">
                        <span>Doorbell light <span class="beta-tag">BETA</span> @PendingMark(_pendingDoorbellLed)</span>
                        <button class="chip @(shownDb == "open" ? "" : "chip-off") @(_pendingDoorbellLed != null ? "chip-pending" : "")"
                                disabled="@_applying" @onclick="StageDoorbellLedToggle">
                            @(shownDb == "open" ? "on" : "off")
                        </button>
                    </div>
                }
                @if (Num(_led, "IRLedBrightness") is { } irCur)
                {
                    <div class="control-row">
                        <span>Infrared brightness <span class="beta-tag">BETA</span> @PendingMark(_pendingIrBright?.ToString())</span>
                        <input class="zf-slider @(_pendingIrBright != null ? "input-pending" : "")"
                               type="range" min="0" max="100" step="1"
                               disabled="@_applying" value="@(_pendingIrBright ?? irCur)"
                               @oninput="e => StageIrBright(long.Parse((string)e.Value!))" />
                        <span class="zf-pos">@(_pendingIrBright ?? irCur)</span>
                    </div>
                }
            </div>
        }

        @if (_http?.Image is { } img)
        {
            <div class="campanel-section">
                <div class="campanel-section-title">@UiIcon.Render("film", 13) PICTURE <span class="beta-tag">BETA</span></div>
                @PictureSlider("Brightness", img.Bright, _pendingBright, StageBright)
                @PictureSlider("Contrast", img.Contrast, _pendingContrast, StageContrast)
                @PictureSlider("Saturation", img.Saturation, _pendingSaturation, StageSaturation)
                @PictureSlider("Hue", img.Hue, _pendingHue, StageHue)
                @PictureSlider("Sharpness", img.Sharpen, _pendingSharpen, StageSharpen)
                @if (img.DayNight is { Length: > 0 })
                {
                    <div class="control-row">
                        <span>Day / night mode @PendingMark(_pendingDayNight)</span>
                        <select class="@(_pendingDayNight != null ? "input-pending" : "")"
                                value="@(_pendingDayNight ?? img.DayNight)"
                                disabled="@_applying" @onchange='e => StageDayNight((string?)e.Value)'>
                            <option value="Auto">auto</option>
                            <option value="Color">always color</option>
                            @* Value must come from C#: Blazor does NOT decode HTML
                               entities in attribute values, so value="Black&amp;White"
                               would send the literal "&amp;" to the API. *@
                            <option value="@DayNightBw">always black &amp; white</option>
                        </select>
                    </div>
                }
                @if (img.AntiFlicker is { Length: > 0 })
                {
                    <div class="control-row">
                        <span>Anti-flicker @PendingMark(_pendingAntiFlicker)</span>
                        <select class="@(_pendingAntiFlicker != null ? "input-pending" : "")"
                                value="@(_pendingAntiFlicker ?? img.AntiFlicker)"
                                disabled="@_applying" @onchange='e => StageAntiFlicker((string?)e.Value)'>
                            <option value="Off">off</option>
                            <option value="Outdoor">outdoor</option>
                            <option value="50HZ">50 Hz</option>
                            <option value="60HZ">60 Hz</option>
                        </select>
                    </div>
                }
                @if (img.Hdr is { } hdrCur)
                {
                    <div class="control-row">
                        <span>HDR <span class="beta-tag">BETA</span> @PendingMark(_pendingHdr?.ToString())</span>
                        <select class="@(_pendingHdr != null ? "input-pending" : "")"
                                value="@(_pendingHdr ?? hdrCur)"
                                disabled="@_applying" @onchange="e => StageHdr(int.Parse((string)e.Value!))">
                            <option value="0">off</option>
                            @* The camera's range table says whether HDR is a plain
                               on/off or the newer off/low/high three-step. *@
                            @if ((img.HdrMax ?? 1) >= 2)
                            {
                                <option value="1">low</option>
                                <option value="2">high</option>
                            }
                            else
                            {
                                <option value="1">on</option>
                            }
                        </select>
                    </div>
                }
                @if (img.Flip is { } flipCur)
                {
                    var shownFlip = _pendingFlip ?? flipCur;
                    <div class="control-row">
                        <span>Flip upside-down @PendingMark(_pendingFlip?.ToString())</span>
                        <button class="chip @(shownFlip ? "" : "chip-off") @(_pendingFlip != null ? "chip-pending" : "")"
                                disabled="@_applying" @onclick="StageFlipToggle">
                            @(shownFlip ? "on" : "off")
                        </button>
                    </div>
                }
                @if (img.Mirror is { } mirrorCur)
                {
                    var shownMirror = _pendingMirror ?? mirrorCur;
                    <div class="control-row">
                        <span>Mirror horizontally @PendingMark(_pendingMirror?.ToString())</span>
                        <button class="chip @(shownMirror ? "" : "chip-off") @(_pendingMirror != null ? "chip-pending" : "")"
                                disabled="@_applying" @onclick="StageMirrorToggle">
                            @(shownMirror ? "on" : "off")
                        </button>
                    </div>
                }
                <div class="notice small">Read from the camera. 128 is neutral for the sliders; changes stage until applied below.</div>
            </div>
        }

        @if (_http?.Volume is { } vol)
        {
            <div class="campanel-section">
                <div class="campanel-section-title">@UiIcon.Render("siren", 13) SPEAKER <span class="beta-tag">BETA</span></div>
                <div class="control-row">
                    <span>Volume @PendingMark(_pendingVolume?.ToString())</span>
                    <input class="zf-slider @(_pendingVolume != null ? "input-pending" : "")"
                           type="range" min="0" max="100" step="1"
                           disabled="@_applying" value="@(_pendingVolume ?? vol)"
                           @oninput="e => StageVolume(long.Parse((string)e.Value!))" />
                    <span class="zf-pos">@(_pendingVolume ?? vol)</span>
                </div>
                <div class="notice small">How loud the camera's speaker plays — sirens, alerts and two-way talk alike.</div>
            </div>
        }

        @if (_http?.AutoTrack is { } track)
        {
            <div class="campanel-section">
                <div class="campanel-section-title">@UiIcon.Render("activity", 13) AUTO-TRACKING <span class="beta-tag">BETA</span></div>
                <div class="control-row">
                    <span>Follow detected subjects @PendingMark(_pendingAutoTrack?.ToString())</span>
                    <button class="chip @((_pendingAutoTrack ?? track) ? "" : "chip-off") @(_pendingAutoTrack != null ? "chip-pending" : "")"
                            disabled="@_applying" @onclick="StageAutoTrackToggle">
                        @((_pendingAutoTrack ?? track) ? "on" : "off")
                    </button>
                </div>
            </div>
        }

        @if (_http?.MdSensitivity != null || _http?.AiSensitivities is { Count: > 0 })
        {
            <div class="campanel-section">
                <div class="campanel-section-title">@UiIcon.Render("bolt", 13) DETECTION SENSITIVITY <span class="beta-tag">BETA</span></div>
                @if (_http?.MdSensitivity is { } mdSens)
                {
                    <div class="control-row">
                        <span>Motion @PendingMark(_pendingMdSens?.ToString())</span>
                        <input class="zf-slider @(_pendingMdSens != null ? "input-pending" : "")"
                               type="range" min="1" max="50" step="1"
                               disabled="@_applying" value="@(_pendingMdSens ?? mdSens)"
                               @oninput="e => StageMdSens(long.Parse((string)e.Value!))" />
                        <span class="zf-pos">@(_pendingMdSens ?? mdSens)/50</span>
                    </div>
                }
                @foreach (var ai in _http?.AiSensitivities ?? new List<ApiAiSensitivity>())
                {
                    var type = ai.Type;
                    long? aiPending = _pendingAiSens.TryGetValue(type, out var pv) ? pv : null;
                    <div class="control-row">
                        <span>@ai.Label @PendingMark(aiPending?.ToString())</span>
                        <input class="zf-slider @(aiPending != null ? "input-pending" : "")"
                               type="range" min="0" max="100" step="1"
                               disabled="@_applying" value="@(aiPending ?? ai.Sensitivity)"
                               @oninput="e => StageAiSens(type, long.Parse((string)e.Value!))" />
                        <span class="zf-pos">@(aiPending ?? ai.Sensitivity)/100</span>
                    </div>
                }
                <div class="notice small">
                    Higher = more sensitive (more alerts). These tune the <b>camera's own</b>
                    detection thresholds — they affect its app notifications and this server's
                    event recording alike.
                </div>
            </div>
        }

        @if (_http?.Osd is { } osd)
        {
            var posOptions = osd.PosOptions ?? new List<string>();
            <div class="campanel-section">
                <div class="campanel-section-title">@UiIcon.Render("logs", 13) ON-SCREEN DISPLAY <span class="beta-tag">BETA</span></div>
                <div class="control-row">
                    <span>Camera name overlay @PendingMark(_pendingOsdName?.ToString())</span>
                    <button class="chip @((_pendingOsdName ?? osd.ShowName) ? "" : "chip-off") @(_pendingOsdName != null ? "chip-pending" : "")"
                            disabled="@_applying" @onclick="StageOsdNameToggle">
                        @((_pendingOsdName ?? osd.ShowName) ? "on" : "off")
                    </button>
                </div>
                @if ((_pendingOsdName ?? osd.ShowName) && posOptions.Count > 0)
                {
                    <div class="control-row">
                        <span>Name position @PendingMark(_pendingOsdNamePos)</span>
                        <select class="@(_pendingOsdNamePos != null ? "input-pending" : "")"
                                value="@(_pendingOsdNamePos ?? osd.NamePos ?? posOptions[0])"
                                disabled="@_applying" @onchange='e => StageOsdNamePos((string?)e.Value)'>
                            @foreach (var pos in PosChoices(posOptions, osd.NamePos))
                            {
                                <option value="@pos">@pos.ToLowerInvariant()</option>
                            }
                        </select>
                    </div>
                }
                <div class="control-row">
                    <span>Timestamp overlay @PendingMark(_pendingOsdTime?.ToString())</span>
                    <button class="chip @((_pendingOsdTime ?? osd.ShowTime) ? "" : "chip-off") @(_pendingOsdTime != null ? "chip-pending" : "")"
                            disabled="@_applying" @onclick="StageOsdTimeToggle">
                        @((_pendingOsdTime ?? osd.ShowTime) ? "on" : "off")
                    </button>
                </div>
                @if ((_pendingOsdTime ?? osd.ShowTime) && posOptions.Count > 0)
                {
                    <div class="control-row">
                        <span>Timestamp position @PendingMark(_pendingOsdTimePos)</span>
                        <select class="@(_pendingOsdTimePos != null ? "input-pending" : "")"
                                value="@(_pendingOsdTimePos ?? osd.TimePos ?? posOptions[0])"
                                disabled="@_applying" @onchange='e => StageOsdTimePos((string?)e.Value)'>
                            @foreach (var pos in PosChoices(posOptions, osd.TimePos))
                            {
                                <option value="@pos">@pos.ToLowerInvariant()</option>
                            }
                        </select>
                    </div>
                }
                @if (osd.Watermark is { } wmCur)
                {
                    <div class="control-row">
                        <span>Reolink watermark @PendingMark(_pendingOsdWatermark?.ToString())</span>
                        <button class="chip @((_pendingOsdWatermark ?? wmCur) ? "" : "chip-off") @(_pendingOsdWatermark != null ? "chip-pending" : "")"
                                disabled="@_applying" @onclick="StageOsdWatermarkToggle">
                            @((_pendingOsdWatermark ?? wmCur) ? "on" : "off")
                        </button>
                    </div>
                }
                <div class="notice small">Burned into the video by the camera itself — it shows in live view and every recording, here and elsewhere.</div>
            </div>
        }

        @if (_caps.Features?.Doorbell == true && _http?.QuickReplies is { Count: > 0 } replies)
        {
            <div class="campanel-section">
                <div class="campanel-section-title">@UiIcon.Render("bell", 13) QUICK REPLY <span class="beta-tag">BETA</span></div>
                <div class="control-row row-inline">
                    <select class="qr-select" @bind="_quickReplyId">
                        @foreach (var r in replies)
                        {
                            <option value="@r.Id">@r.Name</option>
                        }
                    </select>
                    <button class="chip" disabled="@_quickReplyBusy" @onclick="PlayQuickReplyAsync">
                        @(_quickReplyBusy ? "Playing…" : "Play")
                    </button>
                </div>
                <div class="notice small">Plays the selected pre-recorded message through the camera's speaker.</div>
            </div>
        }

        @if (_caps.Features?.Siren == true)
        {
            <div class="campanel-section">
                <div class="campanel-section-title">@UiIcon.Render("siren", 13) SIREN</div>
                <div class="control-row">
                    <span>@(_sirenOn == true ? "Sounding now" : "Sound the siren")</span>
                    @if (_sirenOn == true)
                    {
                        <button class="chip chip-danger" @onclick="() => SirenAsync(false)">Stop siren</button>
                    }
                    else if (!_confirmSiren)
                    {
                        <button class="chip" @onclick="() => _confirmSiren = true">Siren…</button>
                    }
                    else
                    {
                        <span class="row-actions">
                            <button class="chip chip-danger" @onclick="() => SirenAsync(true)">Confirm — sounds until stopped</button>
                            <button class="chip" @onclick="() => _confirmSiren = false">Cancel</button>
                        </span>
                    }
                </div>
            </div>
        }

        @if (_caps.Features?.Privacy == true)
        {
            <div class="campanel-section">
                <div class="campanel-section-title">@UiIcon.Render("eye-off", 13) PRIVACY MODE</div>
                <div class="control-row">
                    <span>Camera dark (no video, no detections)</span>
                    @if (_privacyBusy)
                    {
                        @* Spinner while the write is in flight — the buttons are gone
                           so a slow camera can't be double-toggled; caps at 10s. *@
                        <span class="chip chip-off" aria-busy="true"><span class="btn-spinner"></span>Switching…</span>
                    }
                    else if (_privacyOn == true)
                    {
                        <button class="chip chip-active" @onclick="() => SetPrivacyAsync(false)">on — click to wake</button>
                    }
                    else if (!_confirmPrivacy)
                    {
                        <button class="chip chip-off" @onclick="() => _confirmPrivacy = true">off</button>
                    }
                    else
                    {
                        <span class="row-actions">
                            <button class="chip chip-danger" @onclick="() => SetPrivacyAsync(true)">Confirm — stops video &amp; recording</button>
                            <button class="chip" @onclick="() => _confirmPrivacy = false">Cancel</button>
                        </span>
                    }
                </div>
                @if (_privacyOn == true)
                {
                    <div class="notice small">The stream drops while private; Neolink.NET keeps the control
                        connection and the toggle stays available.</div>
                }
            </div>
        }

        @if (_caps.Features?.Pir == true && _pir != null)
        {
            <div class="campanel-section">
                <div class="campanel-section-title">@UiIcon.Render("activity", 13) PIR MOTION SENSOR</div>
                <div class="control-row">
                    <span>Enabled @PendingMark(_pendingPir?.ToString())</span>
                    <button class="chip @((_pendingPir ?? PirEnabled) ? "" : "chip-off") @(_pendingPir != null ? "chip-pending" : "")"
                            disabled="@_applying" @onclick="StagePirToggle">
                        @((_pendingPir ?? PirEnabled) ? "on" : "off")
                    </button>
                </div>
            </div>
        }

        }

        @if (_camTab == "recording" && _recording != null)
        {
            <div class="campanel-section">
                <div class="campanel-section-title">@UiIcon.Render("rec", 13) RECORDING</div>
                <div class="notice small">
                    These are <b>Neolink.NET server</b> settings — what this server records from the
                    camera's streams. Nothing here is sent to the camera or changes its own
                    (SD-card) recording.
                </div>
                @if (!CanEditRecording)
                {
                    <div class="notice small">Only an <b>admin</b> can change recording settings — shown read-only.</div>
                }
                <fieldset class="rec-lock" disabled="@(!CanEditRecording)">
                @if ((_recording.AvailableStreams?.Count ?? 0) > 1)
                {
                    <div class="control-row">
                        <span>Record from stream</span>
                        <select class="event-filter" value="@(_recording.RecordStream ?? "")"
                                title="Which of this camera's streams gets taped (events and 24/7 alike)"
                                @onchange='e => SetRecordingAsync(recordStream: (string?)e.Value ?? "")'>
                            <option value="">default (@StreamLabel(_recording.DefaultRecordStream))</option>
                            @foreach (var kind in _recording.AvailableStreams!)
                            {
                                <option value="@kind">@StreamLabel(kind)</option>
                            }
                        </select>
                    </div>
                }
                <div class="campanel-divider"></div>
                <div class="campanel-subtitle">@UiIcon.Render("bolt", 12) EVENTS</div>
                @if (_recording.EventsAvailable)
                {
                    <div class="control-row">
                        <span>Detection events</span>
                        <button class="chip @(_recording.Events ? "" : "chip-off")"
                                @onclick="() => SetRecordingAsync(events: !_recording.Events)">
                            @(_recording.Events ? "on" : "off")
                        </button>
                    </div>
                }
                else
                {
                    <div class="notice small">
                        This camera has no detection pushes (generic RTSP), so event recording
                        is unavailable — continuous (24/7) recording works normally.
                    </div>
                }
                @if (_recording.EventsAvailable && _recording.Events)
                {
                    <div class="control-row">
                        <span>Keep event clips (days)</span>
                        <input class="ret-input" type="number" min="0" step="1"
                               placeholder="@RetentionLabel(_recording.DefaultEventRetentionDays)"
                               title="How long this camera's event clips are kept. Blank = server default, 0 = keep forever."
                               value="@(_recording.EventRetentionDays?.ToString() ?? "")"
                               @onchange="e => SetRetentionAsync(forEvents: true, (string?)e.Value)" />
                    </div>
                    <div class="control-row rec-types-row">
                        <span>Event types</span>
                        <div class="stream-options">
                            @* Only types this camera can emit: the AI-alarm sweep proves which
                               AI detections the firmware answers for, and the doorbell chip
                               needs a doorbell. Types with no reliable capability signal
                               (crying, perimeter, motion) always show, as does everything
                               while the camera hasn't been probed yet (offline, no HTTP API). *@
                            @foreach (var t in (_recording.KnownTypes ?? new List<string>()).Where(TypeChipVisible))
                            {
                                <button class="chip @(_recording.TypeEnabled(t) ? "" : "chip-off")"
                                        title="@(_recording.TypeEnabled(t) ? "Recording" : "Discarded")"
                                        @onclick="() => ToggleEventTypeAsync(t)">
                                    @TypeIcon(t) @t
                                </button>
                            }
                        </div>
                    </div>
                    <div class="notice small">
                        ⚠ Person/vehicle/animal labels only arrive when the matching Smart Detection is
                        enabled <b>in the Reolink app</b> (camera → Settings → Detection) — the camera does
                        the detecting. The chips filter what this server keeps; disabled types are discarded.
                        @if ((_recording.KnownTypes ?? new List<string>()).Any(t => !TypeChipVisible(t)))
                        {
                            <text> Detection types this camera doesn't support are hidden.</text>
                        }
                    </div>
                    <div class="control-row">
                        <span>Scheduled capture</span>
                        <button class="chip @(_recording.ScheduleEnabled ? "" : "chip-off")"
                                title="@(_recording.ScheduleEnabled ? "Events are captured only inside the schedule below — click to capture at all times" : "Events are captured at all times — click to restrict capture to a schedule")"
                                @onclick="() => SetRecordingAsync(scheduleEnabled: !_recording.ScheduleEnabled)">
                            @(_recording.ScheduleEnabled ? "on" : "off")
                        </button>
                    </div>
                    @if (_recording.ScheduleEnabled)
                    {
                        <div class="sched">
                            <div class="sched-days">
                                @foreach (var d in WeekDayTokens)
                                {
                                    var day = d;
                                    <button class="chip sched-day @(DayEnabled(day) ? "" : "chip-off")"
                                            title="@(DayEnabled(day) ? $"Capturing on {DayName(day)} — click to skip this day" : $"Skipping {DayName(day)} — click to capture")"
                                            @onclick="() => ToggleScheduleDayAsync(day)">@DayLabel(day)</button>
                                }
                            </div>
                            <div class="sched-times">
                                <label class="sched-time">from
                                    <input type="time" value="@(_recording.ScheduleStart ?? "")"
                                           title="Capture from this time of day (blank = midnight)"
                                           @onchange="e => SetScheduleTimeAsync(start: (string?)e.Value)" />
                                </label>
                                <label class="sched-time">until
                                    <input type="time" value="@(_recording.ScheduleEnd ?? "")"
                                           title="Capture until this time of day (blank = midnight). Earlier than “from” spans midnight."
                                           @onchange="e => SetScheduleTimeAsync(end: (string?)e.Value)" />
                                </label>
                                @if (HasTimeWindow)
                                {
                                    <button class="chip" title="Clear the time window — capture at any hour"
                                            @onclick='() => SetScheduleTimeAsync(start: "", end: "")'>all day</button>
                                }
                            </div>
                            <div class="event-sub">@ScheduleSummary</div>
                        </div>
                    }
                }
                @if (_recording.ContinuousAvailable)
                {
                    @* Hairline between the event-based half above and 24/7 below. *@
                    <div class="campanel-divider"></div>
                    <div class="campanel-subtitle">@UiIcon.Render("clock", 12) CONTINUOUS (24/7)</div>
                    <div class="control-row">
                        <span>Record around the clock</span>
                        <button class="chip @(_recording.Continuous ? "" : "chip-off")"
                                @onclick="() => SetRecordingAsync(continuous: !_recording.Continuous)">
                            @(_recording.Continuous ? "on" : "off")
                        </button>
                    </div>
                    @if (_recording.Continuous)
                    {
                        <div class="control-row">
                            <span>Keep continuous footage (days)</span>
                            <input class="ret-input" type="number" min="0" step="1"
                                   placeholder="@RetentionLabel(_recording.DefaultContinuousRetentionDays)"
                                   title="How long this camera's 24/7 footage is kept. Blank = server default, 0 = keep forever."
                                   value="@(_recording.ContinuousRetentionDays?.ToString() ?? "")"
                                   @onchange="e => SetRetentionAsync(forEvents: false, (string?)e.Value)" />
                        </div>
                    }
                }
                @if (_recording.ArchiveAvailable)
                {
                    <div class="campanel-divider"></div>
                    <div class="campanel-subtitle">@UiIcon.Render("archive", 12) ARCHIVE <span class="beta-tag">BETA</span></div>
                    @* Purpose up-front — visible BEFORE anything is switched on. *@
                    <div class="event-sub lc-explain">
                        Normally footage is deleted when its retention ends. Archiving moves it
                        to the server's archive drive instead — still playable, just off the
                        main disk. Watch the lifecycle strip below react as you toggle.
                    </div>
                    <div class="control-row">
                        <span>Archive event clips</span>
                        <button class="chip @(_recording.ArchiveEvents ? "" : "chip-off")"
                                title="@(_recording.ArchiveEvents
                                    ? "When their retention expires, event clips MOVE to the archive drive instead of being deleted — click for plain deletion"
                                    : "Expired event clips are deleted — click to move them to the archive drive instead")"
                                @onclick="() => SetRecordingAsync(archiveEvents: !_recording.ArchiveEvents)">
                            @(_recording.ArchiveEvents ? "on" : "off")
                        </button>
                    </div>
                    <div class="control-row">
                        <span>Archive continuous footage</span>
                        <button class="chip @(_recording.ArchiveContinuous ? "" : "chip-off")"
                                title="@(_recording.ArchiveContinuous
                                    ? "When its retention expires, 24/7 footage MOVES to the archive drive instead of being deleted — click for plain deletion"
                                    : "Expired 24/7 footage is deleted — click to move it to the archive drive instead")"
                                @onclick="() => SetRecordingAsync(archiveContinuous: !_recording.ArchiveContinuous)">
                            @(_recording.ArchiveContinuous ? "on" : "off")
                        </button>
                    </div>
                    @if (_recording.ArchiveEvents || _recording.ArchiveContinuous)
                    {
                        <div class="control-row">
                            <span>Keep in archive (days)</span>
                            <input class="ret-input" type="number" min="0" step="1"
                                   placeholder="forever"
                                   title="How long archived footage is kept before final deletion. Blank or 0 = keep forever."
                                   value="@(_recording.ArchiveRetentionDays?.ToString() ?? "")"
                                   @onchange="e => SetArchiveDaysAsync((string?)e.Value)" />
                        </div>
                    }
                }
                @if ((_recording.EventsAvailable && _recording.Events) || _recording.Continuous)
                {
                    @* The story of this camera's footage, told with the CURRENT settings —
                       it re-renders on every toggle, so cause and effect are immediate. *@
                    <div class="lifecycle"
                         title="Applied by the hourly cleanup. Blank retention = the server default; 0 = keep forever.">
                        <div class="lc-title">FOOTAGE LIFECYCLE</div>
                        @if (_recording.EventsAvailable && _recording.Events)
                        {
                            @LifecycleRow("Events", _recording.EventRetentionDays ?? _recording.DefaultEventRetentionDays, _recording.ArchiveEvents)
                        }
                        @if (_recording.Continuous)
                        {
                            @LifecycleRow("24/7", _recording.ContinuousRetentionDays ?? _recording.DefaultContinuousRetentionDays, _recording.ArchiveContinuous)
                        }
                        @if (_recording.ArchiveEvents || _recording.ArchiveContinuous)
                        {
                            <div class="event-sub">Archived footage stays playable in Events and the Timeline.</div>
                        }
                    </div>
                }
                </fieldset>
            </div>
        }

        @if (_camTab == "controls" && _caps != null && Camera?.CanSuspend == true)
        {
            <div class="campanel-section">
                <div class="campanel-section-title">@UiIcon.Render("eye-off", 13) SUSPEND <span class="beta-tag">BETA</span></div>
                <div class="notice small">
                    Stops <b>Neolink.NET</b> from connecting to this camera — it can't be viewed
                    or recorded here, and its Home Assistant entities go unavailable, until
                    resumed. No restart needed; the setting survives one.
                </div>
                <div class="control-row">
                    <span>Suspended in Neolink.NET @(_suspended == true ? "— on" : "")</span>
                    @if (_suspendBusy)
                    {
                        <span class="chip chip-off" aria-busy="true"><span class="btn-spinner"></span>Saving…</span>
                    }
                    else if (_suspended == true)
                    {
                        <button class="chip chip-active" disabled="@(!CanEditRecording)"
                                @onclick="() => SetSuspendAsync(false)">suspended — click to resume</button>
                    }
                    else if (!_confirmSuspend)
                    {
                        <button class="chip chip-off" disabled="@(!CanEditRecording)"
                                @onclick="() => _confirmSuspend = true">active</button>
                    }
                    else
                    {
                        <span class="row-actions">
                            <button class="chip chip-danger" @onclick="() => SetSuspendAsync(true)">Confirm — stop Neolink.NET for this camera</button>
                            <button class="chip" @onclick="() => _confirmSuspend = false">Cancel</button>
                        </span>
                    }
                </div>
                <div class="notice warn small">
                    ⚠ This only stops <b>Neolink.NET</b>. The camera keeps running: its own
                    <b>SD-card / cloud recording</b> and any <b>other system</b> pulling its
                    stream directly are unaffected. It is not a privacy guarantee.
                </div>
            </div>
        }

        @if (_camTab == "controls" && _caps != null && _caps.Features?.Reboot != false)
        {
            <div class="campanel-section">
                <div class="campanel-section-title">@UiIcon.Render("wrench", 13) MAINTENANCE</div>
                <div class="control-row">
                    <span>Restart the camera</span>
                    @if (!_confirmReboot)
                    {
                        <button class="chip" @onclick="() => _confirmReboot = true">Reboot…</button>
                    }
                    else
                    {
                        <span class="row-actions">
                            <button class="chip chip-danger" @onclick="RebootAsync">Confirm reboot</button>
                            <button class="chip" @onclick="() => _confirmReboot = false">Cancel</button>
                        </span>
                    }
                </div>
            </div>
        }
        </div> @* /campanel-cols *@
        </div> @* /campanel-body *@

        @if (_toast != null)
        {
            <div class="campanel-toast @(_toastError ? "toast-err" : "toast-ok")" role="status">@_toast</div>
        }

        @* Staged device edits: nothing above is sent to the camera until Apply.
           Disruptive changes get called out BEFORE the user commits to them. *@
        @if (PendingCount > 0)
        {
            <div class="campanel-pending">
                @if (PendingMayReboot)
                {
                    <div class="notice warn small">
                        ⚠ The staged <b>resolution change</b> makes some cameras <b>reboot</b> —
                        expect video (and recording) to drop for up to a minute.
                    </div>
                }
                else if (PendingDisruptive)
                {
                    <div class="notice warn small">
                        ⚠ Applying restarts the camera's video stream briefly — live view
                        resumes in a few seconds.
                    </div>
                }
                <div class="campanel-pending-row">
                    <span class="event-sub">
                        @PendingCount unsaved change@(PendingCount == 1 ? "" : "s") — closing
                        the panel discards @(PendingCount == 1 ? "it" : "them").
                    </span>
                    <span class="tile-spacer"></span>
                    <button class="chip" disabled="@_applying" @onclick="DiscardPending">Discard</button>
                    <button class="chip chip-active" disabled="@_applying" @onclick="ApplyPendingAsync">
                        @(_applying ? "Applying…" : "Apply to camera")
                    </button>
                </div>
            </div>
        }
    }
</aside>

@code {
    [Parameter] public string Server { get; set; } = "";
    [Parameter] public string CameraName { get; set; } = "";
    /// <summary>Live stream state (from /api/cameras) used to highlight the active encode profile.</summary>
    [Parameter] public ApiCamera? Camera { get; set; }
    [Parameter] public string? User { get; set; }
    [Parameter] public string? Pass { get; set; }
    /// <summary>Web-UI session token; when present it supersedes the Basic credentials.</summary>
    [Parameter] public string? Token { get; set; }
    /// <summary>Recording settings persist server-side, so only admins may change
    /// them once accounts exist (mirrors the API's gate); false renders them read-only.</summary>
    [Parameter] public bool CanEditRecording { get; set; } = true;
    [Parameter] public EventCallback OnClose { get; set; }

    private ApiCapabilities? _caps;
    private ApiRecordingSettings? _recording;
    private List<ApiEncodeProfile>? _profiles;
    private JsonElement? _battery;
    private JsonElement? _led;
    private JsonElement? _pir;
    private ApiZoomFocus? _zoomFocus;
    private ApiFloodlight? _floodlight;
    private ApiWhiteLed? _whiteLed;
    private ApiHttpFeatures? _http;
    /// <summary>Read-only firmware-update verdict; null = not checkable.</summary>
    private ApiFirmware? _firmware;
    /// <summary>The camera API's black-and-white day/night value ("Black&amp;White").</summary>
    private const string DayNightBw = "Black&White";
    /// <summary>Panel tab: "controls" (device) or "recording" (server-side).</summary>
    private string _camTab = "controls";

    /// <summary>Whether the Camera settings tab has anything to show — false for
