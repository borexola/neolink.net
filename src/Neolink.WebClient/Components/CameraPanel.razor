@using System.Text.Json
@using System.Net.Http.Headers
@inject HttpClient Http

@* Per-camera settings/control dialog. Everything shown is discovered from the
   camera: device info, encode profiles, and the controls the camera supports.
   Deliberately modal: only the ✕ button dismisses it, so a stray click can't
   close it mid-adjustment. *@

<div class="backdrop panel-backdrop"></div>
<aside class="campanel campanel-wide" role="dialog" aria-label="Camera settings">
    <div class="campanel-head">
        <span class="dot @(_caps?.Online == true ? "on" : "off")"></span>
        <span class="campanel-title">@CameraName</span>
        <button class="icon-btn" title="Close" @onclick="CloseAsync">✕</button>
    </div>

    @if (_error != null)
    {
        <div class="notice error">@_error</div>
    }

    @if (_loading)
    {
        <div class="notice">Querying camera…</div>
    }
    else if (_caps != null && !_caps.Online)
    {
        <div class="notice">Camera is offline (reconnecting). Controls appear when it comes back.</div>
    }
    else if (_caps != null)
    {
        @* Masonry body: sections flow into two columns on wide screens (one on
           mobile) — each card keeps its grouping and never splits across columns. *@
        <div class="campanel-body">
        <div class="campanel-section">
            <div class="campanel-section-title">@UiIcon.Render("info", 13) DEVICE</div>
            <table class="kv">
                @if (!string.IsNullOrEmpty(_caps.Version?.Model)) { <tr><td>Model</td><td>@_caps.Version!.Model</td></tr> }
                @if (!string.IsNullOrEmpty(_caps.Version?.Name)) { <tr><td>Name</td><td>@_caps.Version!.Name</td></tr> }
                @if (!string.IsNullOrEmpty(_caps.Version?.Firmware)) { <tr><td>Firmware</td><td>@_caps.Version!.Firmware</td></tr> }
                @if (!string.IsNullOrEmpty(_caps.Version?.Hardware)) { <tr><td>Hardware</td><td>@_caps.Version!.Hardware</td></tr> }
                @if (!string.IsNullOrEmpty(_caps.Version?.Serial)) { <tr><td>Serial</td><td>@_caps.Version!.Serial</td></tr> }
                @if (!string.IsNullOrEmpty(_caps.Version?.Build)) { <tr><td>Build</td><td>@_caps.Version!.Build</td></tr> }
            </table>
        </div>

        @if (_profiles is { Count: > 0 })
        {
            var canSetStream = _caps.Features?.StreamSettings == true;
            <div class="campanel-section">
                <div class="campanel-section-title">@UiIcon.Render("film", 13) STREAMS</div>
                @foreach (var group in _profiles.GroupBy(p => p.Type))
                {
                    @* The camera reports one encode table per selectable resolution;
                       identical duplicates are deduped. Resolution picks the table,
                       the selects offer that table's full fps/bitrate ranges. *@
                    var options = group
                        .DistinctBy(p => (p.Width, p.Height, p.DefaultFramerate, p.DefaultBitrate))
                        .ToList();
                    var kind = group.Key;
                    var sel = SelectedTable(kind, options);
                    var pending = _pendingStreams.GetValueOrDefault(kind);
                    <div class="stream-group">
                        <span class="stream-group-name">@group.First().Label @PendingMark(pending?.ToString())</span>
                        <div class="stream-options">
                            @foreach (var p in options)
                            {
                                @if (canSetStream)
                                {
                                    <button class="chip stream-chip clickable @(IsPendingTable(kind, p) ? "chip-pending" : IsActiveProfile(p) ? "chip-active" : "")"
                                            disabled="@_applying"
                                            title="Framerates: @string.Join(", ", p.Framerates) fps — Bitrates: @string.Join(", ", p.Bitrates) kbps"
                                            @onclick="() => StageResolution(kind, p, options)">
                                        @(p.Width)×@(p.Height)
                                    </button>
                                }
                                else
                                {
                                    <span class="chip stream-chip @(IsActiveProfile(p) ? "chip-active" : "")"
                                          title="Framerates: @string.Join(", ", p.Framerates) fps — Bitrates: @string.Join(", ", p.Bitrates) kbps">
                                        @(p.Width)×@(p.Height) · @p.DefaultFramerate fps · @p.DefaultBitrate kbps
                                    </span>
                                }
                            }
                            @if (canSetStream && sel != null)
                            {
                                var shownFps = pending?.Fps ?? CurrentFps(kind) ?? sel.DefaultFramerate;
                                var shownKbps = pending?.Kbps ?? CurrentKbps(kind) ?? sel.DefaultBitrate;
                                <label class="stream-tune @(pending != null ? "tune-pending" : "")">
                                    <select disabled="@_applying" value="@shownFps"
                                            @onchange="e => StageFps(kind, uint.Parse((string)e.Value!), options)">
                                        @foreach (var f in TableValues(sel.Framerates, shownFps))
                                        {
                                            <option value="@f">@f fps</option>
                                        }
                                    </select>
                                </label>
                                <label class="stream-tune @(pending != null ? "tune-pending" : "")">
                                    <select disabled="@_applying" value="@shownKbps"
                                            @onchange="e => StageKbps(kind, uint.Parse((string)e.Value!), options)">
                                        @foreach (var b in TableValues(sel.Bitrates, shownKbps))
                                        {
                                            <option value="@b">@b kbps</option>
                                        }
                                    </select>
                                </label>
                            }
                        </div>
                    </div>
                }
                <div class="notice small">
                    @(canSetStream
                        ? "Read from the camera; the highlighted resolution is live and the menus show its full framerate/bitrate tables. Changes stage — nothing is sent until you apply below."
                        : "Read from the camera; the highlighted profile is live. To change profiles from here, set the camera's \"http_address\" in the server config.")
                </div>
            </div>
        }

        @if (_caps.Features?.Battery == true && _battery != null)
        {
            <div class="campanel-section">
                <div class="campanel-section-title">@UiIcon.Render("battery", 13) BATTERY</div>
                <table class="kv">
                    @if (Num(_battery, "batteryPercent") is { } pct) { <tr><td>Charge</td><td>@pct%</td></tr> }
                    @if (Str(_battery, "chargeStatus") is { Length: > 0 } cs) { <tr><td>Status</td><td>@cs</td></tr> }
                    @if (Num(_battery, "temperature") is { } temp) { <tr><td>Temperature</td><td>@temp °C</td></tr> }
                </table>
            </div>
        }

        @if (_caps.Features?.Ptz == true)
        {
            <div class="campanel-section">
                <div class="campanel-section-title">@UiIcon.Render("move", 13) PAN / TILT</div>
                <div class="ptz-row">
                    <div class="ptz-pad">
                        <span></span>
                        <button class="tool-btn" title="Up (hold)"
                                @onpointerdown='() => PtzAsync("up")' @onpointerup="PtzStopAsync" @onpointerleave="PtzStopAsync">▲</button>
                        <span></span>
                        <button class="tool-btn" title="Left (hold)"
                                @onpointerdown='() => PtzAsync("left")' @onpointerup="PtzStopAsync" @onpointerleave="PtzStopAsync">◀</button>
                        <button class="tool-btn" title="Stop" @onclick="PtzStopAsync">■</button>
                        <button class="tool-btn" title="Right (hold)"
                                @onpointerdown='() => PtzAsync("right")' @onpointerup="PtzStopAsync" @onpointerleave="PtzStopAsync">▶</button>
                        <span></span>
                        <button class="tool-btn" title="Down (hold)"
                                @onpointerdown='() => PtzAsync("down")' @onpointerup="PtzStopAsync" @onpointerleave="PtzStopAsync">▼</button>
                        <span></span>
                    </div>
                    <label class="ptz-speed">
                        Speed @_ptzSpeed
                        <input type="range" min="1" max="64" @bind="_ptzSpeed" @bind:event="oninput" />
                    </label>
                </div>
            </div>
        }

        @if (_caps.Features?.Zoom == true && _zoomFocus?.Zoom is { Max: > 0 } zr)
        {
            <div class="campanel-section">
                <div class="campanel-section-title">@UiIcon.Render("zoom", 13) ZOOM / FOCUS</div>
                @* Live controls like PTZ: the lens moves when you let go of the
                   slider — an absolute position, so there is nothing to stage. *@
                <div class="control-row">
                    <span>Optical zoom</span>
                    <input class="zf-slider" type="range" min="@zr.Min" max="@zr.Max" step="1"
                           disabled="@_zfBusy" value="@(_zoomShown ?? zr.Cur)"
                           @oninput="e => _zoomShown = long.Parse((string)e.Value!)"
                           @onchange="e => SetZoomFocusAsync(zoom: long.Parse((string)e.Value!))" />
                    <span class="zf-pos">@(_zoomShown ?? zr.Cur)/@zr.Max</span>
                </div>
                @if (_zoomFocus.Focus is { Max: > 0 } fr)
                {
                    <div class="control-row">
                        <span>Focus</span>
                        <input class="zf-slider" type="range" min="@fr.Min" max="@fr.Max" step="1"
                               disabled="@_zfBusy" value="@(_focusShown ?? fr.Cur)"
                               @oninput="e => _focusShown = long.Parse((string)e.Value!)"
                               @onchange="e => SetZoomFocusAsync(focus: long.Parse((string)e.Value!))" />
                        <span class="zf-pos">@(_focusShown ?? fr.Cur)/@fr.Max</span>
                    </div>
                    <div class="notice small">Most cameras refocus automatically after a zoom — move the focus slider only to override.</div>
                }
            </div>
        }

        @if (_caps.Features?.Led == true && _led != null)
        {
            <div class="campanel-section">
                <div class="campanel-section-title">@UiIcon.Render("sun", 13) LIGHTS</div>
                @* LedState semantics (per the BC protocol): "state" drives the IR
                   night-vision LEDs. "lightState" is the white spotlight on cameras
                   that have one (its on/off) and the little status LED on those that
                   don't — so it's labelled by the floodlight capability below. *@
                @if (Str(_led, "state") is { Length: > 0 } irState)
                {
                    <div class="control-row">
                        <span>Infrared night vision @PendingMark(_pendingIr)</span>
                        <select class="@(_pendingIr != null ? "input-pending" : "")" value="@(_pendingIr ?? irState)"
                                disabled="@_applying" @onchange='e => StageIr((string?)e.Value)'>
                            <option value="auto">auto</option>
                            <option value="open">on</option>
                            <option value="close">off</option>
                        </select>
                    </div>
                }
                @if (Str(_led, "lightState") is { Length: > 0 } lightState)
                {
                    var shownLed = _pendingStatusLed ?? lightState;
                    var isFloodlight = _caps.Features?.Floodlight == true;
                    <div class="control-row">
                        <span>@(isFloodlight ? "Floodlight" : "Status LED") @PendingMark(_pendingStatusLed)</span>
                        <button class="chip @(shownLed == "open" ? "" : "chip-off") @(_pendingStatusLed != null ? "chip-pending" : "")"
                                disabled="@_applying" @onclick="StageStatusLedToggle">
                            @(shownLed == "open" ? "on" : "off")
                        </button>
                    </div>
                }
                @if (_caps.Features?.Floodlight == true && _floodlight is { } flCur)
                {
                    @* The spotlight's BEHAVIOR (staged like other device settings);
                       the Floodlight on/off toggle above drives it directly. *@
                    <div class="control-row">
                        <span>Floodlight brightness @PendingMark(_pendingFlBrightness?.ToString())</span>
                        <input class="zf-slider @(_pendingFlBrightness != null ? "input-pending" : "")"
                               type="range" min="@flCur.BrightnessMin" max="@flCur.BrightnessMax" step="1"
                               disabled="@_applying" value="@(_pendingFlBrightness ?? flCur.Brightness)"
                               @oninput="e => StageFlBrightness(long.Parse((string)e.Value!))" />
                        <span class="zf-pos">@(_pendingFlBrightness ?? flCur.Brightness)</span>
                    </div>
                    <div class="control-row">
                        <span>Auto: on motion at night @PendingMark(_pendingFlAuto?.ToString())</span>
                        <button class="chip @((_pendingFlAuto ?? flCur.Auto) ? "" : "chip-off") @(_pendingFlAuto != null ? "chip-pending" : "")"
                                disabled="@_applying" @onclick="StageFlAutoToggle">
                            @((_pendingFlAuto ?? flCur.Auto) ? "on" : "off")
                        </button>
                    </div>
                }
            </div>
        }

        @if (_caps.Features?.Siren == true)
        {
            <div class="campanel-section">
                <div class="campanel-section-title">@UiIcon.Render("siren", 13) SIREN</div>
                <div class="control-row">
                    <span>@(_sirenOn == true ? "Sounding now" : "Sound the siren")</span>
                    @if (_sirenOn == true)
                    {
                        <button class="chip chip-danger" @onclick="() => SirenAsync(false)">Stop siren</button>
                    }
                    else if (!_confirmSiren)
                    {
                        <button class="chip" @onclick="() => _confirmSiren = true">Siren…</button>
                    }
                    else
                    {
                        <button class="chip chip-danger" @onclick="() => SirenAsync(true)">Confirm — sounds until stopped</button>
                        <button class="chip" @onclick="() => _confirmSiren = false">Cancel</button>
                    }
                </div>
            </div>
        }

        @if (_caps.Features?.Privacy == true)
        {
            <div class="campanel-section">
                <div class="campanel-section-title">@UiIcon.Render("eye-off", 13) PRIVACY MODE</div>
                <div class="control-row">
                    <span>Camera dark (no video, no detections)</span>
                    @if (_privacyBusy)
                    {
                        @* Spinner while the write is in flight — the buttons are gone
                           so a slow camera can't be double-toggled; caps at 10s. *@
                        <span class="chip chip-off" aria-busy="true"><span class="btn-spinner"></span>Switching…</span>
                    }
                    else if (_privacyOn == true)
                    {
                        <button class="chip chip-active" @onclick="() => SetPrivacyAsync(false)">on — click to wake</button>
                    }
                    else if (!_confirmPrivacy)
                    {
                        <button class="chip chip-off" @onclick="() => _confirmPrivacy = true">off</button>
                    }
                    else
                    {
                        <button class="chip chip-danger" @onclick="() => SetPrivacyAsync(true)">Confirm — stops video &amp; recording</button>
                        <button class="chip" @onclick="() => _confirmPrivacy = false">Cancel</button>
                    }
                </div>
                @if (_privacyOn == true)
                {
                    <div class="notice small">The stream drops while private; Neolink keeps the control
                        connection and the toggle stays available.</div>
                }
            </div>
        }

        @if (_caps.Features?.Pir == true && _pir != null)
        {
            <div class="campanel-section">
                <div class="campanel-section-title">@UiIcon.Render("activity", 13) PIR MOTION SENSOR</div>
                <div class="control-row">
                    <span>Enabled @PendingMark(_pendingPir?.ToString())</span>
                    <button class="chip @((_pendingPir ?? PirEnabled) ? "" : "chip-off") @(_pendingPir != null ? "chip-pending" : "")"
                            disabled="@_applying" @onclick="StagePirToggle">
                        @((_pendingPir ?? PirEnabled) ? "on" : "off")
                    </button>
                </div>
            </div>
        }

        @if (_recording != null)
        {
            <div class="campanel-section">
                <div class="campanel-section-title">@UiIcon.Render("rec", 13) RECORDING</div>
                <div class="notice small">
                    These are <b>Neolink server</b> settings — what this server records from the
                    camera's streams. Nothing here is sent to the camera or changes its own
                    (SD-card) recording.
                </div>
                @if ((_recording.AvailableStreams?.Count ?? 0) > 1)
                {
                    <div class="control-row">
                        <span>Record from stream</span>
                        <select class="event-filter" value="@(_recording.RecordStream ?? "")"
                                title="Which of this camera's streams gets taped (events and 24/7 alike)"
                                @onchange='e => SetRecordingAsync(recordStream: (string?)e.Value ?? "")'>
                            <option value="">default (@StreamLabel(_recording.DefaultRecordStream))</option>
                            @foreach (var kind in _recording.AvailableStreams!)
                            {
                                <option value="@kind">@StreamLabel(kind)</option>
                            }
                        </select>
                    </div>
                }
                <div class="campanel-divider"></div>
                <div class="campanel-subtitle">@UiIcon.Render("bolt", 12) EVENTS</div>
                @if (_recording.EventsAvailable)
                {
                    <div class="control-row">
                        <span>Detection events</span>
                        <button class="chip @(_recording.Events ? "" : "chip-off")"
                                @onclick="() => SetRecordingAsync(events: !_recording.Events)">
                            @(_recording.Events ? "on" : "off")
                        </button>
                    </div>
                }
                else
                {
                    <div class="notice small">
                        This camera has no detection pushes (generic RTSP), so event recording
                        is unavailable — continuous (24/7) recording works normally.
                    </div>
                }
                @if (_recording.EventsAvailable && _recording.Events)
                {
                    <div class="control-row">
                        <span>Keep event clips (days)</span>
                        <input class="ret-input" type="number" min="0" step="1"
                               placeholder="@RetentionLabel(_recording.DefaultEventRetentionDays)"
                               title="How long this camera's event clips are kept. Blank = server default, 0 = keep forever."
                               value="@(_recording.EventRetentionDays?.ToString() ?? "")"
                               @onchange="e => SetRetentionAsync(forEvents: true, (string?)e.Value)" />
                    </div>
                    <div class="control-row rec-types-row">
                        <span>Event types</span>
                        <div class="stream-options">
                            @foreach (var t in _recording.KnownTypes ?? new List<string>())
                            {
                                <button class="chip @(_recording.TypeEnabled(t) ? "" : "chip-off")"
                                        title="@(_recording.TypeEnabled(t) ? "Recording" : "Discarded")"
                                        @onclick="() => ToggleEventTypeAsync(t)">
                                    @TypeIcon(t) @t
                                </button>
                            }
                        </div>
                    </div>
                    <div class="notice small">
                        ⚠ Person/vehicle/animal labels only arrive when the matching Smart Detection is
                        enabled <b>in the Reolink app</b> (camera → Settings → Detection) — the camera does
                        the detecting. The chips filter what this server keeps; disabled types are discarded.
                    </div>
                    <div class="control-row">
                        <span>Scheduled capture</span>
                        <button class="chip @(_recording.ScheduleEnabled ? "" : "chip-off")"
                                title="@(_recording.ScheduleEnabled ? "Events are captured only inside the schedule below — click to capture at all times" : "Events are captured at all times — click to restrict capture to a schedule")"
                                @onclick="() => SetRecordingAsync(scheduleEnabled: !_recording.ScheduleEnabled)">
                            @(_recording.ScheduleEnabled ? "on" : "off")
                        </button>
                    </div>
                    @if (_recording.ScheduleEnabled)
                    {
                        <div class="sched">
                            <div class="sched-days">
                                @foreach (var d in WeekDayTokens)
                                {
                                    var day = d;
                                    <button class="chip sched-day @(DayEnabled(day) ? "" : "chip-off")"
                                            title="@(DayEnabled(day) ? $"Capturing on {DayName(day)} — click to skip this day" : $"Skipping {DayName(day)} — click to capture")"
                                            @onclick="() => ToggleScheduleDayAsync(day)">@DayLabel(day)</button>
                                }
                            </div>
                            <div class="sched-times">
                                <label class="sched-time">from
                                    <input type="time" value="@(_recording.ScheduleStart ?? "")"
                                           title="Capture from this time of day (blank = midnight)"
                                           @onchange="e => SetScheduleTimeAsync(start: (string?)e.Value)" />
                                </label>
                                <label class="sched-time">until
                                    <input type="time" value="@(_recording.ScheduleEnd ?? "")"
                                           title="Capture until this time of day (blank = midnight). Earlier than “from” spans midnight."
                                           @onchange="e => SetScheduleTimeAsync(end: (string?)e.Value)" />
                                </label>
                                @if (HasTimeWindow)
                                {
                                    <button class="chip" title="Clear the time window — capture at any hour"
                                            @onclick='() => SetScheduleTimeAsync(start: "", end: "")'>all day</button>
                                }
                            </div>
                            <div class="event-sub">@ScheduleSummary</div>
                        </div>
                    }
                }
                @if (_recording.ContinuousAvailable)
                {
                    @* Hairline between the event-based half above and 24/7 below. *@
                    <div class="campanel-divider"></div>
                    <div class="campanel-subtitle">@UiIcon.Render("clock", 12) CONTINUOUS (24/7)</div>
                    <div class="control-row">
                        <span>Record around the clock</span>
                        <button class="chip @(_recording.Continuous ? "" : "chip-off")"
                                @onclick="() => SetRecordingAsync(continuous: !_recording.Continuous)">
                            @(_recording.Continuous ? "on" : "off")
                        </button>
                    </div>
                    @if (_recording.Continuous)
                    {
                        <div class="control-row">
                            <span>Keep continuous footage (days)</span>
                            <input class="ret-input" type="number" min="0" step="1"
                                   placeholder="@RetentionLabel(_recording.DefaultContinuousRetentionDays)"
                                   title="How long this camera's 24/7 footage is kept. Blank = server default, 0 = keep forever."
                                   value="@(_recording.ContinuousRetentionDays?.ToString() ?? "")"
                                   @onchange="e => SetRetentionAsync(forEvents: false, (string?)e.Value)" />
                        </div>
                    }
                }
                @if (_recording.ArchiveAvailable)
                {
                    <div class="campanel-divider"></div>
                    <div class="campanel-subtitle">@UiIcon.Render("archive", 12) ARCHIVE <span class="beta-tag">BETA</span></div>
                    @* Purpose up-front — visible BEFORE anything is switched on. *@
                    <div class="event-sub lc-explain">
                        Normally footage is deleted when its retention ends. Archiving moves it
                        to the server's archive drive instead — still playable, just off the
                        main disk. Watch the lifecycle strip below react as you toggle.
                    </div>
                    <div class="control-row">
                        <span>Archive event clips</span>
                        <button class="chip @(_recording.ArchiveEvents ? "" : "chip-off")"
                                title="@(_recording.ArchiveEvents
                                    ? "When their retention expires, event clips MOVE to the archive drive instead of being deleted — click for plain deletion"
                                    : "Expired event clips are deleted — click to move them to the archive drive instead")"
                                @onclick="() => SetRecordingAsync(archiveEvents: !_recording.ArchiveEvents)">
                            @(_recording.ArchiveEvents ? "on" : "off")
                        </button>
                    </div>
                    <div class="control-row">
                        <span>Archive continuous footage</span>
                        <button class="chip @(_recording.ArchiveContinuous ? "" : "chip-off")"
                                title="@(_recording.ArchiveContinuous
                                    ? "When its retention expires, 24/7 footage MOVES to the archive drive instead of being deleted — click for plain deletion"
                                    : "Expired 24/7 footage is deleted — click to move it to the archive drive instead")"
                                @onclick="() => SetRecordingAsync(archiveContinuous: !_recording.ArchiveContinuous)">
                            @(_recording.ArchiveContinuous ? "on" : "off")
                        </button>
                    </div>
                    @if (_recording.ArchiveEvents || _recording.ArchiveContinuous)
                    {
                        <div class="control-row">
                            <span>Keep in archive (days)</span>
                            <input class="ret-input" type="number" min="0" step="1"
                                   placeholder="forever"
                                   title="How long archived footage is kept before final deletion. Blank or 0 = keep forever."
                                   value="@(_recording.ArchiveRetentionDays?.ToString() ?? "")"
                                   @onchange="e => SetArchiveDaysAsync((string?)e.Value)" />
                        </div>
                    }
                }
                @if ((_recording.EventsAvailable && _recording.Events) || _recording.Continuous)
                {
                    @* The story of this camera's footage, told with the CURRENT settings —
                       it re-renders on every toggle, so cause and effect are immediate. *@
                    <div class="lifecycle"
                         title="Applied by the hourly cleanup. Blank retention = the server default; 0 = keep forever.">
                        <div class="lc-title">FOOTAGE LIFECYCLE</div>
                        @if (_recording.EventsAvailable && _recording.Events)
                        {
                            @LifecycleRow("Events", _recording.EventRetentionDays ?? _recording.DefaultEventRetentionDays, _recording.ArchiveEvents)
                        }
                        @if (_recording.Continuous)
                        {
                            @LifecycleRow("24/7", _recording.ContinuousRetentionDays ?? _recording.DefaultContinuousRetentionDays, _recording.ArchiveContinuous)
                        }
                        @if (_recording.ArchiveEvents || _recording.ArchiveContinuous)
                        {
                            <div class="event-sub">Archived footage stays playable in Events and the Timeline.</div>
                        }
                    </div>
                }
            </div>
        }

        @if (_caps.Features?.Reboot != false)
        {
            <div class="campanel-section">
                <div class="campanel-section-title">@UiIcon.Render("wrench", 13) MAINTENANCE</div>
                <div class="control-row">
                    <span>Restart the camera</span>
                    @if (!_confirmReboot)
                    {
                        <button class="chip" @onclick="() => _confirmReboot = true">Reboot…</button>
                    }
                    else
                    {
                        <button class="chip chip-danger" @onclick="RebootAsync">Confirm reboot</button>
                        <button class="chip" @onclick="() => _confirmReboot = false">Cancel</button>
                    }
                </div>
            </div>
        }
        </div> @* /campanel-body *@

        @if (_status != null)
        {
            <div class="notice">@_status</div>
        }

        @* Staged device edits: nothing above is sent to the camera until Apply.
           Disruptive changes get called out BEFORE the user commits to them. *@
        @if (PendingCount > 0)
        {
            <div class="campanel-pending">
                @if (PendingMayReboot)
                {
                    <div class="notice warn small">
                        ⚠ The staged <b>resolution change</b> makes some cameras <b>reboot</b> —
                        expect video (and recording) to drop for up to a minute.
                    </div>
                }
                else if (PendingDisruptive)
                {
                    <div class="notice warn small">
                        ⚠ Applying restarts the camera's video stream briefly — live view
                        resumes in a few seconds.
                    </div>
                }
                <div class="campanel-pending-row">
                    <span class="event-sub">
                        @PendingCount unsaved change@(PendingCount == 1 ? "" : "s") — closing
                        the panel discards @(PendingCount == 1 ? "it" : "them").
                    </span>
                    <span class="tile-spacer"></span>
                    <button class="chip" disabled="@_applying" @onclick="DiscardPending">Discard</button>
                    <button class="chip chip-active" disabled="@_applying" @onclick="ApplyPendingAsync">
                        @(_applying ? "Applying…" : "Apply to camera")
                    </button>
                </div>
            </div>
        }
    }
</aside>

@code {
    [Parameter] public string Server { get; set; } = "";
    [Parameter] public string CameraName { get; set; } = "";
    /// <summary>Live stream state (from /api/cameras) used to highlight the active encode profile.</summary>
    [Parameter] public ApiCamera? Camera { get; set; }
    [Parameter] public string? User { get; set; }
    [Parameter] public string? Pass { get; set; }
    /// <summary>Web-UI session token; when present it supersedes the Basic credentials.</summary>
    [Parameter] public string? Token { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    private ApiCapabilities? _caps;
    private ApiRecordingSettings? _recording;
    private List<ApiEncodeProfile>? _profiles;
    private JsonElement? _battery;
    private JsonElement? _led;
    private JsonElement? _pir;
    private ApiZoomFocus? _zoomFocus;
    private ApiFloodlight? _floodlight;
    private bool _loading;
    private string? _error;
    private string? _status;
    private bool _confirmReboot;
    private bool _confirmSiren;
    private bool _confirmPrivacy;
    private bool _privacyBusy;   // a privacy-mode write is in flight (spinner shown)
    private bool? _sirenOn;   // last known state (pushes / this panel's own actions)
    private bool? _privacyOn;
    private int _ptzSpeed = 32;
    private string? _loadedFor;

    // Zoom/focus are LIVE controls: the shown value tracks the slider while it
    // drags; the position is written on release and re-read afterwards.
    private long? _zoomShown;
    private long? _focusShown;
    private bool _zfBusy;

    private bool PirEnabled => Num(_pir, "enable") == 1;

    // ---------------------------------------------------------- staged edits
    // Device settings stage locally and are sent only on "Apply to camera":
    // a mis-click can be discarded, and disruptive changes (a profile write
    // restarts the stream; a resolution change reboots some models) are
    // announced by a warning before the user commits. Staging the current
    // value again simply un-stages it.

    /// <summary>One stream's staged encode change: the resolution table + the
    /// fps/bitrate picked from that table's ranges.</summary>
    private sealed record PendingStream(ApiEncodeProfile Table, uint Fps, uint Kbps);

    private readonly Dictionary<string, PendingStream> _pendingStreams = new(StringComparer.Ordinal);
    private List<ApiStreamEnc>? _encCurrent; // the camera's CURRENT selections (null without http_address)
    private string? _pendingIr;          // "auto" | "open" | "close"
    private string? _pendingStatusLed;   // "open" | "close"
    private bool? _pendingPir;
    private long? _pendingFlBrightness;
    private bool? _pendingFlAuto;
    private bool _applying;

    private int PendingCount =>
        _pendingStreams.Count + (_pendingIr != null ? 1 : 0)
        + (_pendingStatusLed != null ? 1 : 0) + (_pendingPir != null ? 1 : 0)
        + (_pendingFlBrightness != null ? 1 : 0) + (_pendingFlAuto != null ? 1 : 0);

    /// <summary>Any staged change that interrupts the device when applied.</summary>
    private bool PendingDisruptive => _pendingStreams.Count > 0;

    /// <summary>A resolution change (not just fps/bitrate) makes some models fully
    /// reboot. "Same resolution" is checked against the camera's reported encode
    /// selection first, the live stream's dimensions as fallback — unknown counts
    /// as a change, so uncertainty over-warns rather than under-warns.</summary>
    private bool PendingMayReboot =>
        _pendingStreams.Any(kv =>
            !(CurrentEnc(kv.Key) is { } e && e.Width == kv.Value.Table.Width && e.Height == kv.Value.Table.Height)
            && Camera?.Streams.Any(s => s.Kind == kv.Value.Table.Type
                && s.Width == kv.Value.Table.Width && s.Height == kv.Value.Table.Height) != true);

    /// <summary>The little "· pending" tag next to a staged control's label.</summary>
    private static string PendingMark(string? pending) => pending != null ? "· pending" : "";

    // ---- streams: resolution picks the table, fps/kbps come from its ranges ----

    private ApiStreamEnc? CurrentEnc(string kind) => _encCurrent?.FirstOrDefault(e => e.Stream == kind);
    private uint? CurrentFps(string kind) => CurrentEnc(kind) is { Framerate: > 0 } e ? e.Framerate : null;
    private uint? CurrentKbps(string kind) => CurrentEnc(kind) is { Bitrate: > 0 } e ? e.Bitrate : null;

    private bool IsPendingTable(string kind, ApiEncodeProfile p) =>
        _pendingStreams.GetValueOrDefault(kind) is { } ps && SameTable(ps.Table, p);

    private static bool SameTable(ApiEncodeProfile a, ApiEncodeProfile b) =>
        a.Width == b.Width && a.Height == b.Height;

    /// <summary>The table whose fps/bitrate ranges the selects offer: the staged
    /// one, else the live resolution's, else the camera's first.</summary>
    private ApiEncodeProfile? SelectedTable(string kind, List<ApiEncodeProfile> options) =>
        _pendingStreams.GetValueOrDefault(kind)?.Table
        ?? options.FirstOrDefault(IsActiveProfile)
        ?? options.FirstOrDefault();

    /// <summary>The table's values, with the shown value included even when the
    /// camera reports something off-table (older firmware quirks).</summary>
    private static IEnumerable<uint> TableValues(List<uint> table, uint shown) =>
        table.Contains(shown) ? table : table.Append(shown).OrderByDescending(v => v);

    private void StageStream(string kind, ApiEncodeProfile table, uint fps, uint kbps, List<ApiEncodeProfile> options)
    {
        // Clamp to the chosen table's ranges (switching tables can strand values).
        if (!table.Framerates.Contains(fps)) fps = table.DefaultFramerate;
        if (!table.Bitrates.Contains(kbps)) kbps = table.DefaultBitrate;

        // Staging exactly the live state again un-stages (nothing to send).
        bool liveTable = IsActiveProfile(table);
        bool liveRates = fps == (CurrentFps(kind) ?? table.DefaultFramerate)
                         && kbps == (CurrentKbps(kind) ?? table.DefaultBitrate);
        if (liveTable && liveRates)
            _pendingStreams.Remove(kind);
        else
            _pendingStreams[kind] = new PendingStream(table, fps, kbps);
    }

    private void StageResolution(string kind, ApiEncodeProfile table, List<ApiEncodeProfile> options)
    {
        var ps = _pendingStreams.GetValueOrDefault(kind);
        StageStream(kind, table,
            ps?.Fps ?? CurrentFps(kind) ?? table.DefaultFramerate,
            ps?.Kbps ?? CurrentKbps(kind) ?? table.DefaultBitrate, options);
    }

    private void StageFps(string kind, uint fps, List<ApiEncodeProfile> options)
    {
        var table = SelectedTable(kind, options);
        if (table == null) return;
        var ps = _pendingStreams.GetValueOrDefault(kind);
        StageStream(kind, table, fps, ps?.Kbps ?? CurrentKbps(kind) ?? table.DefaultBitrate, options);
    }

    private void StageKbps(string kind, uint kbps, List<ApiEncodeProfile> options)
    {
        var table = SelectedTable(kind, options);
        if (table == null) return;
        var ps = _pendingStreams.GetValueOrDefault(kind);
        StageStream(kind, table, ps?.Fps ?? CurrentFps(kind) ?? table.DefaultFramerate, kbps, options);
    }

    private void StageIr(string? value) =>
        _pendingIr = value == null || value == Str(_led, "state") ? null : value;

    private void StageStatusLedToggle()
    {
        var target = (_pendingStatusLed ?? Str(_led, "lightState")) == "open" ? "close" : "open";
        _pendingStatusLed = target == Str(_led, "lightState") ? null : target;
    }

    private void StagePirToggle()
    {
        var target = !(_pendingPir ?? PirEnabled);
        _pendingPir = target == PirEnabled ? null : target;
    }

    private void StageFlBrightness(long value) =>
        _pendingFlBrightness = value == _floodlight?.Brightness ? null : value;

    private void StageFlAutoToggle()
    {
        var target = !(_pendingFlAuto ?? _floodlight?.Auto ?? false);
        _pendingFlAuto = target == _floodlight?.Auto ? null : target;
    }

    private void DiscardPending()
    {
        _pendingStreams.Clear();
        _pendingIr = _pendingStatusLed = null;
        _pendingPir = null;
        _pendingFlBrightness = null;
        _pendingFlAuto = null;
    }

    /// <summary>Sends the staged changes one at a time (the camera answers control
    /// commands serially). Whatever fails stays staged, so Apply can be retried.</summary>
    private async Task ApplyPendingAsync()
    {
        if (_applying) return;
        _applying = true;
        var applied = new List<string>();
        try
        {
            if (_pendingIr is { } ir && await PostAsync("led", new { state = ir }))
            {
                _pendingIr = null;
                applied.Add("night vision");
            }
            if (_pendingStatusLed is { } led && await PostAsync("led", new { lightState = led }))
            {
                _pendingStatusLed = null;
                applied.Add("status LED");
            }
            if (_pendingPir is { } pir && await PostAsync("pir", new { enabled = pir }))
            {
                _pendingPir = null;
                applied.Add("PIR");
            }
            if ((_pendingFlBrightness != null || _pendingFlAuto != null)
                && await PostAsync("floodlight", new { brightness = _pendingFlBrightness, auto = _pendingFlAuto }))
            {
                _pendingFlBrightness = null;
                _pendingFlAuto = null;
                applied.Add("floodlight behavior");
            }
            // The disruptive ones go LAST: the quick settings land before the
            // stream restarts make the camera briefly deaf to commands.
            foreach (var (kind, ps) in _pendingStreams.ToList())
            {
                if (!await PostAsync("settings/stream", new
                    {
                        stream = kind,
                        width = ps.Table.Width,
                        height = ps.Table.Height,
                        framerate = ps.Fps,
                        bitrate = ps.Kbps,
                    }))
                    break; // whatever failed stays staged for retry
                _pendingStreams.Remove(kind);
                applied.Add($"{ps.Table.Label} stream → {ps.Table.Width}×{ps.Table.Height} @{ps.Fps} fps {ps.Kbps} kbps " +
                            "(the camera restarts the stream; video resumes shortly)");
            }

            if (applied.Count > 0)
                _status = "Applied: " + string.Join(", ", applied) + ".";

            // Refresh what the camera now reports (best-effort).
            if (_caps?.Features?.Led == true) _led = await GetAsync<JsonElement?>("led");
            if (_caps?.Features?.Pir == true) _pir = await GetAsync<JsonElement?>("pir");
            if (_caps?.Features?.Floodlight == true) _floodlight = await GetAsync<ApiFloodlight?>("floodlight");
            if (_caps?.Features?.StreamSettings == true) _encCurrent = await GetAsync<List<ApiStreamEnc>?>("settings/stream");
        }
        finally
        {
            _applying = false;
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (_loadedFor == CameraName) return;
        _loadedFor = CameraName;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error = _status = null;
        _caps = null;
        _recording = null;
        _profiles = null;
        _battery = _led = _pir = null;
        _zoomFocus = null;
        _floodlight = null;
        _encCurrent = null;
        _zoomShown = _focusShown = null;
        _sirenOn = _privacyOn = null;
        _confirmReboot = _confirmSiren = _confirmPrivacy = _privacyBusy = false;
        DiscardPending(); // switching cameras must not carry staged edits across
        StateHasChanged();

        // Capability discovery drives everything else; the camera answers control
        // commands one at a time, so the remaining queries run sequentially.
        _caps = await GetAsync<ApiCapabilities>("capabilities");
        if (_caps is { Online: true })
        {
            _recording = await GetAsync<ApiRecordingSettings>("recording"); // null when the server records nothing
            _profiles = (await GetAsync<ApiStreamProfiles>("streaminfo"))?.Profiles;
            if (_caps.Features?.Battery == true) _battery = await GetAsync<JsonElement?>("battery");
            if (_caps.Features?.Led == true) _led = await GetAsync<JsonElement?>("led");
            if (_caps.Features?.Pir == true) _pir = await GetAsync<JsonElement?>("pir");
            if (_caps.Features?.Zoom == true) _zoomFocus = await GetAsync<ApiZoomFocus?>("zoomfocus");
            if (_caps.Features?.Floodlight == true) _floodlight = await GetAsync<ApiFloodlight?>("floodlight");
            if (_caps.Features?.StreamSettings == true) _encCurrent = await GetAsync<List<ApiStreamEnc>?>("settings/stream");
            if (_caps.Features?.Siren == true) _sirenOn = (await GetAsync<JsonElement?>("siren"))?.TryGetProperty("on", out var so) == true && so.ValueKind != JsonValueKind.Null ? so.GetBoolean() : null;
            if (_caps.Features?.Privacy == true) _privacyOn = (await GetAsync<JsonElement?>("privacy"))?.TryGetProperty("on", out var po) == true && po.ValueKind != JsonValueKind.Null ? po.GetBoolean() : null;
        }
        _loading = false;
    }

    private Task CloseAsync() => OnClose.InvokeAsync();

    // ------------------------------------------------------------ actions

    private Task PtzAsync(string command) => PostAsync("ptz", new { command, speed = (float)_ptzSpeed });
    private Task PtzStopAsync() => PtzAsync("stop");

    /// <summary>Live lens control: write the absolute position, then re-read where
    /// the lens actually landed (zooming usually moves the focus too).</summary>
    private async Task SetZoomFocusAsync(long? zoom = null, long? focus = null)
    {
        if (_zfBusy) return;
        _zfBusy = true;
        try
        {
            if (await PostAsync("zoomfocus", new { zoom, focus }))
            {
                _zoomFocus = await GetAsync<ApiZoomFocus?>("zoomfocus") ?? _zoomFocus;
                _zoomShown = _focusShown = null;
            }
        }
        finally
        {
            _zfBusy = false;
        }
    }

    private async Task SirenAsync(bool on)
    {
        _confirmSiren = false;
        if (await PostAsync("siren", new { on }))
        {
            _sirenOn = on;
            _status = on ? "Siren ON — it sounds until you stop it." : "Siren stopped.";
        }
    }

    private async Task SetPrivacyAsync(bool on)
    {
        if (_privacyBusy) return; // ignore repeat clicks while a switch is in flight
        _confirmPrivacy = false;
        _privacyBusy = true;
        _status = null;
        try
        {
            // The write blocks until the camera acknowledges (msg 575). Cap the
            // wait at 10s so a slow/offline camera can't hang the spinner forever.
            using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(10));
            if (await PostAsync("privacy", new { on }, cts.Token))
            {
                _privacyOn = on;
                _status = on
                    ? "Privacy mode ON — the camera goes dark until switched back."
                    : "Privacy mode off — the camera wakes and video resumes shortly.";
            }
        }
        finally
        {
            _privacyBusy = false;
        }
    }

    private bool IsActiveProfile(ApiEncodeProfile p) =>
        Camera?.Streams.Any(s => s.Kind == p.Type && s.Width == p.Width && s.Height == p.Height) == true;

    private static string TypeIcon(string label) => label switch
    {
        "person" => "🧍",
        "vehicle" => "🚗",
        "animal" => "🐾",
        "package" => "📦",
        "doorbell" => "🔔",
        "line-crossing" => "🚧",
        "intrusion" => "🚷",
        "loitering" => "🕒",
        "motion" => "👁",
        _ => "•",
    };

    private async Task SetRecordingAsync(bool? events = null, bool? continuous = null, List<string>? eventTypes = null,
        int? eventRetentionDays = null, int? continuousRetentionDays = null, string? recordStream = null,
        List<string>? scheduleDays = null, string? scheduleStart = null, string? scheduleEnd = null,
        bool? scheduleEnabled = null,
        bool? archiveEvents = null, bool? archiveContinuous = null, int? archiveRetentionDays = null)
    {
        object body = new
        {
            events, continuous, eventTypes, eventRetentionDays, continuousRetentionDays, recordStream,
            scheduleDays, scheduleStart, scheduleEnd, scheduleEnabled,
            archiveEvents, archiveContinuous, archiveRetentionDays,
        };
        if (await PostAsync("recording", body))
            _recording = await GetAsync<ApiRecordingSettings>("recording");
    }

    /// <summary>Blank/invalid input clears the override (the API takes negative = clear).</summary>
    private Task SetArchiveDaysAsync(string? raw)
    {
        int days = int.TryParse(raw?.Trim(), out var d) && d >= 0 ? d : -1;
        return SetRecordingAsync(archiveRetentionDays: days);
    }

    private static string StreamLabel(string? kind) => kind switch
    {
        "mainStream" => "Main",
        "subStream" => "Sub",
        "externStream" => "Ext",
        _ => kind ?? "Main",
    };

    private static string RetentionLabel(int days) =>
        days > 0 ? $"default ({days}d)" : "default (forever)";

    private static string DaysLabel(int days) => days == 1 ? "1 day" : $"{days} days";

    /// <summary>One lifecycle-strip line: live window → archive → deletion, from
    /// the settings as they stand right now (retention 0 = nothing ever expires).</summary>
    private RenderFragment LifecycleRow(string name, int days, bool archives) => __builder =>
    {
        <div class="lc-row">
            <span class="lc-name">@name</span>
            @if (days <= 0)
            {
                <span class="lc-pill lc-live">kept forever</span>
            }
            else
            {
                <span class="lc-pill lc-live">@DaysLabel(days) on this server</span>
                <span class="lc-arrow">→</span>
                @if (archives)
                {
                    var keep = _recording?.ArchiveRetentionDays ?? 0;
                    <span class="lc-pill lc-archive">archive@(keep > 0 ? $" · {DaysLabel(keep)}" : " · forever")</span>
                    @if (keep > 0)
                    {
                        <span class="lc-arrow">→</span>
                        <span class="lc-pill lc-del">deleted</span>
                    }
                }
                else
                {
                    <span class="lc-pill lc-del">deleted</span>
                }
            }
        </div>
    };

    /// <summary>Blank/invalid input resets to the server default (the API takes negative = clear).</summary>
    private Task SetRetentionAsync(bool forEvents, string? raw)
    {
        int days = int.TryParse(raw?.Trim(), out var d) && d >= 0 ? d : -1;
        return forEvents
            ? SetRecordingAsync(eventRetentionDays: days)
            : SetRecordingAsync(continuousRetentionDays: days);
    }

    private Task ToggleEventTypeAsync(string label)
    {
        if (_recording == null) return Task.CompletedTask;
        // null filter = all types; materialize it before toggling one off.
        var types = (_recording.EventTypes ?? _recording.KnownTypes ?? new List<string>()).ToList();
        if (!types.Remove(label)) types.Add(label);
        return SetRecordingAsync(eventTypes: types);
    }

    // ------------------------------------------------------------ capture schedule

    private static readonly string[] WeekDayTokens = { "mon", "tue", "wed", "thu", "fri", "sat", "sun" };

    private bool DayEnabled(string day) =>
        _recording?.ScheduleDays is not { Count: > 0 } days || days.Contains(day);

    private static string DayLabel(string day) => char.ToUpperInvariant(day[0]) + day[1..];
    private static string DayName(string day) => day switch
    {
        "mon" => "Mondays", "tue" => "Tuesdays", "wed" => "Wednesdays", "thu" => "Thursdays",
        "fri" => "Fridays", "sat" => "Saturdays", _ => "Sundays",
    };

    private static int MinutesOf(string? hhmm) =>
        hhmm is { Length: >= 5 }
        && int.TryParse(hhmm.AsSpan(0, 2), out var h) && int.TryParse(hhmm.AsSpan(3, 2), out var m)
            ? h * 60 + m
            : 0;

    private bool HasTimeWindow =>
        _recording != null && MinutesOf(_recording.ScheduleStart) != MinutesOf(_recording.ScheduleEnd);

    private async Task ToggleScheduleDayAsync(string day)
    {
        if (_recording == null) return;
        var days = _recording.ScheduleDays is { Count: > 0 } d ? d.ToList() : WeekDayTokens.ToList();
        if (!days.Remove(day)) days.Add(day);
        if (days.Count == 0)
        {
            // No days = capture nothing, which is what the events switch is for.
            _status = "At least one day stays selected — to stop capturing entirely, turn off detection events.";
            return;
        }
        await SetRecordingAsync(scheduleDays: days);
    }

    /// <summary>Time inputs post only the field that changed (null = leave alone).</summary>
    private Task SetScheduleTimeAsync(string? start = null, string? end = null) =>
        SetRecordingAsync(scheduleStart: Hhmm(start), scheduleEnd: Hhmm(end));

    /// <summary>Browsers may report "HH:mm:ss" — the API wants strict HH:mm ("" clears).</summary>
    private static string? Hhmm(string? raw) =>
        raw is { Length: > 5 } ? raw[..5] : raw;

    private string ScheduleSummary
    {
        get
        {
            if (_recording == null) return "";
            var days = _recording.ScheduleDays;
            string dayPart;
            if (days is not { Count: > 0 } || days.Count >= 7)
                dayPart = "every day";
            else
            {
                var ordered = WeekDayTokens.Where(days.Contains).ToList();
                dayPart = string.Join(", ", ordered) switch
                {
                    "mon, tue, wed, thu, fri" => "on weekdays",
                    "sat, sun" => "at weekends",
                    _ => "on " + string.Join(", ", ordered.Select(DayLabel)),
                };
            }
            if (!HasTimeWindow) return $"Capturing events all day, {dayPart}.";
            int s = MinutesOf(_recording.ScheduleStart), e = MinutesOf(_recording.ScheduleEnd);
            string from = s == 0 ? "midnight" : _recording.ScheduleStart!;
            string until = e == 0 ? "midnight" : _recording.ScheduleEnd!;
            string wrap = s > e && e != 0 ? " (overnight)" : "";
            return $"Capturing events {from}–{until}{wrap}, {dayPart}. Anything outside is discarded.";
        }
    }

    private async Task RebootAsync()
    {
        _confirmReboot = false;
        if (await PostAsync("reboot", new { }))
            _status = "Reboot accepted — the camera will drop offline for a minute.";
    }

    // ------------------------------------------------------------ HTTP helpers

    private string BaseUrl => $"{Server.TrimEnd('/')}/api/cameras/{Uri.EscapeDataString(CameraName)}";

    private HttpRequestMessage NewRequest(HttpMethod method, string path)
    {
        var req = new HttpRequestMessage(method, $"{BaseUrl}/{path}");
        if (!string.IsNullOrEmpty(Token))
        {
            req.Headers.Authorization = new AuthenticationHeaderValue("Bearer", Token);
        }
        else if (!string.IsNullOrEmpty(User))
        {
            var token = Convert.ToBase64String(System.Text.Encoding.UTF8.GetBytes($"{User}:{Pass}"));
            req.Headers.Authorization = new AuthenticationHeaderValue("Basic", token);
        }
        return req;
    }

    private async Task<T?> GetAsync<T>(string path)
    {
        try
        {
            using var res = await Http.SendAsync(NewRequest(HttpMethod.Get, path));
            if (!res.IsSuccessStatusCode) return default;
            return await res.Content.ReadFromJsonAsync<T>();
        }
        catch (Exception ex)
        {
            _error = $"Cannot reach {Server}: {ex.Message}";
            return default;
        }
    }

    private async Task<bool> PostAsync(string path, object body, CancellationToken ct = default)
    {
        _status = null;
        try
        {
            var req = NewRequest(HttpMethod.Post, path);
            req.Content = JsonContent.Create(body);
            using var res = await Http.SendAsync(req, ct);
            if (res.IsSuccessStatusCode)
            {
                _error = null;
                return true;
            }
            _error = res.StatusCode == System.Net.HttpStatusCode.Unauthorized
                ? "Not authorized — set your credentials under server settings (⚙)."
                : await ReadErrorAsync(res) ?? $"Request failed ({(int)res.StatusCode})";
            return false;
        }
        catch (OperationCanceledException) when (ct.IsCancellationRequested)
        {
            _error = "Timed out waiting for the camera to confirm — it may be slow or offline. Check its state and try again.";
            return false;
        }
        catch (Exception ex)
        {
            _error = $"Cannot reach {Server}: {ex.Message}";
            return false;
        }
    }

    private static async Task<string?> ReadErrorAsync(HttpResponseMessage res)
    {
        try
        {
            var el = await res.Content.ReadFromJsonAsync<JsonElement>();
            return el.TryGetProperty("error", out var err) ? err.GetString() : null;
        }
        catch
        {
            return null;
        }
    }

    // ------------------------------------------------------------ JSON helpers

    private static string? Str(JsonElement? el, string name) =>
        el is { ValueKind: JsonValueKind.Object } obj && obj.TryGetProperty(name, out var v)
            ? v.ValueKind switch
            {
                JsonValueKind.String => v.GetString(),
                JsonValueKind.Number => v.GetRawText(),
                _ => null,
            }
            : null;

    private static long? Num(JsonElement? el, string name) =>
        el is { ValueKind: JsonValueKind.Object } obj
        && obj.TryGetProperty(name, out var v)
        && v.ValueKind == JsonValueKind.Number
            ? v.GetInt64()
            : null;
}
