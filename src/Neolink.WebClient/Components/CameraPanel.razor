    private static string WifiLabel(int signal) =>
        signal < 0 ? $"{signal} dBm" : signal <= 4 ? $"{signal} / 4 bars" : signal.ToString();

    private static string SdLabel(ApiSdCard card) =>
        !card.Mounted ? "not mounted"
        : !card.Formatted ? "not formatted"
        : $"{card.FreeMb / 1024.0:0.#} GB free of {card.TotalMb / 1024.0:0.#} GB";

    private void DiscardPending()
    {
        _pendingStreams.Clear();
        _pendingIr = _pendingStatusLed = null;
        _pendingPir = null;
        _pendingFlBrightness = null;
        _pendingFlAuto = null;
        _pendingWlBright = null;
        _pendingWlAuto = null;
        _pendingBright = _pendingContrast = _pendingSaturation = _pendingHue = _pendingSharpen = null;
        _pendingDayNight = _pendingAntiFlicker = null;
        _pendingFlip = _pendingMirror = null;
        _pendingVolume = null;
        _pendingAutoTrack = null;
        _pendingIrBright = null;
        _pendingDoorbellLed = null;
        _pendingHdr = null;
        _pendingMdSens = null;
        _pendingAiSens.Clear();
        _pendingOsdName = _pendingOsdTime = _pendingOsdWatermark = null;
        _pendingOsdNamePos = _pendingOsdTimePos = null;
    }

    /// <summary>Sends the staged changes one at a time (the camera answers control
    /// commands serially). Whatever fails stays staged, so Apply can be retried.</summary>
    private async Task ApplyPendingAsync()
    {
        if (_applying) return;
        _applying = true;
        var applied = new List<string>();
        bool? appliedFlip = null, appliedMirror = null;
        try
        {
            if (_pendingIr is { } ir && await PostAsync("led", new { state = ir }))
            {
                _pendingIr = null;
                applied.Add("night vision");
            }
            if (_pendingStatusLed is { } led && await PostAsync("led", new { lightState = led }))
            {
                _pendingStatusLed = null;
                applied.Add("status LED");
            }
            if (_pendingPir is { } pir && await PostAsync("pir", new { enabled = pir }))
            {
                _pendingPir = null;
                applied.Add("PIR");
            }
            if ((_pendingFlBrightness != null || _pendingFlAuto != null)
                && await PostAsync("floodlight", new { brightness = _pendingFlBrightness, auto = _pendingFlAuto }))
            {
                _pendingFlBrightness = null;
                _pendingFlAuto = null;
                applied.Add("floodlight behavior");
            }
            if ((_pendingWlBright != null || _pendingWlAuto != null)
                && await PostAsync("whiteled", new
                {
                    brightness = _pendingWlBright,
                    mode = _pendingWlAuto is { } a ? (a ? 1 : 0) : (int?)null,
                }))
            {
                _pendingWlBright = null;
                _pendingWlAuto = null;
                applied.Add("spotlight");
            }
            if (_pendingDoorbellLed is { } dbl && await PostAsync("led", new { doorbellLightState = dbl }))
            {
                _pendingDoorbellLed = null;
                applied.Add("doorbell light");
            }
            if (_pendingIrBright is { } irb && await PostAsync("led", new { irBrightness = irb }))
            {
                _pendingIrBright = null;
                applied.Add("IR brightness");
            }
            if ((_pendingBright != null || _pendingContrast != null || _pendingSaturation != null
                 || _pendingHue != null || _pendingSharpen != null || _pendingDayNight != null
                 || _pendingAntiFlicker != null || _pendingFlip != null || _pendingMirror != null)
                && await PostAsync("image", new
                {
                    bright = _pendingBright,
                    contrast = _pendingContrast,
                    saturation = _pendingSaturation,
                    hue = _pendingHue,
                    sharpen = _pendingSharpen,
                    dayNight = _pendingDayNight,
                    antiFlicker = _pendingAntiFlicker,
                    flip = _pendingFlip,
                    mirror = _pendingMirror,
                }))
            {
                _pendingBright = _pendingContrast = _pendingSaturation = _pendingHue = _pendingSharpen = null;
                _pendingDayNight = _pendingAntiFlicker = null;
                (appliedFlip, appliedMirror) = (_pendingFlip, _pendingMirror);
                _pendingFlip = _pendingMirror = null;
                applied.Add("picture");
            }
            if (_pendingHdr is { } hdr && await PostAsync("hdr", new { value = hdr }))
            {
                _pendingHdr = null;
                applied.Add("HDR");
            }
            if (_pendingMdSens is { } mds && await PostAsync("mdsensitivity", new { sensitivity = mds }))
            {
                _pendingMdSens = null;
                applied.Add("motion sensitivity");
            }
            foreach (var (aiType, aiVal) in _pendingAiSens.ToList())
            {
                if (!await PostAsync("aisensitivity", new { type = aiType, sensitivity = aiVal }))
                    break; // whatever failed stays staged for retry
                _pendingAiSens.Remove(aiType);
                applied.Add($"{aiType} sensitivity");
            }
            if ((_pendingOsdName != null || _pendingOsdTime != null || _pendingOsdWatermark != null
                 || _pendingOsdNamePos != null || _pendingOsdTimePos != null)
                && await PostAsync("osd", new
                {
                    showName = _pendingOsdName,
                    namePos = _pendingOsdNamePos,
                    showTime = _pendingOsdTime,
                    timePos = _pendingOsdTimePos,
                    watermark = _pendingOsdWatermark,
                }))
            {
                _pendingOsdName = _pendingOsdTime = _pendingOsdWatermark = null;
                _pendingOsdNamePos = _pendingOsdTimePos = null;
                applied.Add("on-screen display");
            }
            if (_pendingVolume is { } pv && await PostAsync("volume", new { volume = pv }))
            {
                _pendingVolume = null;
                applied.Add("speaker volume");
            }
            if (_pendingAutoTrack is { } pat && await PostAsync("autotrack", new { on = pat }))
            {
                _pendingAutoTrack = null;
                applied.Add("auto-tracking");
            }
            // The disruptive ones go LAST: the quick settings land before the
            // stream restarts make the camera briefly deaf to commands.
            foreach (var (kind, ps) in _pendingStreams.ToList())
            {
                if (!await PostAsync("settings/stream", new
                    {
                        stream = kind,
                        width = ps.Table.Width,
                        height = ps.Table.Height,
                        framerate = ps.Fps,
                        bitrate = ps.Kbps,
                    }))
                    break; // whatever failed stays staged for retry
                _pendingStreams.Remove(kind);
                applied.Add($"{ps.Table.Label} stream → {ps.Table.Width}×{ps.Table.Height} @{ps.Fps} fps {ps.Kbps} kbps " +
                            "(the camera restarts the stream; video resumes shortly)");
            }

            if (applied.Count > 0 && PendingCount == 0)
                ShowToast("Applied: " + string.Join(", ", applied) + ".");
            else if (applied.Count > 0)
                // Something in the batch failed (its own red toast already showed);
                // say what DID land so the retry scope is clear.
                ShowToast("Applied: " + string.Join(", ", applied) +
                          " — the rest failed and stays staged for retry.", error: true);

            // Refresh what the camera now reports (best-effort).
            if (_caps?.Features?.Led == true) _led = await GetAsync<JsonElement?>("led");
            if (_caps?.Features?.Pir == true) _pir = await GetAsync<JsonElement?>("pir");
            if (_caps?.Features?.Floodlight == true) _floodlight = await GetAsync<ApiFloodlight?>("floodlight");
            if (_caps?.Features?.WhiteLed == true) _whiteLed = await GetAsync<ApiWhiteLed?>("whiteled");
            if (_caps?.Features?.StreamSettings == true) _encCurrent = await GetAsync<List<ApiStreamEnc>?>("settings/stream");
            if (_http != null && await GetAsync<ApiHttpFeatures?>("httpfeatures") is { } freshHttp)
                _http = MergeHttp(freshHttp, _http);
            // A CONFIRMED flip/mirror write outranks the camera's echo for this
            // refresh: the camera applies these by restarting its video pipeline
            // and can still report the pre-write value while it does — the panel
            // then looked like the toggle didn't take.
            if ((appliedFlip != null || appliedMirror != null) && _http?.Image is { } img)
                _http = _http with
                {
                    Image = img with { Flip = appliedFlip ?? img.Flip, Mirror = appliedMirror ?? img.Mirror },
                };
        }
        finally
        {
            _applying = false;
        }
    }

    /// <summary>Post-apply refresh guard: a camera busy applying a write (an OSD
    /// change re-renders the burned-in overlays; flip/mirror restarts the video
    /// pipeline) can time out parts of the combined httpfeatures re-read, which
    /// then reports those features as ABSENT — and their panel sections vanish
    /// right after a successful apply, looking like the feature broke. Any member
    /// the fresh read couldn't get keeps its previous reading instead.</summary>
    private static ApiHttpFeatures MergeHttp(ApiHttpFeatures fresh, ApiHttpFeatures old) => new(
        fresh.Image ?? old.Image,
        fresh.Volume ?? old.Volume,
        fresh.WifiSignal ?? old.WifiSignal,
        fresh.PtzPresets ?? old.PtzPresets,
        fresh.QuickReplies ?? old.QuickReplies,
        fresh.AutoTrack ?? old.AutoTrack,
        fresh.SdCards ?? old.SdCards,
        fresh.MdSensitivity ?? old.MdSensitivity,
        fresh.AiSensitivities ?? old.AiSensitivities,
        fresh.Osd ?? old.Osd);

    protected override async Task OnParametersSetAsync()
    {
        if (_loadedFor == CameraName) return;
        _loadedFor = CameraName;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _probing = false;
        _error = _toast = null;
        _caps = null;
        _recording = null;
        _profiles = null;
        _battery = _led = _pir = null;
        _zoomFocus = null;
        _floodlight = null;
        _whiteLed = null;
        _http = null;
        _firmware = null;
        _encCurrent = null;
        _zoomShown = _focusShown = null;
        _sirenOn = _privacyOn = null;
        _newPresetName = "";
        _presetBusy = _quickReplyBusy = false;
        _quickReplyId = 0;
        _camTab = "controls";
        _confirmReboot = _confirmSiren = _confirmPrivacy = _privacyBusy = false;
        _confirmSuspend = _suspendBusy = false;
        // Suspend state: seeded from the camera list (reachable even while the
        // camera is offline), then confirmed against the server — the list entry
        // the parent passed in can be stale, e.g. right after resuming from this
        // very panel, and it must not flip the panel back to "suspended".
        _suspended = Camera?.CanSuspend == true ? Camera.Suspended : null;
        DiscardPending(); // switching cameras must not carry staged edits across
        StateHasChanged();

        if (Camera?.CanSuspend == true &&
            (await GetAsync<JsonElement?>("suspend"))?.TryGetProperty("suspended", out var su) == true
            && su.ValueKind is JsonValueKind.True or JsonValueKind.False)
        {
            _suspended = su.GetBoolean();
        }

        // Phase 1 — known upfront, no camera round-trip: the recording settings are
        // pure server state (retention, event-type filter), readable even while the
        // camera is offline. Fetch and render them FIRST so the panel is useful in a
        // few milliseconds instead of waiting on the camera's capability probe.
        _recording = await GetAsync<ApiRecordingSettings>("recording"); // null when the server records nothing
        if (_recording != null) _camTab = "recording";
        _loading = false;
        _probing = true;
        StateHasChanged();

        // Phase 2 — the slow part: capability discovery probes the camera with a
        // handful of commands, and each control read is another round-trip. Runs in
        // the background behind the "querying the camera" hint; the device-controls
        // tab appears once this lands.
        _caps = await GetAsync<ApiCapabilities>("capabilities");
        if (_caps is { Online: true })
        {
            // A camera that came online since phase 1 (or records nothing) still
            // wants the controls tab as its default.
            if (_recording == null) _camTab = "controls";
            _profiles = (await GetAsync<ApiStreamProfiles>("streaminfo"))?.Profiles;
            if (_caps.Features?.Battery == true) _battery = await GetAsync<JsonElement?>("battery");
            if (_caps.Features?.Led == true) _led = await GetAsync<JsonElement?>("led");
            if (_caps.Features?.Pir == true) _pir = await GetAsync<JsonElement?>("pir");
            if (_caps.Features?.Zoom == true) _zoomFocus = await GetAsync<ApiZoomFocus?>("zoomfocus");
            if (_caps.Features?.Floodlight == true) _floodlight = await GetAsync<ApiFloodlight?>("floodlight");
            if (_caps.Features?.WhiteLed == true) _whiteLed = await GetAsync<ApiWhiteLed?>("whiteled");
            if (_caps.Features?.StreamSettings == true) _encCurrent = await GetAsync<List<ApiStreamEnc>?>("settings/stream");
            if (_caps.Features?.Siren == true) _sirenOn = (await GetAsync<JsonElement?>("siren"))?.TryGetProperty("on", out var so) == true && so.ValueKind != JsonValueKind.Null ? so.GetBoolean() : null;
            if (_caps.Features?.Privacy == true) _privacyOn = (await GetAsync<JsonElement?>("privacy"))?.TryGetProperty("on", out var po) == true && po.ValueKind != JsonValueKind.Null ? po.GetBoolean() : null;
            // The HTTP-API extras (beta): one combined read; 404/null just hides them.
            // Also fetched for ONVIF-only cameras (no http_address) — the sweep then
            // returns just the picture settings ONVIF can provide.
            if (_caps.Features?.StreamSettings == true || _caps.Features?.Imaging == true)
            {
                _http = await GetAsync<ApiHttpFeatures?>("httpfeatures");
                _quickReplyId = _http?.QuickReplies?.FirstOrDefault()?.Id ?? 0;
                // The (server-cached) firmware-update check — display-only.
                _firmware = await GetAsync<ApiFirmware?>("firmware");
            }
        }
        _loading = false;
        _probing = false;
    }

    private Task CloseAsync() => OnClose.InvokeAsync();

    public void Dispose() => _disposed = true;

    /// <summary>Shows the bottom-of-panel feedback toast; it replaces any current
    /// one and dismisses itself after 5 seconds.</summary>
    private void ShowToast(string message, bool error = false)
    {
        _toast = message;
        _toastError = error;
        _ = DismissToastLaterAsync(++_toastSeq);
    }

    private async Task DismissToastLaterAsync(int seq)
    {
        await Task.Delay(TimeSpan.FromSeconds(5));
        if (_disposed || seq != _toastSeq) return;
        _toast = null;
        await InvokeAsync(StateHasChanged);
    }

    // ------------------------------------------------------------ actions

    private Task PtzAsync(string command) => PostAsync("ptz", new { command, speed = (float)_ptzSpeed });
    private Task PtzStopAsync() => PtzAsync("stop");

    /// <summary>Live lens control: write the absolute position, then re-read where
    /// the lens actually landed (zooming usually moves the focus too).</summary>
    private async Task SetZoomFocusAsync(long? zoom = null, long? focus = null)
    {
        if (_zfBusy) return;
        _zfBusy = true;
        try
        {
            if (await PostAsync("zoomfocus", new { zoom, focus }))
            {
                _zoomFocus = await GetAsync<ApiZoomFocus?>("zoomfocus") ?? _zoomFocus;
                _zoomShown = _focusShown = null;
            }
        }
        finally
        {
            _zfBusy = false;
        }
    }

    private async Task SirenAsync(bool on)
    {
        _confirmSiren = false;
        if (await PostAsync("siren", new { on }))
        {
            _sirenOn = on;
            ShowToast(on ? "Siren ON — it sounds until you stop it." : "Siren stopped.");
        }
    }

    private async Task SetPrivacyAsync(bool on)
    {
        if (_privacyBusy) return; // ignore repeat clicks while a switch is in flight
        _confirmPrivacy = false;
        _privacyBusy = true;
        _toast = null;
        try
        {
            // The write blocks until the camera acknowledges (msg 575). Cap the
            // wait at 10s so a slow/offline camera can't hang the spinner forever.
            using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(10));
            if (await PostAsync("privacy", new { on }, cts.Token))
            {
                _privacyOn = on;
                ShowToast(on
                    ? "Privacy mode ON — the camera goes dark until switched back."
                    : "Privacy mode off — the camera wakes and video resumes shortly.");
            }
        }
        finally
        {
            _privacyBusy = false;
        }
    }

    /// <summary>Suspends/resumes the camera in Neolink (server-side; persisted). No
    /// camera write — this only drops/keeps Neolink's own connection.</summary>
    private async Task SetSuspendAsync(bool suspend)
    {
        if (_suspendBusy) return;
        _confirmSuspend = false;
        _suspendBusy = true;
        try
        {
            if (await PostAsync("suspend", new { suspended = suspend }))
            {
                _suspended = suspend;
                _requerySeq++; // a new toggle supersedes any resume poll in flight
                ShowToast(suspend
                    ? "Suspended — Neolink.NET won't view or record this camera until resumed. The camera itself keeps running."
                    : "Resumed — Neolink.NET is reconnecting to this camera.");
                if (!suspend)
                {
                    // Repopulate now (honest offline notice while it reconnects),
                    // then keep re-querying until the camera answers so the panel
                    // fills in by itself — no close/reopen needed.
                    await LoadAsync();
                    _ = RequeryUntilOnlineAsync(_requerySeq, CameraName);
                }
            }
        }
        finally
        {
            _suspendBusy = false;
        }
    }

    /// <summary>After a resume the camera needs a few seconds to reconnect: probe
    /// it every 2 s (up to a minute) and reload the panel once it reports online.
    /// Stops quietly when the panel closes, switches camera, or is re-suspended.</summary>
    private async Task RequeryUntilOnlineAsync(int seq, string camera)
    {
        for (int i = 0; i < 30; i++)
        {
            await Task.Delay(TimeSpan.FromSeconds(2));
            if (_disposed || seq != _requerySeq || _loadedFor != camera || _suspended != false)
                return;
            if (_caps is { Online: true }) return; // already populated — done
            await InvokeAsync(async () =>
            {
                // Light probe first; the full (multi-query) reload only runs once
                // the camera actually answers, so the panel doesn't churn.
                var caps = await GetAsync<ApiCapabilities>("capabilities");
                if (caps is { Online: true }) await LoadAsync();
                else if (caps != null) _caps = caps;
                StateHasChanged();
            });
            if (_caps is { Online: true }) return;
        }
    }

    private bool IsActiveProfile(ApiEncodeProfile p) =>
        Camera?.Streams.Any(s => s.Kind == p.Type && s.Width == p.Width && s.Height == p.Height) == true;

    private static string TypeIcon(string label) => label switch
    {
        "person" => "🧍",
        "vehicle" => "🚗",
        "animal" => "🐾",
        "package" => "📦",
        "doorbell" => "🔔",
        "crying" => "😢",
        "line-crossing" => "🚧",
        "intrusion" => "🚷",
        "loitering" => "🕒",
        "motion" => "👁",
        _ => "•",
    };

    // Live probe results win; the server's cached signals (in the phase-1
    // /recording payload) fill in until then — so the chip list renders already
    // filtered instead of showing everything and pruning when the probe lands.
    // It only visibly shifts when the camera's answers changed (firmware update,
    // camera swapped) — rare by design.
    private bool TypeChipVisible(string t) =>
        EventTypeSupported(t,
            _http?.AiSensitivities is { Count: > 0 } live
                ? live.Select(a => a.Type).ToList()
                : _recording?.SupportedAiTypes,
            _caps?.Features?.Doorbell ?? _recording?.SupportedDoorbell);

    /// <summary>
    /// Whether an event-type chip should be offered for this camera. Hide only
    /// what is DISPROVEN: the AI-alarm sweep answers per type (a camera without
    /// e.g. package detection rejects that query), and the doorbell type needs a
    /// doorbell. Types with no reliable capability signal (crying, the perimeter
    /// trio, motion) always show — hiding on a guess would strand a camera that
    /// genuinely emits them. Null inputs mean "not probed yet": show everything.
    /// </summary>
    public static bool EventTypeSupported(string type, IReadOnlyList<string>? aiTypes, bool? doorbell) => type switch
    {
        "person" => AiAnswered(aiTypes, "people"),
        "vehicle" => AiAnswered(aiTypes, "vehicle"),
        "animal" => AiAnswered(aiTypes, "dog_cat"),
        "package" => AiAnswered(aiTypes, "package"),
        "doorbell" => doorbell ?? true,
        _ => true,
    };

    private static bool AiAnswered(IReadOnlyList<string>? ai, string type) =>
        ai is not { Count: > 0 } || ai.Contains(type);

    private async Task SetRecordingAsync(bool? events = null, bool? continuous = null, List<string>? eventTypes = null,
        int? eventRetentionDays = null, int? continuousRetentionDays = null, string? recordStream = null,
        List<string>? scheduleDays = null, string? scheduleStart = null, string? scheduleEnd = null,
        bool? scheduleEnabled = null,
        bool? archiveEvents = null, bool? archiveContinuous = null, int? archiveRetentionDays = null)
    {
        object body = new
        {
            events, continuous, eventTypes, eventRetentionDays, continuousRetentionDays, recordStream,
            scheduleDays, scheduleStart, scheduleEnd, scheduleEnabled,
            archiveEvents, archiveContinuous, archiveRetentionDays,
        };
        if (await PostAsync("recording", body))
            _recording = await GetAsync<ApiRecordingSettings>("recording");
    }

    /// <summary>Blank/invalid input clears the override (the API takes negative = clear).</summary>
    private Task SetArchiveDaysAsync(string? raw)
    {
        int days = int.TryParse(raw?.Trim(), out var d) && d >= 0 ? d : -1;
        return SetRecordingAsync(archiveRetentionDays: days);
    }

    private static string StreamLabel(string? kind) => kind switch
    {
        "mainStream" => "Main",
        "subStream" => "Sub",
        "externStream" => "Ext",
        _ => kind ?? "Main",
    };

    private static string RetentionLabel(int days) =>
        days > 0 ? $"default ({days}d)" : "default (forever)";

    private static string DaysLabel(int days) => days == 1 ? "1 day" : $"{days} days";

    /// <summary>One lifecycle-strip line: live window → archive → deletion, from
    /// the settings as they stand right now (retention 0 = nothing ever expires).</summary>
    private RenderFragment LifecycleRow(string name, int days, bool archives) => __builder =>
    {
        <div class="lc-row">
            <span class="lc-name">@name</span>
            @if (days <= 0)
            {
                <span class="lc-pill lc-live">kept forever</span>
            }
            else
            {
                <span class="lc-pill lc-live">@DaysLabel(days) on this server</span>
                <span class="lc-arrow">→</span>
                @if (archives)
                {
                    var keep = _recording?.ArchiveRetentionDays ?? 0;
                    <span class="lc-pill lc-archive">archive@(keep > 0 ? $" · {DaysLabel(keep)}" : " · forever")</span>
                    @if (keep > 0)
                    {
                        <span class="lc-arrow">→</span>
                        <span class="lc-pill lc-del">deleted</span>
                    }
                }
                else
                {
                    <span class="lc-pill lc-del">deleted</span>
                }
            }
        </div>
    };

    /// <summary>Blank/invalid input resets to the server default (the API takes negative = clear).</summary>
    private Task SetRetentionAsync(bool forEvents, string? raw)
    {
        int days = int.TryParse(raw?.Trim(), out var d) && d >= 0 ? d : -1;
        return forEvents
            ? SetRecordingAsync(eventRetentionDays: days)
            : SetRecordingAsync(continuousRetentionDays: days);
    }

    private Task ToggleEventTypeAsync(string label)
    {
        if (_recording == null) return Task.CompletedTask;
        // null filter = all types; materialize it before toggling one off.
        var types = (_recording.EventTypes ?? _recording.KnownTypes ?? new List<string>()).ToList();
        if (!types.Remove(label)) types.Add(label);
        return SetRecordingAsync(eventTypes: types);
    }

    // ------------------------------------------------------------ capture schedule

    private static readonly string[] WeekDayTokens = { "mon", "tue", "wed", "thu", "fri", "sat", "sun" };

    private bool DayEnabled(string day) =>
        _recording?.ScheduleDays is not { Count: > 0 } days || days.Contains(day);

    private static string DayLabel(string day) => char.ToUpperInvariant(day[0]) + day[1..];
    private static string DayName(string day) => day switch
    {
        "mon" => "Mondays", "tue" => "Tuesdays", "wed" => "Wednesdays", "thu" => "Thursdays",
        "fri" => "Fridays", "sat" => "Saturdays", _ => "Sundays",
    };

    private static int MinutesOf(string? hhmm) =>
        hhmm is { Length: >= 5 }
        && int.TryParse(hhmm.AsSpan(0, 2), out var h) && int.TryParse(hhmm.AsSpan(3, 2), out var m)
            ? h * 60 + m
            : 0;

    private bool HasTimeWindow =>
        _recording != null && MinutesOf(_recording.ScheduleStart) != MinutesOf(_recording.ScheduleEnd);

    private async Task ToggleScheduleDayAsync(string day)
    {
        if (_recording == null) return;
        var days = _recording.ScheduleDays is { Count: > 0 } d ? d.ToList() : WeekDayTokens.ToList();
        if (!days.Remove(day)) days.Add(day);
        if (days.Count == 0)
        {
            // No days = capture nothing, which is what the events switch is for.
            ShowToast("At least one day stays selected — to stop capturing entirely, turn off detection events.", error: true);
            return;
        }
        await SetRecordingAsync(scheduleDays: days);
    }

    /// <summary>Time inputs post only the field that changed (null = leave alone).</summary>
    private Task SetScheduleTimeAsync(string? start = null, string? end = null) =>
        SetRecordingAsync(scheduleStart: Hhmm(start), scheduleEnd: Hhmm(end));

    /// <summary>Browsers may report "HH:mm:ss" — the API wants strict HH:mm ("" clears).</summary>
    private static string? Hhmm(string? raw) =>
        raw is { Length: > 5 } ? raw[..5] : raw;

    private string ScheduleSummary
    {
        get
        {
            if (_recording == null) return "";
            var days = _recording.ScheduleDays;
            string dayPart;
            if (days is not { Count: > 0 } || days.Count >= 7)
                dayPart = "every day";
            else
            {
                var ordered = WeekDayTokens.Where(days.Contains).ToList();
                dayPart = string.Join(", ", ordered) switch
                {
                    "mon, tue, wed, thu, fri" => "on weekdays",
                    "sat, sun" => "at weekends",
                    _ => "on " + string.Join(", ", ordered.Select(DayLabel)),
                };
            }
            if (!HasTimeWindow) return $"Capturing events all day, {dayPart}.";
            int s = MinutesOf(_recording.ScheduleStart), e = MinutesOf(_recording.ScheduleEnd);
            string from = s == 0 ? "midnight" : _recording.ScheduleStart!;
            string until = e == 0 ? "midnight" : _recording.ScheduleEnd!;
            string wrap = s > e && e != 0 ? " (overnight)" : "";
            return $"Capturing events {from}–{until}{wrap}, {dayPart}. Anything outside is discarded.";
        }
    }

    private async Task RebootAsync()
    {
        _confirmReboot = false;
        if (await PostAsync("reboot", new { }))
            ShowToast("Reboot accepted — the camera will drop offline for a minute.");
    }

    // ------------------------------------------------ HTTP-API extras (beta)

    private async Task GoToPresetAsync(int id)
    {
        if (_presetBusy) return;
        _presetBusy = true;
        try
        {
            if (await PostAsync("ptzpreset", new { id }))
                ShowToast("Moving to the preset position.");
        }
        finally
        {
            _presetBusy = false;
        }
    }

    /// <summary>Saves the current position: an existing preset with the same name is
    /// overwritten, otherwise the first free slot is used.</summary>
    private async Task SavePresetAsync()
    {
        var name = _newPresetName.Trim();
        if (name.Length == 0 || _presetBusy || _http?.PtzPresets is not { } presets) return;
        var slot = presets.FirstOrDefault(p => p.Enabled && string.Equals(p.Name, name, StringComparison.OrdinalIgnoreCase))
                   ?? presets.FirstOrDefault(p => !p.Enabled);
        if (slot == null)
        {
            ShowToast("All preset slots are taken — reuse an existing preset's name to overwrite it.", error: true);
            return;
        }
        _presetBusy = true;
        try
        {
            if (await PostAsync("ptzpreset", new { id = slot.Id, name, save = true }))
            {
                _newPresetName = "";
                ShowToast($"Saved this position as \"{name}\".");
                if (_http != null && await GetAsync<ApiHttpFeatures?>("httpfeatures") is { } freshHttp)
                    _http = MergeHttp(freshHttp, _http);
            }
        }
        finally
        {
            _presetBusy = false;
        }
    }

    private async Task PlayQuickReplyAsync()
    {
        if (_quickReplyBusy) return;
        _quickReplyBusy = true;
        try
        {
            if (await PostAsync("quickreply", new { id = _quickReplyId }))
                ShowToast("Playing the quick reply on the camera.");
        }
        finally
        {
            _quickReplyBusy = false;
        }
    }

    // ------------------------------------------------------------ HTTP helpers

    private string BaseUrl => $"{Server.TrimEnd('/')}/api/cameras/{Uri.EscapeDataString(CameraName)}";

    private HttpRequestMessage NewRequest(HttpMethod method, string path)
    {
        var req = new HttpRequestMessage(method, $"{BaseUrl}/{path}");
        if (!string.IsNullOrEmpty(Token))
        {
            req.Headers.Authorization = new AuthenticationHeaderValue("Bearer", Token);
        }
        else if (!string.IsNullOrEmpty(User))
        {
            var token = Convert.ToBase64String(System.Text.Encoding.UTF8.GetBytes($"{User}:{Pass}"));
            req.Headers.Authorization = new AuthenticationHeaderValue("Basic", token);
        }
        return req;
    }

    private async Task<T?> GetAsync<T>(string path)
    {
        try
        {
            // The shared client's timeout is only a cap; panel reads get 30s —
            // room for a slow camera sweep (the server bounds those tighter),
            // while a genuinely stuck server still fails within the panel's
            // attention span.
            using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(30));
            using var res = await Http.SendAsync(NewRequest(HttpMethod.Get, path), cts.Token);
            if (!res.IsSuccessStatusCode) return default;
            return await res.Content.ReadFromJsonAsync<T>(cancellationToken: cts.Token);
        }
        catch (OperationCanceledException)
        {
            _error = "The camera is taking too long to answer — it may be busy or slow to respond. " +
                     "Close and reopen this panel to retry.";
            return default;
        }
        catch (Exception ex)
        {
            _error = $"Cannot reach {Server}: {ex.Message}";
            return default;
        }
    }

    private async Task<bool> PostAsync(string path, object body, CancellationToken ct = default)
    {
        _toast = null;
        try
        {
            var req = NewRequest(HttpMethod.Post, path);
            req.Content = JsonContent.Create(body);
            using var cts = CancellationTokenSource.CreateLinkedTokenSource(ct);
            cts.CancelAfter(TimeSpan.FromSeconds(30));
            using var res = await Http.SendAsync(req, cts.Token);
            if (res.IsSuccessStatusCode)
            {
                _error = null;
                return true;
            }
            ShowToast(res.StatusCode == System.Net.HttpStatusCode.Unauthorized
                ? "Not authorized — set your credentials under server settings (⚙)."
                : await ReadErrorAsync(res) ?? $"Request failed ({(int)res.StatusCode})", error: true);
            return false;
        }
        catch (OperationCanceledException)
        {
            ShowToast("Timed out waiting for the camera to confirm — it may be slow or offline. Check its state and try again.", error: true);
            return false;
        }
        catch (Exception ex)
        {
            ShowToast($"Cannot reach {Server}: {ex.Message}", error: true);
            return false;
        }
    }

    private static async Task<string?> ReadErrorAsync(HttpResponseMessage res)
    {
        try
        {
            var el = await res.Content.ReadFromJsonAsync<JsonElement>();
            return el.TryGetProperty("error", out var err) ? err.GetString() : null;
        }
        catch
        {
            return null;
        }
    }

    // ------------------------------------------------------------ JSON helpers

    private static string? Str(JsonElement? el, string name) =>
        el is { ValueKind: JsonValueKind.Object } obj && obj.TryGetProperty(name, out var v)
            ? v.ValueKind switch
            {
                JsonValueKind.String => v.GetString(),
                JsonValueKind.Number => v.GetRawText(),
                _ => null,
            }
            : null;

    private static long? Num(JsonElement? el, string name) =>
        el is { ValueKind: JsonValueKind.Object } obj
        && obj.TryGetProperty(name, out var v)
        && v.ValueKind == JsonValueKind.Number
            ? v.GetInt64()
            : null;
}
