@page "/timeline"
@using System.Text.Json
@inject HttpClient Http
@inject IJSRuntime JS
@inject LocalApiInfo Local
@implements IAsyncDisposable

@* NVR-style timeline: pick a day, scrub the lanes, and every included camera
   shows its continuous footage at that instant. Coverage is drawn per camera;
   detection events overlay the lanes color-coded by type. *@

<PageTitle>Neolink.NET — Timeline</PageTitle>

<div class="tl-page @(_studio ? "studio" : "")">
    <div class="toolbar tl-toolbar">
        <a class="tool-btn" href="" title="Back to live view">@UiIcon.Render("chev-left", 16) <span class="tool-name">Live</span></a>
        <span class="tool-label">TIMELINE</span>

        @* --- Date group: prev/next day flanking a calendar-dropdown button. --- *@
        <div class="tl-group tl-date-group">
            <button class="tool-btn tl-daynav" title="Previous day" @onclick="() => ChangeDayAsync(-1)">@UiIcon.Render("chev-left", 16)</button>
            <button class="tool-btn tl-date-btn @(_showCalendar ? "active" : "")"
                    title="Pick a day — days with footage are highlighted"
                    @onclick="ToggleCalendarAsync">
                @UiIcon.Render("calendar", 13) <span class="tl-date-text">@_date.ToString("ddd, d MMM yyyy")</span> @UiIcon.Render("chev-down", 12)
            </button>
            <button class="tool-btn tl-daynav" title="Next day" disabled="@(_date >= DateTime.Today)"
                    @onclick="() => ChangeDayAsync(1)">@UiIcon.Render("chev-right", 16)</button>
        </div>

        @* --- Transport group: event hops + coarse/fine steps around play/pause.
           Every control names its keyboard twin — the fastest way to learn them. --- *@
        <div class="tl-group tl-transport">
            <button class="tool-btn tl-step" title="Previous event   —   [" @onclick="() => JumpEventAsync(-1)">@UiIcon.Render("skip-back", 13)</button>
            <button class="tool-btn tl-step" title="Back 10 seconds   —   J or Shift+←" @onclick="() => StepAsync(-10)">−10s</button>
            <button class="tool-btn tl-step" title="Back 1 second   —   ←   (Ctrl+← or , for 0.1 s)" @onclick="() => StepAsync(-1)">−1s</button>
            <button class="tl-play @(_playing ? "playing" : "")"
                    title="@(_playing ? "Pause — Space or K" : "Play — Space or K")" @onclick="TogglePlayAsync">
                @UiIcon.Render(_playing ? "pause" : "play", 14) <span class="tool-name">@(_playing ? "Pause" : "Play")</span>
            </button>
            <button class="tool-btn tl-step" title="Forward 1 second   —   →   (Ctrl+→ or . for 0.1 s)" @onclick="() => StepAsync(1)">+1s</button>
            <button class="tool-btn tl-step" title="Forward 10 seconds   —   L or Shift+→" @onclick="() => StepAsync(10)">+10s</button>
            <button class="tool-btn tl-step" title="Next event   —   ]" @onclick="() => JumpEventAsync(1)">@UiIcon.Render("skip-fwd", 13)</button>
        </div>

        @* --- Speed group: slow motion through fast skim; the choice sticks. --- *@
        <div class="tl-group tl-speed-group">
            @foreach (var s in SpeedOptions)
            {
                var sp = s;
                <button class="chip tl-speed @(_speed == sp ? "chip-active" : "")"
                        title="Play at @SpeedLabel(sp) speed" @onclick="() => SetSpeedAsync(sp)">@SpeedLabel(sp)</button>
            }
        </div>

        @* Always in the layout, only shown while lagging: appearing/disappearing
           used to reflow the toolbar and shove the clock/export controls onto
           another line at some widths. Reserved space cannot jump. *@
        <span class="tl-lag @(Lagging ? "" : "tl-lag-idle")"
              title="The streams can't sustain @SpeedLabel(_speed) right now (server delivery or browser decoding is the limit) — the timeline slows down until they catch up">
            ⏳ catching up…
        </span>

        <span class="tool-spacer"></span>

        @* --- View group: clock, zoom, keyboard help. --- *@
        <div class="tl-group tl-view-group">
            @if (_editClock)
            {
                <input id="tl-clock-edit" class="tl-clock-edit" value="@TimeText(_t)" spellcheck="false"
                       placeholder="HH:mm:ss" @onchange="ClockEditedAsync" @onblur="() => _editClock = false" />
            }
            else
            {
                <span class="tl-clock tl-clock-btn" role="button" title="Click (or press T) to type an exact time"
                      @onclick="OpenClockEdit">@TimeText(_t)</span>
            }
            <button class="chip tl-zoom-chip @(Zoomed ? "chip-active" : "chip-off")"
                    title="@(Zoomed ? "Zoomed in — click (or press 0) to see the whole day again" : "Scroll or pinch on the timeline to zoom in for fine seeking")"
                    @onclick="ResetZoomAsync">@UiIcon.Render("zoom", 12) @SpanLabel(_viewSpan)</button>
            @if (_continuous && Included.Any())
            {
                <button class="tool-btn tl-export-btn @(_showExport ? "active" : "")"
                        title="Export footage: download a period of this day (up to the whole day) as a zip of its recordings"
                        @onclick="OpenExportAsync">@UiIcon.Render("download", 13) <span class="tool-name">Export</span></button>
            }
            <button class="tool-btn tl-studio-btn @(_studio ? "active" : "")"
                    title="@(_studio
                        ? "Studio layout is on — click to switch back to the classic view (your choice is saved)"
                        : "Studio layout: monitors on top, the timeline docked at the bottom like a video editor — saved to your account")"
                    @onclick="ToggleStudioAsync">@UiIcon.Render("film", 13) <span class="tool-name">Studio</span></button>
            <button class="tool-btn tl-keys-btn @(_showKeys ? "active" : "")" title="Keyboard shortcuts"
                    @onclick="() => _showKeys = !_showKeys">?</button>
        </div>
    </div>

    @if (_showCalendar)
    {
        <div class="tl-cal-backdrop" @onclick="() => _showCalendar = false"></div>
        <div class="tl-cal" @onclick:stopPropagation="true">
            <div class="tl-cal-head">
                <button class="tool-btn tl-daynav" title="Previous month" @onclick="() => ShiftMonth(-1)">@UiIcon.Render("chev-left", 15)</button>
                <span class="tl-cal-month">@_calMonth.ToString("MMMM yyyy")</span>
                <button class="tool-btn tl-daynav" title="Next month"
                        disabled="@(_calMonth >= new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1))"
                        @onclick="() => ShiftMonth(1)">@UiIcon.Render("chev-right", 15)</button>
            </div>
            <div class="tl-cal-grid">
                @foreach (var d in new[] { "Mo", "Tu", "We", "Th", "Fr", "Sa", "Su" })
                {
                    <span class="tl-cal-dow">@d</span>
                }
                @foreach (var cell in CalendarCells())
                {
                    @if (cell is { } day)
                    {
                        bool hasFootage = _contentDays.Contains(day);
                        bool isFuture = day > DateTime.Today;
                        <button class="tl-cal-day @(day == _date ? "sel" : "") @(hasFootage ? "has" : "") @(day == DateTime.Today ? "today" : "")"
                                disabled="@isFuture"
                                title="@(hasFootage ? "Footage on this day" : isFuture ? "" : "No footage")"
                                @onclick="() => PickDayAsync(day)">@day.Day</button>
                    }
                    else
                    {
                        <span class="tl-cal-day empty"></span>
                    }
                }
            </div>
            <div class="tl-cal-foot">
                <span class="tl-cal-legend"><span class="tl-cal-dot"></span> has footage</span>
                <button class="chip" @onclick="() => PickDayAsync(DateTime.Today)">Today</button>
            </div>
        </div>
    }

    @if (_showKeys)
    {
        <div class="tl-keys-backdrop" @onclick="() => _showKeys = false">
            <div class="tl-keys-panel" @onclick:stopPropagation="true">
                <div class="tl-keys-title">
                    <span>KEYBOARD SHORTCUTS</span>
                    <button class="icon-btn" title="Close" @onclick="() => _showKeys = false">✕</button>
                </div>
                <div class="tl-keys-grid">
                    <span>Space · K</span><span>Play / pause</span>
                    <span>← →</span><span>Step 1 s &nbsp;(Shift: 10 s, Ctrl: 0.1 s)</span>
                    <span>J · L</span><span>Back / forward 10 s</span>
                    <span>, · .</span><span>Nudge 0.1 s — frame-level review</span>
                    <span>[ · ]</span><span>Previous / next event</span>
                    <span>scroll</span><span>Zoom in/out around the mouse (Shift: pan)</span>
                    <span>+ − 0</span><span>Zoom in / out / whole day</span>
                    <span>T</span><span>Jump to an exact time</span>
                    <span>S</span><span>Save a still (focused monitor, or a lone camera)</span>
                </div>
                <div class="event-sub tl-keys-hint">
                    Drag the thin day strip above the lanes to move the zoomed view. Double-click the lanes to zoom back out.
                    Drag the divider beside the tracks to make the timeline taller; with a focused monitor, the handle beside
                    the thumbnail rail resizes it the same way. Double-click a divider for its default.
                </div>
            </div>
        </div>
    }

    @if (_showExport)
    {
        <div class="tl-keys-backdrop" @onclick="() => _showExport = false">
            <div class="tl-keys-panel tl-export-panel" @onclick:stopPropagation="true">
                <div class="tl-keys-title">
                    <span>EXPORT FOOTAGE — @_date.ToString("ddd, d MMM yyyy")</span>
                    <button class="icon-btn" title="Close" @onclick="() => _showExport = false">✕</button>
                </div>
                <div class="tl-export-sec">Camera</div>
                <div class="tl-export-cams">
                    @foreach (var cam in Included)
                    {
                        var name = cam.Name;
                        <button class="chip @(string.Equals(_exCam, name, StringComparison.OrdinalIgnoreCase) ? "chip-active" : "")"
                                @onclick="() => PickExportCamAsync(name)">@name</button>
                    }
                </div>

                <div class="tl-export-sec">Time range</div>
                <div class="tl-export-range">
                    <label>From <input class="tl-clock-edit" value="@_exFrom" spellcheck="false" placeholder="HH:mm:ss"
                                       @onchange="e => ExportRangeEditedAsync(e, from: true)" /></label>
                    <span class="tl-export-arrow">→</span>
                    <label>To <input class="tl-clock-edit" value="@_exTo" spellcheck="false" placeholder="HH:mm:ss"
                                     @onchange="e => ExportRangeEditedAsync(e, from: false)" /></label>
                    @if (ExportRangeValid(out var exF, out var exT))
                    {
                        <span class="tl-export-window" title="Length of the chosen range">@SpanLabel((exT - exF).TotalSeconds)</span>
                    }
                </div>
                <div class="tl-export-presets">
                    @if (Zoomed)
                    {
                        <button class="chip" title="The stretch of the day you are zoomed into"
                                @onclick="@(() => ApplyExportPresetAsync("view"))">Zoomed view</button>
                    }
                    @if (_date == DateTime.Today)
                    {
                        <button class="chip" title="The 60 minutes up to now"
                                @onclick="@(() => ApplyExportPresetAsync("hour"))">Last hour</button>
                    }
                    <button class="chip" title="Midnight to midnight"
                            @onclick="@(() => ApplyExportPresetAsync("day"))">Whole day</button>
                </div>

                <div class="tl-export-sec">Format</div>
                <div class="tl-export-format">
                    <button class="tl-export-card @(EffectiveFormat == "mp4" ? "sel" : "")" disabled="@(_exMp4Bytes == null)"
                            @onclick="@(() => _exFormat = "mp4")">
                        <span class="tl-export-card-title">Single MP4</span>
                        <span class="tl-export-card-sub">
                            @(_exMp4Bytes == null && _exMp4Reason != null && _exFiles > 0
                                ? _exMp4Reason
                                : "one continuous video, trimmed to your range — starts on a keyframe, seconds early at most")
                        </span>
                    </button>
                    <button class="tl-export-card @(EffectiveFormat == "zip" ? "sel" : "")"
                            @onclick="@(() => _exFormat = "zip")">
                        <span class="tl-export-card-title">Zip of segments</span>
                        <span class="tl-export-card-sub">the untouched originals — whole segments, one file per roll, named by start time</span>
                    </button>
                </div>

                <div class="tl-export-est">
                    @if (_exError != null)
                    {
                        <span class="tl-export-err">@_exError</span>
                    }
                    else if (_exBusy)
                    {
                        <span>sizing up the range…</span>
                    }
                    else if (_exFiles == 0)
                    {
                        <span>no recorded footage in this range</span>
                    }
                    else
                    {
                        <span>
                            @(EffectiveFormat == "mp4"
                                ? $"one video · {DurText(_exMp4DurMs ?? 0)} of footage"
                                : $"{_exFiles} segment{(_exFiles == 1 ? "" : "s")} · whole originals")
                        </span>
                        @if (EffBytes > 2L * 1024 * 1024 * 1024)
                        {
                            <span class="tl-export-warn">large download — leave this tab open until it finishes</span>
                        }
                    }
                </div>
                <div class="event-sub tl-export-hint">
                    Footage still being recorded is left out until its segment closes.
                </div>
                <div class="tl-export-actions">
                    <button class="chip" @onclick="() => _showExport = false">Cancel</button>
                    <button class="tl-play tl-export-go" disabled="@(_exBusy || _exFiles == 0 || _exError != null)"
                            @onclick="StartExportAsync">
                        @UiIcon.Render("download", 14) Export@(!_exBusy && _exFiles > 0 && _exError == null ? $" ≈ {SizeText(EffBytes)}" : "")
                    </button>
                </div>
            </div>
        </div>
    }

    @if (_error != null)
    {
        <div class="notice error">@_error</div>
    }
    else if (!_supported)
    {
        <div class="notice">
            Recording is not enabled on this server — add a "recording" section to the config
            to use the timeline.
        </div>
    }
    else
    {
        <div class="tl-cams">
            <span class="tool-label">CAMERAS</span>
            @foreach (var cam in _cameras)
            {
                var name = cam.Name;
                <button class="chip @(_included.Contains(name) ? "" : "chip-off")"
                        title="@(_included.Contains(name) ? "Loaded — click to remove" : "Click to load this camera's footage")"
                        @onclick="() => ToggleCameraAsync(name)">@name</button>
            }
            <span class="event-sub">
                @(_continuous
                    ? "— pick the cameras to scrub; colored marks are events"
                    : "— continuous recording is off, so only detection events (colored marks) play here")
            </span>
        </div>

        @if (!Included.Any())
        {
            <div class="notice">Select cameras above to load their footage — colored marks on the lanes are events.</div>
        }
        else
        {
        @* The board's height is the user's: the divider under it (over it, in the
           studio layout) drags, and the tracks share out whatever it is given. *@
        <div class="tl-board" id="tl-board" style="@BoardStyle()">
            @* Names and lanes are one row so both columns get the same height —
               that is what keeps every label level with its track as they grow. *@
            <div class="tl-tracks">
                <div class="tl-names">
                    <div class="tl-name tl-name-head"></div>
                    @foreach (var cam in Included)
                    {
                        <div class="tl-name" title="@cam.Name">@cam.Name</div>
                    }
                </div>
                @* data-vs/data-vspan let the JS hover bubble map pixels → time locally,
                   with zero server round-trips while the mouse moves. *@
                <div class="tl-lanes" id="tl-scrub" data-vs="@_viewStart" data-vspan="@_viewSpan">
                    @* The whole day at a glance, always: footage blocks, the red cursor,
                       and — when zoomed — the draggable view-window rectangle. *@
                    <div class="tl-overview">
                        @foreach (var cam in Included)
                        {
                            @if (_cov.TryGetValue(cam.Name, out var ovSegs))
                            {
                                @foreach (var s in ovSegs)
                                {
                                    <div class="tl-ov-cov" style="left:@DayPct(s.Start); width:@DayPct(s.Span)"></div>
                                }
                            }
                        }
                        <div class="tl-ov-cursor" style="left:@DayPct(_t)"></div>
                        @if (Zoomed)
                        {
                            <div class="tl-ov-win" style="left:@DayPct(_viewStart); width:@DayPct(_viewSpan)"></div>
                        }
                    </div>
                    <div class="tl-ruler">
                        @foreach (var (t, label) in RulerTicks())
                        {
                            @if (label != null)
                            {
                                <span class="tl-tick" style="left:@Pct(t)">@label</span>
                            }
                            else
                            {
                                <span class="tl-tick-minor" style="left:@Pct(t)"></span>
                            }
                        }
                    </div>
                    @foreach (var cam in Included)
                    {
                        <div class="tl-lane">
                            @if (_cov.TryGetValue(cam.Name, out var segs))
                            {
                                @foreach (var s in segs)
                                {
                                    @if (InView(s.Start, s.Start + s.Span))
                                    {
                                        <div class="tl-cov" style="left:@Pct(s.Start); width:@W(s.Span)"></div>
                                    }
                                }
                            }
                            @if (_marks.TryGetValue(cam.Name, out var marks))
                            {
                                @foreach (var m in marks)
                                {
                                    @if (InView(m.Start, m.End))
                                    {
                                        <div class="tl-ev" title="@m.Title"
                                             style="left:@Pct(m.Start); width:@WMark(m.End - m.Start); background:@m.Color"></div>
                                    }
                                }
                            }
                        </div>
                    }
                    @if (InView(_t, _t))
                    {
                        <div class="tl-cursor" style="left:@Pct(_t)">
                            <span class="tl-cursor-time">@TimeText(_t)</span>
                        </div>
                    }
                </div>
            </div>
            @if (!Zoomed)
            {
                @* Discovery nudge for the timeline's best trick; it bows out
                   the moment the user zooms (and returns at the full-day view). *@
                <div class="tl-zoom-hint">@UiIcon.Render("zoom", 11) <span>Scroll or pinch here to zoom into the day</span></div>
            }
        </div>

        @* Drag to trade height between the monitors and the tracks. JS owns the
           drag (see tlResizeInit) and hands back the height it landed on. *@
        <div class="tl-resizer" id="tl-resizer" role="separator" aria-orientation="horizontal"
             title="Drag to make the timeline taller or shorter — double-click to reset"
             @ondblclick="ResetBoardHeightAsync">
            <span class="tl-resizer-grip"></span>
        </div>

        @* Tile size adapts to the selection: fewer cameras = bigger tiles. In the
           studio layout, clicking a tile promotes it to the program monitor (the
           rest become a thumbnail rail); clicking it again restores the grid. *@
        <div class="tl-grid @(FocusActive ? "tl-focused" : "")" style="@GridStyle()">
            @foreach (var cam in Included)
            {
                bool focused = FocusActive && IsFocus(cam.Name);
                <div class="tl-tile @(focused ? "tl-tile-focus" : "") @(FocusActive && !focused ? "tl-tile-rail" : "")"
                     style="@TileStyle(cam.Name)"
                     title="@(_studio ? (focused ? "Click to show all monitors again" : "Click to focus this monitor") : null)"
                     @onclick="() => ToggleFocus(cam.Name)" @key="cam.Name">
                    <video id="@VideoId(cam.Name)" muted playsinline preload="auto"></video>
                    @if (_noFootage.Contains(cam.Name))
                    {
                        <div class="tl-nofootage">no footage at @TimeText(_t)</div>
                    }
                    <div class="tl-tile-name">@cam.Name</div>
                    <button class="tl-snap" title="Save a still of this frame (PNG)"
                            @onclick="() => SnapshotAsync(cam.Name)" @onclick:stopPropagation="true">
                        @UiIcon.Render("camera", 14)
                    </button>
                </div>
            }
            @if (FocusActive && Included.Count() > 1)
            {
                @* Drag to trade width between the program monitor and the rail.
                   Lives in its own thin grid column between the two; the drag is
                   JS-owned like the board divider's (see tlColResizeInit). *@
                <div class="tl-vresizer" id="tl-vresizer" role="separator" aria-orientation="vertical"
                     style="grid-column: 2; grid-row: 1 / span @(Math.Max(1, Included.Count() - 1));"
                     title="Drag to make the thumbnail rail wider or narrower — double-click to reset"
                     @ondblclick="ResetRailWidthAsync">
                    <span class="tl-vresizer-grip"></span>
                </div>
            }
        </div>
        }
    }
</div>

@code {
    private const double DaySeconds = 24 * 3600;

    private string _server = "";
    private string? _token; // web-UI session (shared with the live view via localStorage)
    private DateTime _date = DateTime.Today;
    private double _t;
    private bool _playing;
    private bool _supported = true;
    private bool _continuous = true;
    private string? _error;

    private readonly List<ApiCamera> _cameras = new();
    private HashSet<string> _included = new(StringComparer.OrdinalIgnoreCase);
    private readonly Dictionary<string, List<Seg>> _cov = new(StringComparer.OrdinalIgnoreCase);
    // Event clips as playable segments — the fallback when there is no continuous
    // footage under the cursor (or when continuous recording is off entirely).
    private readonly Dictionary<string, List<Seg>> _eventSegs = new(StringComparer.OrdinalIgnoreCase);
    private readonly Dictionary<string, List<Mark>> _marks = new(StringComparer.OrdinalIgnoreCase);
    private readonly HashSet<string> _noFootage = new(StringComparer.OrdinalIgnoreCase);

    private DotNetObjectReference<Timeline>? _selfRef;
    private PeriodicTimer? _clock;
    private DateTime _covRefreshed = DateTime.UtcNow; // last periodic coverage reload (today only)
    private DateTime _lastTick;
    private bool _scrubInit;
    private bool _railInit; // rail-divider drag hooked (focused studio only)
    private bool _booted;

    // Calendar date-picker: days that hold footage are highlighted at a glance.
    private bool _showCalendar;
    private DateTime _calMonth = new(DateTime.Today.Year, DateTime.Today.Month, 1);
    private readonly HashSet<DateTime> _contentDays = new();

    /// <summary>One recording segment: seconds-of-day start, span and playback URL.</summary>
    private sealed record Seg(double Start, double Span, string Url);
    /// <summary>One event as a colored lane mark (seconds of day).</summary>
    private sealed record Mark(double Start, double End, string Color, string Title);

    private const string PrefsKey = "neolink.timeline";
    /// <summary>Timeline preferences. Fields are nullable so a partial blob (an
    /// older build's, or the server's empty "{}") only overrides what it holds.
    /// Saved to localStorage always, and per account via /api/me/settings/timeline
    /// when signed in — so choices like the studio layout follow the user across
    /// browsers and devices.</summary>
    private sealed class Prefs
    {
        public List<string>? Included { get; set; }
        public double? Speed { get; set; }
        public bool? Studio { get; set; }
        public double? BoardH { get; set; }
        public double? StudioBoardH { get; set; }
        public double? StudioRailW { get; set; }
    }

    // ------------------------------------------------------------ resizable tracks
    //
    // The board's height in pixels, kept per layout: the two want very different
    // sizes (a strip above the monitors vs. the editing desk under them), and one
    // shared number would mean every Studio toggle undid the other's tuning.
    // null = the layout's natural size, which is what everyone gets until they
    // drag. The lanes share out whatever height the board has, so this is really
    // "how thick are my tracks" — the reason the drag is worth having at all.
    private const double MinBoard = 90; // ruler + a full track stay reachable
    private double? _boardH;
    private double? _studioBoardH;

    private double? BoardH => _studio ? _studioBoardH : _boardH;

    /// <summary>The dragged height, if any. The max-height rides along to outrank
    /// the studio layout's 34vh cap and to keep a height saved on a roomy desktop
    /// from swallowing a phone screen — it is the same ceiling the drag clamps to.</summary>
    private string? BoardStyle() =>
        BoardH is { } h ? $"height:{h:0}px; max-height:70vh;" : null;

    /// <summary>The divider drag ended. JS applied the height live (no round-trip
    /// per pixel); this records where it landed and saves it to the account.</summary>
    [JSInvokable]
    public async Task OnBoardResize(double px)
    {
        await InvokeAsync(async () =>
        {
            var h = Math.Clamp(px, MinBoard, 4000);
            if (_studio) _studioBoardH = h; else _boardH = h;
            StateHasChanged();
            await SavePrefsAsync();
        });
    }

    /// <summary>Double-click the divider: back to this layout's natural size.</summary>
    private async Task ResetBoardHeightAsync()
    {
        if (_studio) _studioBoardH = null; else _boardH = null;
        await SavePrefsAsync();
    }

    // Width of the thumbnail rail while a monitor is focused (studio). Same
    // deal as the board height: null = the default (clamp to ~18vw), a number
    // = the user's drag, saved to the account so it follows them.
    private const double MinRail = 96; // thumbnails stay recognizable
    private double? _studioRailW;

    /// <summary>The rail divider drag ended (JS applied the width live).</summary>
    [JSInvokable]
    public async Task OnRailResize(double px)
    {
        await InvokeAsync(async () =>
        {
            _studioRailW = Math.Clamp(px, MinRail, 2000);
            StateHasChanged();
            await SavePrefsAsync();
        });
    }

    /// <summary>Double-click the rail divider: back to the default width.</summary>
    private async Task ResetRailWidthAsync()
    {
        _studioRailW = null;
        await SavePrefsAsync();
    }

    // Studio (opt-in): monitors fill the top, and the editing desk — transport,
    // camera chips, tracks — docks at the bottom, like a video editor.
    private bool _studio;
    private string? _focusCam; // studio program monitor; null = equal grid

    // 0.25/0.5 are slow motion — fine review of a fast moment; the rest skim.
    private static readonly double[] SpeedOptions = { 0.25, 0.5, 1, 2, 4, 8, 16 };
    private double _speed = 1;

    private static string SpeedLabel(double sp) => sp switch
    {
        0.25 => "¼×",
        0.5 => "½×",
        _ => $"{sp:0.#}×",
    };

    // ------------------------------------------------------------ zoomable view window
    //
    // The lanes show [_viewStart, _viewStart + _viewSpan] seconds of the day.
    // At the full 24 h a pixel is ~a minute of footage — zooming to the 60 s
    // floor makes a pixel ~50 ms, which is what turns scrubbing from "roughly
    // there" into frame-level seeking.

    private const double MinSpan = 60;
    private double _viewStart;
    private double _viewSpan = DaySeconds;
    private bool _showKeys;
    private bool _editClock;
    private bool _focusClock;

    private bool Zoomed => _viewSpan < DaySeconds - 1;

    private string Pct(double seconds) =>
        $"{(seconds - _viewStart) / _viewSpan * 100:0.####}%";

    /// <summary>Width of an exact span within the view window.</summary>
    private string W(double span) => $"{span / _viewSpan * 100:0.####}%";

    /// <summary>Event-mark width: never thinner than ~2px worth of the window.</summary>
    private string WMark(double span) => W(Math.Max(span, _viewSpan * 0.0018));

    /// <summary>Position on the full-day overview strip (never windowed).</summary>
    private static string DayPct(double seconds) => $"{seconds / DaySeconds * 100:0.###}%";

    private bool InView(double start, double end) =>
        end >= _viewStart && start <= _viewStart + _viewSpan;

    private static string SpanLabel(double span) => span switch
    {
        >= DaySeconds - 1 => "24 h",
        >= 3600 => $"{span / 3600:0.#} h",
        >= 60 => $"{span / 60:0.#} m",
        _ => $"{span:0} s",
    };

    /// <summary>
    /// Adaptive ruler: pick the largest step that yields ≲16 labeled ticks for
    /// the current window, with unlabeled minor ticks between them. Labels grow
    /// detail as the window shrinks (hours → minutes → seconds).
    /// </summary>
    private IEnumerable<(double T, string? Label)> RulerTicks()
    {
        // Smallest step that still fits ≲16 labels (the array is descending).
        double[] steps = { 10800, 7200, 3600, 1800, 900, 600, 300, 120, 60, 30, 10, 5, 2, 1 };
        double major = steps.LastOrDefault(s => _viewSpan / s <= 16, 10800);
        int perMajor = major >= 60 ? 4 : 5;
        double minor = major / perMajor;
        long from = (long)Math.Ceiling(_viewStart / minor);
        long to = (long)Math.Floor((_viewStart + _viewSpan) / minor);
        for (long k = from; k <= to; k++)
        {
            double t = k * minor;
            bool isMajor = k % perMajor == 0;
            yield return (t, isMajor ? TickLabel(t, major) : null);
        }
    }

    private static string TickLabel(double t, double major)
    {
        var ts = TimeSpan.FromSeconds(t);
        return major >= 3600 ? $"{(int)ts.TotalHours:00}"
            : major >= 60 ? $"{(int)ts.TotalHours:00}:{ts.Minutes:00}"
            : $"{(int)ts.TotalHours:00}:{ts.Minutes:00}:{ts.Seconds:00}";
    }

    // Adaptive playback: when the slowest healthy video falls behind the cursor
    // (server can't serve segments fast enough, or the browser can't decode this
    // many streams at this rate), the clock slows toward it instead of racing
    // ahead and forcing a seek-storm. Lag below LagSoft is normal jitter; at
    // LagHard the cursor is nearly holding still.
    private const double LagSoft = 1.5;
    private const double LagHard = 5.0;
    private double _maxLag;
    private bool Lagging => _playing && _maxLag > LagSoft;

    /// <summary>Only explicitly selected cameras load footage — scrubbing all cams at once is expensive.</summary>
    private IEnumerable<ApiCamera> Included => _cameras.Where(c => _included.Contains(c.Name));

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Server + credentials are shared with the live view's persisted settings.
            try
            {
                var json = await JS.InvokeAsync<string?>("neolink.lsGet", "neolink.view");
                if (json != null)
                    _server = JsonSerializer.Deserialize<PersistedView>(json)?.Server ?? "";
                var auth = await JS.InvokeAsync<string?>("neolink.lsGet", "neolink.auth");
                if (!string.IsNullOrWhiteSpace(auth))
                {
                    var el = JsonSerializer.Deserialize<JsonElement>(auth);
                    if (el.TryGetProperty("token", out var t)) _token = t.GetString();
                }
            }
            catch { }
            try { _origin = await JS.InvokeAsync<string>("neolink.defaultServer"); } catch { }
            if (string.IsNullOrWhiteSpace(_server))
                _server = _origin;

            try
            {
                var json = await JS.InvokeAsync<string?>("neolink.lsGet", PrefsKey);
                if (json != null)
                    ApplyPrefs(JsonSerializer.Deserialize<Prefs>(json));
            }
            catch { }
            await LoadServerPrefsAsync(); // signed in: the account's copy wins

            await LoadCamerasAsync();
            _included.RemoveWhere(name => _cameras.All(c => !string.Equals(c.Name, name, StringComparison.OrdinalIgnoreCase)));
            await LoadDayAsync();

            _selfRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("neolink.tlKeysInit", _selfRef);
            _ = ClockLoopAsync();
            _booted = true;
            StateHasChanged();
            return;
        }

        if (!_booted || _selfRef == null) return;

        if (_focusClock)
        {
            _focusClock = false;
            await JS.InvokeVoidAsync("neolink.focusEl", "tl-clock-edit");
        }

        // The lane strip only exists while cameras are selected; (re)hook the
        // scrub + zoom/hover + divider handlers whenever it (re)appears.
        if (Included.Any() && !_scrubInit)
        {
            _scrubInit = true;
            await JS.InvokeVoidAsync("neolink.tlScrubInit", "tl-scrub", _selfRef);
            await JS.InvokeVoidAsync("neolink.tlZoomInit", "tl-scrub", _selfRef);
            await JS.InvokeVoidAsync("neolink.tlResizeInit", "tl-resizer", "tl-board", _selfRef);
        }
        else if (!Included.Any() && _scrubInit)
        {
            _scrubInit = false;
            await JS.InvokeVoidAsync("neolink.tlScrubDispose", "tl-scrub");
            await JS.InvokeVoidAsync("neolink.tlZoomDispose", "tl-scrub");
            await JS.InvokeVoidAsync("neolink.tlResizeDispose", "tl-resizer");
        }

        // The rail divider only exists while a monitor is focused (studio) —
        // (re)hook its drag whenever it (re)appears.
        bool wantRail = FocusActive && Included.Count() > 1;
        if (wantRail && !_railInit)
        {
            _railInit = true;
            await JS.InvokeVoidAsync("neolink.tlColResizeInit", "tl-vresizer", _selfRef);
        }
        else if (!wantRail && _railInit)
        {
            _railInit = false;
            await JS.InvokeVoidAsync("neolink.tlColResizeDispose", "tl-vresizer");
        }
    }

    // ------------------------------------------------------------ data

    /// <summary>Base for BROWSER-side URLs (the segment videos) — goes through any reverse proxy.</summary>
    private string Base => _server.TrimEnd('/');

    /// <summary>
    /// Base for SERVER-side fetches: the circuit runs in this process, so its own
    /// origin resolves to loopback instead of looping out through a reverse proxy.
    /// </summary>
    private string ApiBase =>
        _origin.Length > 0 && string.Equals(Base, _origin.TrimEnd('/'), StringComparison.OrdinalIgnoreCase)
            ? Local.BaseUrl.TrimEnd('/')
            : Base;

    private string _origin = "";

    private string TokenQuery(char sep) =>
        string.IsNullOrEmpty(_token) ? "" : $"{sep}token={Uri.EscapeDataString(_token)}";

    /// <summary>Authenticated GET; null on failure (401 also sets the sign-in notice).</summary>
    private async Task<T?> GetJsonAsync<T>(string path)
    {
        var req = new HttpRequestMessage(HttpMethod.Get, $"{ApiBase}{path}");
        if (!string.IsNullOrEmpty(_token))
            req.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", _token);
        using var res = await Http.SendAsync(req);
        if (res.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            _error = "Authentication required — sign in on the live view first.";
            return default;
        }
        if (!res.IsSuccessStatusCode) return default;
        return await res.Content.ReadFromJsonAsync<T>();
    }

    private async Task LoadCamerasAsync()
    {
        try
        {
            var cams = await GetJsonAsync<List<ApiCamera>>("/api/cameras");
            _cameras.Clear();
            if (cams != null)
            {
                _cameras.AddRange(cams);
                _error = null;
            }
        }
        catch (Exception ex)
        {
            _error = $"Cannot reach {_server}: {ex.Message}";
        }
    }

    private async Task LoadDayAsync()
    {
        _cov.Clear();
        _eventSegs.Clear();
        _marks.Clear();
        _playing = false;

        // The timeline needs event recording; continuous footage is optional
        // (event clips play as a fallback when it is off or has gaps).
        try
        {
            var features = await GetJsonAsync<ApiFeaturesInfo>("/api/features");
            _supported = features?.Events == true;
            _continuous = features?.Continuous == true;
        }
        catch
        {
            _supported = false;
            return;
        }
        if (!_supported) return;

        // The events reply gives the day's colored lane marks AND playable event clips.
        try
        {
            var events = await GetJsonAsync<List<ApiEvent>>("/api/events?limit=1000");
            if (events == null)
            {
                _supported = false;
                return;
            }
            foreach (var ev in events)
            {
                var start = ev.Start.ToLocalTime();
                if (start.Date != _date) continue;
                double s = (start - _date).TotalSeconds;
                double dur = Math.Max(ev.Duration.TotalSeconds, 1);
                double e = Math.Min(DaySeconds, s + dur);
                if (!_marks.TryGetValue(ev.Camera, out var list))
                    _marks[ev.Camera] = list = new List<Mark>();
                list.Add(new Mark(s, e, LabelColor(ev.Labels), $"{ev.Title} · {start:HH:mm:ss}"));

                // The clip (full main-stream) is what plays; the sub-stream preview
                // is a lighter fallback. Offset into the file = cursor − event start.
                if (ev.HasClip || ev.HasPreview)
                {
                    var kind = ev.HasClip ? "clip" : "preview";
                    if (!_eventSegs.TryGetValue(ev.Camera, out var segs))
                        _eventSegs[ev.Camera] = segs = new List<Seg>();
                    segs.Add(new Seg(s, dur,
                        $"{Base}/api/events/{Uri.EscapeDataString(ev.Id)}/{kind}{TokenQuery('?')}"));
                }
            }
        }
        catch
        {
            _supported = false;
            return;
        }

        // Continuous coverage only for the cameras the user selected (the expensive part).
        if (_continuous)
        {
            foreach (var cam in Included)
                await LoadCoverageAsync(cam.Name);
        }
        _covRefreshed = DateTime.UtcNow; // the periodic refresh restarts from here

        // Land the cursor somewhere useful: today starts five minutes back —
        // autoplay then rolls through the recent past, which is almost always
        // what a "let me check the cameras" visit is after. Other days: midday.
        _t = _date == DateTime.Today
            ? Math.Max(0, (DateTime.Now - _date).TotalSeconds - 300)
            : DaySeconds / 2;
        // Autoplay: the day starts rolling as soon as it loads (first visit and
        // day changes alike) — pause is one click away, dead-stopped tiles that
        // LOOK broken were the common first impression.
        _playing = true;
        await SyncVideosAsync();
    }

    private async Task LoadCoverageAsync(string camera)
    {
        var date = _date.ToString("yyyy-MM-dd");
        try
        {
            var segs = await GetJsonAsync<List<ApiSegment>>(
                $"/api/recordings/{Uri.EscapeDataString(camera)}/{date}");
            _cov[camera] = BuildSegs(segs ?? new List<ApiSegment>(), camera, date);
        }
        catch
        {
            _cov[camera] = new List<Seg>();
        }
    }

    /// <summary>
    /// Segment spans: the file's real media length when the server reports it
    /// (so a segment cut short — camera suspended or offline — claims exactly the
    /// minutes it has, and the lane goes blank for the rest of the gap), with a
    /// butt-join to the next file when it starts about where this one ends so
    /// normal rolls stay seamless. Servers that predate the duration field fall
    /// back to the old typical-length guess.
    /// </summary>
    private List<Seg> BuildSegs(List<ApiSegment> files, string camera, string date)
    {
        var parsed = files
            .Select(f => (f.File, Start: ParseStart(f.File), f.Seconds, f.Live))
            .Where(x => x.Start >= 0)
            .OrderBy(x => x.Start)
            .ToList();

        var diffs = parsed.Zip(parsed.Skip(1), (a, b) => b.Start - a.Start)
            .Where(d => d > 1).OrderBy(d => d).ToList();
        double typical = diffs.Count > 0 ? Math.Clamp(diffs[diffs.Count / 2], 30, 1800) : 600;
        // The duration derives from the file's close time, which trails the last
        // frame by the recorder's silence window (~15 s) — joins get that much slack.
        const double Fuzz = 30;

        var segs = new List<Seg>();
        for (int i = 0; i < parsed.Count; i++)
        {
            double start = parsed[i].Start;
            double dur = parsed[i].Seconds > 0.5 ? parsed[i].Seconds : typical;
            double span = dur;
            if (i + 1 < parsed.Count)
            {
                double gap = parsed[i + 1].Start - start;
                if (gap <= dur + Fuzz) span = gap; // contiguous roll: butt-join
            }
            else if (parsed[i].Live
                     || (date == DateTime.Today.ToString("yyyy-MM-dd")
                         && start + dur > (DateTime.Now - DateTime.Today).TotalSeconds - 120))
            {
                // This file is still being written. The server says so outright
                // (live, from the recorder's own memory — trustworthy even where
                // an open file's mtime is stale: NTFS, FUSE, network mounts);
                // older servers without the flag fall back to the mtime heuristic:
                // the newest file whose reported end reaches (about) now.
                // Cover up to NOW (plus a small buffer that the once-a-minute
                // coverage refresh renews) — and no further: projecting a full
                // segment length ahead made lanes reach into the future by
                // different amounts per camera (a high-bitrate camera rolls on
                // the size cap every few minutes, the others on the timer), so
                // equal footage looked unequal. A newest file that ENDED long
                // ago (camera suspended/offline right now) gets no allowance:
                // that lane is genuinely blank from its end onward. The REAL
                // reported seconds anchor the max — never the typical-length
                // guess, which would project a just-opened file a whole
                // segment into the future.
                span = Math.Max(Math.Max(0, parsed[i].Seconds),
                    (DateTime.Now - DateTime.Today).TotalSeconds - start + 75);
            }
            span = Math.Min(span, DaySeconds - start);
            segs.Add(new Seg(start, span,
                $"{Base}/api/recordings/{Uri.EscapeDataString(camera)}/{date}/{parsed[i].File}{TokenQuery('?')}"));
        }
        return segs;
    }

    private static double ParseStart(string file) =>
        file.Length >= 8
        && int.TryParse(file.AsSpan(0, 2), out var h)
        && int.TryParse(file.AsSpan(3, 2), out var m)
        && int.TryParse(file.AsSpan(6, 2), out var s)
            ? h * 3600 + m * 60 + s
            : -1;

    private static string LabelColor(List<string> labels) =>
        labels.Contains("person") ? "#4f8cff"
        : labels.Contains("vehicle") ? "#ffb020"
        : labels.Contains("animal") ? "#3fd07f"
        : labels.Contains("package") ? "#b06bff"
        : labels.Contains("crying") ? "#ff7eb6" // crying-sound detection (indoor cams)
        : labels.Contains("external") ? "#e05c6e" // held open from Home Assistant
        : "#8a93a5"; // motion / other

    // ------------------------------------------------------------ playback

    [JSInvokable]
    public async Task OnTimelineScrub(double fraction, bool final)
    {
        await InvokeAsync(async () =>
        {
            // The lane strip shows the view window, so a drag fraction maps
            // through it — zoomed in, the same pixel distance seeks far finer.
            _t = _viewStart + Math.Clamp(fraction, 0, 1) * _viewSpan;
            await SyncVideosAsync();
            StateHasChanged();
        });
    }

    /// <summary>Wheel/pinch zoom: the instant under the pointer stays put.</summary>
    [JSInvokable]
    public async Task OnTimelineZoom(double frac, double factor)
    {
        await InvokeAsync(() =>
        {
            double anchor = _viewStart + Math.Clamp(frac, 0, 1) * _viewSpan;
            _viewSpan = Math.Clamp(_viewSpan * factor, MinSpan, DaySeconds);
            _viewStart = Math.Clamp(anchor - Math.Clamp(frac, 0, 1) * _viewSpan, 0, DaySeconds - _viewSpan);
            StateHasChanged();
        });
    }

    [JSInvokable]
    public async Task OnTimelinePan(int dir)
    {
        await InvokeAsync(() =>
        {
            _viewStart = Math.Clamp(_viewStart + dir * _viewSpan * 0.2, 0, DaySeconds - _viewSpan);
            StateHasChanged();
        });
    }

    /// <summary>Dragging the day-overview strip moves the zoomed window (a viewport
    /// control — the cursor stays where it is).</summary>
    [JSInvokable]
    public async Task OnOverviewSeek(double frac)
    {
        await InvokeAsync(() =>
        {
            if (!Zoomed) return;
            _viewStart = Math.Clamp(frac * DaySeconds - _viewSpan / 2, 0, DaySeconds - _viewSpan);
            StateHasChanged();
        });
    }

    [JSInvokable]
    public async Task OnTimelineKey(string action)
    {
        await InvokeAsync(async () =>
        {
            var parts = action.Split(':');
            switch (parts[0])
            {
                case "playpause":
                    await TogglePlayAsync();
                    break;
                case "step" when double.TryParse(parts[1], System.Globalization.CultureInfo.InvariantCulture, out var s):
                    await StepAsync(s);
                    break;
                case "event":
                    await JumpEventAsync(parts[1] == "-1" ? -1 : 1);
                    break;
                case "zoom":
                    if (parts[1] == "reset") await ResetZoomAsync();
                    else await OnTimelineZoom(CursorFrac(), parts[1] == "in" ? 0.6 : 1.7);
                    break;
                case "clock":
                    OpenClockEdit();
                    break;
                case "snap":
                    // Unambiguous targets only: the focused monitor, or a lone camera.
                    var target = FocusActive ? _focusCam
                        : Included.Count() == 1 ? Included.First().Name : null;
                    if (target != null) await SnapshotAsync(target);
                    break;
            }
            StateHasChanged();
        });
    }

    private double CursorFrac()
    {
        double f = (_t - _viewStart) / _viewSpan;
        return f is >= 0 and <= 1 ? f : 0.5;
    }

    private async Task TogglePlayAsync()
    {
        _playing = !_playing;
        _lastTick = DateTime.UtcNow;
        await SyncVideosAsync();
    }

    /// <summary>Nudge the cursor and keep it on screen. Fine steps (0.1 s) pair
    /// with the tight paused seek tolerance for near-frame-level review.</summary>
    private async Task StepAsync(double seconds)
    {
        _t = Math.Clamp(_t + seconds, 0, DaySeconds - 0.05);
        EnsureCursorVisible();
        await SyncVideosAsync();
        StateHasChanged();
    }

    /// <summary>Snap to the previous/next detection across the included cameras —
    /// the fastest way to review a day: [ and ] hop from incident to incident.</summary>
    private async Task JumpEventAsync(int dir)
    {
        var starts = Included
            .SelectMany(c => _marks.TryGetValue(c.Name, out var m) ? m : (IEnumerable<Mark>)Array.Empty<Mark>())
            .Select(m => m.Start)
            .OrderBy(s => s);
        double? target = dir > 0
            ? starts.Where(s => s > _t + 0.25).Cast<double?>().FirstOrDefault()
            : starts.Where(s => s < _t - 0.25).Cast<double?>().LastOrDefault();
        if (target == null) return;
        _t = target.Value;
        EnsureCursorVisible(center: true);
        await SyncVideosAsync();
        StateHasChanged();
    }

    private async Task ResetZoomAsync()
    {
        _viewStart = 0;
        _viewSpan = DaySeconds;
        await Task.CompletedTask;
        StateHasChanged();
    }

    /// <summary>Keeps the cursor inside the zoomed window after steps and jumps.</summary>
    private void EnsureCursorVisible(bool center = false)
    {
        if (!Zoomed) return;
        if (center)
            _viewStart = _t - _viewSpan / 2;
        else if (_t < _viewStart || _t > _viewStart + _viewSpan)
            _viewStart = _t - _viewSpan * 0.2;
        else
            return;
        _viewStart = Math.Clamp(_viewStart, 0, DaySeconds - _viewSpan);
    }

    private void OpenClockEdit()
    {
        _editClock = true;
        _focusClock = true;
    }

    /// <summary>"16:39" or "16:39:12" → jump straight there.</summary>
    private async Task ClockEditedAsync(ChangeEventArgs e)
    {
        _editClock = false;
        if (!TimeSpan.TryParse((string?)e.Value, System.Globalization.CultureInfo.InvariantCulture, out var ts)
            || ts < TimeSpan.Zero || ts >= TimeSpan.FromDays(1))
            return;
        _t = ts.TotalSeconds;
        EnsureCursorVisible(center: true);
        await SyncVideosAsync();
    }

    private async Task SetSpeedAsync(double speed)
    {
        _speed = speed;
        await SavePrefsAsync();
        await SyncVideosAsync(); // applies the new playbackRate immediately
    }

    private void ApplyPrefs(Prefs? p)
    {
        if (p == null) return;
        if (p.Included != null) _included = new HashSet<string>(p.Included, StringComparer.OrdinalIgnoreCase);
        if (p.Speed is { } sp && SpeedOptions.Contains(sp)) _speed = sp;
        if (p.Studio is { } st) _studio = st;
        if (p.BoardH is { } bh) _boardH = Math.Clamp(bh, MinBoard, 4000);
        if (p.StudioBoardH is { } sbh) _studioBoardH = Math.Clamp(sbh, MinBoard, 4000);
        if (p.StudioRailW is { } rw) _studioRailW = Math.Clamp(rw, MinRail, 2000);
    }

    /// <summary>Signed in: the account's server-side prefs override the local copy —
    /// preferences follow the user across browsers. Signed out (or the endpoint is
    /// unavailable): localStorage carries on alone.</summary>
    private async Task LoadServerPrefsAsync()
    {
        if (string.IsNullOrEmpty(_token)) return;
        try
        {
            var p = await GetJsonAsync<Prefs>("/api/me/settings/timeline");
            if (p == null || (p.Included == null && p.Speed == null && p.Studio == null))
                return; // never saved yet — keep whatever localStorage had
            ApplyPrefs(p);
            // Refresh the local copy so the next (pre-network) boot starts right.
            try { await JS.InvokeVoidAsync("neolink.lsSet", PrefsKey, SerializePrefs()); } catch { }
        }
        catch { }
    }

    private string SerializePrefs() =>
        JsonSerializer.Serialize(new Prefs
        {
            Included = _included.ToList(),
            Speed = _speed,
            Studio = _studio,
            BoardH = _boardH,
            StudioBoardH = _studioBoardH,
            StudioRailW = _studioRailW,
        });

    private async Task SavePrefsAsync()
    {
        var json = SerializePrefs();
        try { await JS.InvokeVoidAsync("neolink.lsSet", PrefsKey, json); } catch { }
        if (string.IsNullOrEmpty(_token)) return;
        try
        {
            var req = new HttpRequestMessage(HttpMethod.Put, $"{ApiBase}/api/me/settings/timeline");
            req.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", _token);
            req.Content = new StringContent(json, System.Text.Encoding.UTF8, "application/json");
            using var _ = await Http.SendAsync(req);
        }
        catch { /* transient: localStorage still has it */ }
    }

    private async Task ClockLoopAsync()
    {
        _clock = new PeriodicTimer(TimeSpan.FromMilliseconds(500));
        _lastTick = DateTime.UtcNow;
        try
        {
            while (await _clock.WaitForNextTickAsync())
            {
                var now = DateTime.UtcNow;
                var elapsed = (now - _lastTick).TotalSeconds;
                _lastTick = now;

                // Viewing TODAY, footage keeps arriving: refresh the coverage
                // once a minute so new segments show up while the page is open.
                // Without this a suspend/resume (or any recording that starts
                // after the day loaded) records to disk but the lanes stay
                // blank until a manual reload — REC on, timeline empty.
                if (_date == DateTime.Today && _continuous && Included.Any()
                    && now - _covRefreshed > TimeSpan.FromSeconds(60))
                {
                    _covRefreshed = now;
                    await InvokeAsync(async () =>
                    {
                        foreach (var cam in Included)
                            await LoadCoverageAsync(cam.Name);
                        StateHasChanged();
                    });
                }

                if (!_playing) continue;
                double advance = elapsed * _speed;
                if (_maxLag > LagSoft)
                {
                    // Feedback: hold the cursor back for the slowest stream. The
                    // floor keeps it crawling forward so one bad file can never
                    // freeze the whole timeline.
                    advance *= Math.Clamp(1 - (_maxLag - LagSoft) / (LagHard - LagSoft), 0.1, 1.0);
                }
                _t += advance;
                if (_t >= DaySeconds - 1)
                {
                    _t = DaySeconds - 1;
                    _playing = false;
                }
                // Zoomed playback follows the cursor — but ONLY when it just
                // walked up to the window's right edge. A cursor far outside the
                // window means the user deliberately zoomed elsewhere; stealing
                // the view back would fight them.
                if (Zoomed && _t > _viewStart + _viewSpan * 0.85 && _t < _viewStart + _viewSpan * 1.5)
                    _viewStart = Math.Clamp(_t - _viewSpan * 0.15, 0, DaySeconds - _viewSpan);
                await InvokeAsync(async () =>
                {
                    await SyncVideosAsync();
                    StateHasChanged();
                });
            }
        }
        catch (OperationCanceledException) { }
        catch (ObjectDisposedException) { }
    }

    /// <summary>The footage under the cursor for a camera: continuous first, then event clips.</summary>
    private Seg? SegmentAt(string camera)
    {
        if (_cov.TryGetValue(camera, out var cont))
        {
            var hit = cont.FirstOrDefault(s => _t >= s.Start && _t < s.Start + s.Span);
            if (hit != null) return hit;
        }
        if (_eventSegs.TryGetValue(camera, out var evs))
            return evs.FirstOrDefault(s => _t >= s.Start && _t < s.Start + s.Span);
        return null;
    }

    /// <summary>
    /// Points every included camera's player at the footage under the cursor and
    /// measures how far the slowest healthy player is behind it — the feedback
    /// signal for the adaptive clock (broken media reports -1 and is ignored).
    /// One batched interop call per tick: this runs twice a second while playing,
    /// so per-camera round trips would multiply with the wall size.
    /// </summary>
    private async Task SyncVideosAsync()
    {
        var entries = new List<object>();
        foreach (var cam in Included)
        {
            var seg = SegmentAt(cam.Name);
            if (seg == null)
            {
                _noFootage.Add(cam.Name);
                entries.Add(new { id = VideoId(cam.Name), url = (string?)null, offset = 0d, playing = false, rate = 1 });
            }
            else
            {
                _noFootage.Remove(cam.Name);
                entries.Add(new
                {
                    id = VideoId(cam.Name),
                    url = (string?)seg.Url,
                    offset = _t - seg.Start,
                    playing = _playing,
                    rate = _speed,
                });
            }
        }
        if (entries.Count == 0)
        {
            _maxLag = 0;
            return;
        }
        _maxLag = await JS.InvokeAsync<double>("neolink.tlSyncAll", entries);
    }

    // ------------------------------------------------------------ actions

    private async Task ChangeDayAsync(int days)
    {
        var next = _date.AddDays(days);
        if (next > DateTime.Today) return;
        _date = next;
        await LoadDayAsync();
    }

    // ------------------------------------------------------------ calendar picker

    /// <summary>Loads the set of days that hold footage (once) and opens the calendar on the current month.</summary>
    private async Task ToggleCalendarAsync()
    {
        if (_showCalendar) { _showCalendar = false; return; }
        _calMonth = new DateTime(_date.Year, _date.Month, 1);
        await LoadContentDaysAsync();
        _showCalendar = true;
    }

    private async Task LoadContentDaysAsync()
    {
        try
        {
            var days = await GetJsonAsync<List<string>>("/api/events/days");
            _contentDays.Clear();
            if (days != null)
                foreach (var s in days)
                    if (DateTime.TryParseExact(s, "yyyy-MM-dd", null,
                            System.Globalization.DateTimeStyles.None, out var d))
                        _contentDays.Add(d.Date);
        }
        catch { /* highlighting is a nicety; the picker still works without it */ }
    }

    private void ShiftMonth(int months)
    {
        var next = _calMonth.AddMonths(months);
        var thisMonth = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
        _calMonth = next > thisMonth ? thisMonth : next;
    }

    private async Task PickDayAsync(DateTime day)
    {
        _showCalendar = false;
        if (day > DateTime.Today || day.Date == _date) return;
        _date = day.Date;
        await LoadDayAsync();
    }

    /// <summary>Month grid, Monday-first: leading blanks (null) then each day of the month.</summary>
    private IEnumerable<DateTime?> CalendarCells()
    {
        int lead = ((int)_calMonth.DayOfWeek + 6) % 7; // Mon=0 … Sun=6
        for (int i = 0; i < lead; i++) yield return null;
        int days = DateTime.DaysInMonth(_calMonth.Year, _calMonth.Month);
        for (int d = 1; d <= days; d++) yield return new DateTime(_calMonth.Year, _calMonth.Month, d);
    }

    private async Task ToggleCameraAsync(string name)
    {
        if (_included.Remove(name))
        {
            _cov.Remove(name); // free it; reselecting fetches fresh coverage
        }
        else
        {
            _included.Add(name);
            if (_continuous)
                await LoadCoverageAsync(name); // lazy: only now does this camera cost anything
        }
        await SavePrefsAsync();
        await SyncVideosAsync();
    }

    // ------------------------------------------------------------ helpers

    private static string VideoId(string camera) => "tlv-" + Uri.EscapeDataString(camera);

    /// <summary>Square-ish grid: 1 cam fills the stage, 2 side by side, 3-4 in a 2x2, ...</summary>
    private int TileColumns()
    {
        int n = Included.Count();
        return n <= 1 ? 1 : (int)Math.Ceiling(Math.Sqrt(n));
    }

    // ------------------------------------------------------------ studio layout

    // Focus needs at least TWO monitors: one for the program view and one or more
    // for the thumbnail rail. Promoting the only camera is meaningless — it is
    // already the sole monitor — and the 3-column program·divider·rail grid would
    // leave the rail column empty, shoving the lone monitor left with dead space
    // on the right.
    private bool FocusActive =>
        _studio && _focusCam != null && Included.Count() > 1
        && Included.Any(c => string.Equals(c.Name, _focusCam, StringComparison.OrdinalIgnoreCase));

    private bool IsFocus(string cam) => string.Equals(cam, _focusCam, StringComparison.OrdinalIgnoreCase);

    private async Task ToggleStudioAsync()
    {
        _studio = !_studio;
        if (!_studio) _focusCam = null;
        await SavePrefsAsync();
    }

    /// <summary>Studio only: a click promotes the tile to the program monitor;
    /// a click on the program monitor restores the equal grid. A lone camera has
    /// nothing to promote against, so the click is a no-op (and never leaves a
    /// stale focus that would spring the rail open when a second camera joins).</summary>
    private void ToggleFocus(string cam)
    {
        if (!_studio || Included.Count() <= 1) { _focusCam = null; return; }
        _focusCam = IsFocus(cam) ? null : cam;
    }

    /// <summary>Equal grid normally; focused: program monitor · divider · rail.
    /// The rail column is the user's to drag (see the vresizer); min() keeps a
    /// width saved on a roomy desktop from swallowing a narrow screen.</summary>
    private string GridStyle() => FocusActive
        ? $"grid-template-columns: minmax(0, 1fr) 10px {(
            _studioRailW is { } w ? $"min({w:0}px, 45vw)" : "clamp(96px, 18vw, 220px)")};"
        : $"grid-template-columns: repeat({TileColumns()}, 1fr);";

    private string? TileStyle(string cam) => !FocusActive ? null
        : IsFocus(cam) ? $"grid-column: 1; grid-row: 1 / span {Math.Max(1, Included.Count() - 1)};"
        : "grid-column: 3;";

    /// <summary>Downloads the current frame of a camera's player as a PNG
    /// (e.g. "driveway 2026-07-15 08.30.12.png").</summary>
    private async Task SnapshotAsync(string camera)
    {
        var file = $"{camera} {_date:yyyy-MM-dd} {TimeText(_t).Replace(':', '.')}.png";
        try { await JS.InvokeVoidAsync("neolink.tlSnap", VideoId(camera), file); } catch { }
    }

    // ------------------------------------------------------------ footage export
    //
    // One camera, one day, [from, to]: the server streams a zip of the segments
    // overlapping the range (whole files — lossless, no re-encode) and the
    // browser downloads it. The dialog pre-fills the zoomed window, so "zoom to
    // the incident, hit Export" needs no typing, and it shows the size before
    // the user commits to a multi-gigabyte download.

    private bool _showExport;
    private string _exCam = "";
    private string _exFrom = "00:00:00";
    private string _exTo = "23:59:59";
    private int _exFiles;
    private long _exBytes;
    private bool _exBusy;
    private string? _exError;
    // Format preference: one combined MP4 when the range allows it (same stream
    // config throughout), otherwise the zip of original segments takes over.
    private string _exFormat = "mp4";
    private long? _exMp4Bytes;
    private long? _exMp4DurMs;
    private string? _exMp4Reason;

    private string EffectiveFormat => _exFormat == "mp4" && _exMp4Bytes != null ? "mp4" : "zip";

    /// <summary>The bytes the chosen format would download.</summary>
    private long EffBytes => EffectiveFormat == "mp4" && _exMp4Bytes is { } mb ? mb : _exBytes;

    /// <summary>One-click ranges: the zoomed view, the last hour (today), the whole day.</summary>
    private async Task ApplyExportPresetAsync(string preset)
    {
        switch (preset)
        {
            case "view" when Zoomed:
                _exFrom = TimeText(_viewStart);
                _exTo = TimeText(Math.Min(_viewStart + _viewSpan, DaySeconds - 1));
                break;
            case "hour":
                double now = (DateTime.Now - DateTime.Today).TotalSeconds;
                _exFrom = TimeText(Math.Max(0, now - 3600));
                _exTo = TimeText(Math.Min(now, DaySeconds - 1));
                break;
            case "day":
                _exFrom = "00:00:00";
                _exTo = "23:59:59";
                break;
        }
        await ExportEstimateAsync();
    }

    private async Task OpenExportAsync()
    {
        if (!Included.Any()) return;
        // The focused monitor (studio) or the first loaded camera; keep a prior
        // valid pick so reopening the dialog remembers it.
        if (!Included.Any(c => string.Equals(c.Name, _exCam, StringComparison.OrdinalIgnoreCase)))
            _exCam = (FocusActive ? _focusCam : null) ?? Included.First().Name;
        if (Zoomed)
        {
            _exFrom = TimeText(_viewStart);
            _exTo = TimeText(Math.Min(_viewStart + _viewSpan, DaySeconds - 1));
        }
        else
        {
            _exFrom = "00:00:00";
            _exTo = "23:59:59";
        }
        _showExport = true;
        await ExportEstimateAsync();
    }

    private async Task PickExportCamAsync(string camera)
    {
        _exCam = camera;
        await ExportEstimateAsync();
    }

    private async Task ExportRangeEditedAsync(ChangeEventArgs e, bool from)
    {
        var text = ((string?)e.Value ?? "").Trim();
        if (from) _exFrom = text; else _exTo = text;
        await ExportEstimateAsync();
    }

    private bool ExportRangeValid(out TimeSpan fromT, out TimeSpan toT)
    {
        toT = default;
        return TimeSpan.TryParse(_exFrom, System.Globalization.CultureInfo.InvariantCulture, out fromT)
            && TimeSpan.TryParse(_exTo, System.Globalization.CultureInfo.InvariantCulture, out toT)
            && fromT >= TimeSpan.Zero && toT <= TimeSpan.FromDays(1) && fromT < toT;
    }

    private string ExportQuery() =>
        $"/api/recordings/{Uri.EscapeDataString(_exCam)}/{_date:yyyy-MM-dd}/export" +
        $"?from={Uri.EscapeDataString(_exFrom)}&to={Uri.EscapeDataString(_exTo)}";

    private async Task ExportEstimateAsync()
    {
        if (!ExportRangeValid(out _, out _))
        {
            _exError = "times must be HH:mm[:ss] with From before To";
            _exFiles = 0;
            return;
        }
        _exError = null;
        _exBusy = true;
        StateHasChanged();
        try
        {
            var est = await GetJsonAsync<JsonElement?>(ExportQuery() + "&estimate=1");
            if (est is { ValueKind: JsonValueKind.Object } o
                && o.TryGetProperty("files", out var f) && o.TryGetProperty("bytes", out var b))
            {
                _exFiles = f.GetInt32();
                _exBytes = b.GetInt64();
                _exMp4Bytes = o.TryGetProperty("mp4Bytes", out var mb) && mb.ValueKind == JsonValueKind.Number
                    ? mb.GetInt64() : null;
                _exMp4DurMs = o.TryGetProperty("mp4DurationMs", out var md) && md.ValueKind == JsonValueKind.Number
                    ? md.GetInt64() : null;
                _exMp4Reason = o.TryGetProperty("mp4Reason", out var mr) && mr.ValueKind == JsonValueKind.String
                    ? mr.GetString() : null;
            }
            else
            {
                _exError = "could not size the range — is the server reachable?";
                _exFiles = 0;
            }
        }
        catch
        {
            _exError = "could not size the range — is the server reachable?";
            _exFiles = 0;
        }
        finally
        {
            _exBusy = false;
            StateHasChanged();
        }
    }

    /// <summary>Hands the export URL to the browser: the zip streams straight into
    /// its download manager (the server names the file via Content-Disposition).</summary>
    private async Task StartExportAsync()
    {
        if (_exBusy || _exFiles == 0 || !ExportRangeValid(out _, out _)) return;
        var format = EffectiveFormat == "mp4" ? "&format=mp4" : "";
        try { await JS.InvokeVoidAsync("neolink.download", $"{Base}{ExportQuery()}{format}{TokenQuery('&')}"); } catch { }
        _showExport = false;
    }

    private static string SizeText(long bytes) => bytes switch
    {
        >= 1024L * 1024 * 1024 => $"{bytes / (1024.0 * 1024 * 1024):0.0} GB",
        >= 1024L * 1024 => $"{bytes / (1024.0 * 1024):0} MB",
        _ => $"{bytes / 1024.0:0} KB",
    };

    private static string DurText(long ms)
    {
        var t = TimeSpan.FromMilliseconds(ms);
        return t.TotalHours >= 1 ? $"{(int)t.TotalHours} h {t.Minutes:00} m"
            : t.TotalMinutes >= 1 ? $"{t.Minutes} m {t.Seconds:00} s"
            : $"{t.TotalSeconds:0.#} s";
    }

    private static string TimeText(double t) =>
        TimeSpan.FromSeconds(Math.Clamp(t, 0, DaySeconds - 1)).ToString(@"hh\:mm\:ss");

    public async ValueTask DisposeAsync()
    {
        _clock?.Dispose();
        try
        {
            await JS.InvokeVoidAsync("neolink.tlScrubDispose", "tl-scrub");
            await JS.InvokeVoidAsync("neolink.tlZoomDispose", "tl-scrub");
            await JS.InvokeVoidAsync("neolink.tlResizeDispose", "tl-resizer");
            await JS.InvokeVoidAsync("neolink.tlColResizeDispose", "tl-vresizer");
            await JS.InvokeVoidAsync("neolink.tlKeysDispose");
        }
        catch { /* circuit already gone */ }
        _selfRef?.Dispose();
    }
}
