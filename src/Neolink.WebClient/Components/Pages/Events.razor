@page "/events"
@page "/events/{Camera}"
@using System.Text.Json
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject LocalApiInfo Local
@implements IAsyncDisposable

@* Dedicated events page — the landing target for "motion detected" push
   notifications (Home Assistant's clickAction can deep-link /events/{camera}).
   A recent-events list on the left, the selected clip on the right (stacked on
   phones), and a one-tap jump to that camera's live feed. *@

<PageTitle>Neolink.NET — Events</PageTitle>

<div class="ev-page @((_sdMode ? _sdSelected != null : _selected != null) ? "has-selection" : "")">
    <div class="toolbar ev-toolbar">
        <a class="tool-btn" href="" title="Back to the live camera wall">@UiIcon.Render("chev-left", 16) <span class="tool-name">Live</span></a>
        <span class="tool-label">EVENTS</span>

        @* Events ⇄ Live segmented toggle: the fast switch the use case asks for. *@
        <span class="ev-switch" role="tablist">
            <span class="ev-switch-opt active" role="tab" aria-selected="true">Events</span>
            <a class="ev-switch-opt" role="tab" href="@LiveHref()" title="Watch the cameras live">Live</a>
        </span>

        <span class="tile-spacer"></span>

        @* SOURCE: what the list shows — this server's recorded events, or footage
           on the camera's own SD card. A labelled segmented switch: the previous
           lone "SD card" chip read as an action, not as the page-wide mode it is. *@
        <span class="tool-label">SOURCE</span>
        <span class="ev-switch" role="tablist" style="margin-right:8px">
            <button class="ev-switch-opt @(!_sdMode ? "active" : "")" role="tab" aria-selected="@(!_sdMode)"
                    title="Events this server recorded"
                    @onclick="() => SetSdModeAsync(false)">Server</button>
            <button class="ev-switch-opt @(_sdMode ? "active" : "")" role="tab" aria-selected="@_sdMode"
                    title="Recordings stored on the camera's own SD card — including footage from while this server was off"
                    @onclick="() => SetSdModeAsync(true)">SD card <span class="beta-tag">BETA</span></button>
        </span>

        @if (!_sdMode)
        {
            <select class="event-filter" @bind="_cameraFilter" @bind:after="OnFilterChanged"
                    title="Show one camera's events, or all of them">
                <option value="">all cameras</option>
                @foreach (var c in _cameras)
                {
                    <option value="@c.Name">@c.Name</option>
                }
            </select>
            <button class="chip @(_unreviewedOnly ? "chip-active" : "chip-off")"
                    title="@(_unreviewedOnly ? "Showing only events you haven't opened yet — click to show all" : "Show only events you haven't opened yet")"
                    @onclick="() => _unreviewedOnly = !_unreviewedOnly">unreviewed only</button>
            <span class="tool-label">DAY</span>
            <input class="event-filter event-date-input" type="date"
                   title="Show one day's events (blank = the rolling last 24 hours)"
                   max="@DateTime.Today.ToString("yyyy-MM-dd")"
                   value="@(_date?.ToString("yyyy-MM-dd") ?? "")"
                   @onchange="e => SetDateAsync((string?)e.Value)" />
            @if (_date != null)
            {
                <button class="chip" title="Back to the rolling last 24 hours" @onclick="() => SetDateAsync(null)">↺ 24h</button>
            }
            <button class="chip @(_selectMode ? "chip-active" : "")"
                    title="@(_selectMode ? "Leave selection mode without deleting" : "Pick multiple events to delete at once")"
                    @onclick="ToggleSelectModeAsync">@UiIcon.Render("trash", 13) Delete…</button>
        }
        else
        {
            <span class="tool-label">CAMERA</span>
            <select class="event-filter" @bind="_sdCamera" @bind:after="LoadSdAsync"
                    title="Whose SD card to browse (one camera at a time)">
                @foreach (var c in _cameras)
                {
                    <option value="@c.Name">@c.Name</option>
                }
            </select>
            <span class="tool-label">DAY</span>
            <input class="event-filter event-date-input" type="date"
                   title="Day to list from the camera's SD card — days with footage are offered as chips in the list"
                   max="@DateTime.Today.ToString("yyyy-MM-dd")"
                   value="@_sdDate.ToString("yyyy-MM-dd")"
                   @onchange="e => SetSdDateAsync((string?)e.Value)" />
        }
        <button class="icon-btn" title="Refresh" @onclick="RefreshCurrentAsync">@UiIcon.Render("refresh", 14)</button>
    </div>

    @if (_selectMode)
    {
        @* Selection action bar: what's picked, select-all, and the delete trigger. *@
        <div class="ev-selbar">
            <label class="ev-selall" title="Select or clear every event in view">
                <input type="checkbox" checked="@AllShownSelected"
                       @onchange="e => ToggleSelectAll((bool)(e.Value ?? false))" />
                <span>@(_selectedIds.Count == 0 ? "Select all" : $"{_selectedIds.Count} selected")</span>
            </label>
            <span class="tile-spacer"></span>
            <button class="chip" disabled="@(_selectedIds.Count == 0)" @onclick="ClearSelection">Clear</button>
            <button class="chip ev-del-btn" disabled="@(_selectedIds.Count == 0)" @onclick="OpenDeleteAsync">
                @UiIcon.Render("trash", 13) Delete@(_selectedIds.Count > 0 ? $" ({_selectedIds.Count})" : "")
            </button>
        </div>
    }

    @if (_sdMode)
    {
        @* Camera-SD browser: footage the CAMERA recorded onto its own card,
           listed and streamed straight off the camera. Works even when this
           server records nothing — it's a window into the camera's storage. *@
        <div class="ev-body">
            <div class="ev-list" role="list">
                @if (_sdLoading)
                {
                    <div class="notice"><span class="btn-spinner"></span> Asking the camera…</div>
                }
                else if (_sdError != null)
                {
                    <div class="notice">@_sdError</div>
                }
                else
                {
                    @if (_sdDays.Count > 0)
                    {
                        <div class="ev-day">
                            <div class="ev-day-head">@_sdDate.ToString("MMMM yyyy").ToUpperInvariant() — DAYS WITH RECORDINGS</div>
                            <div class="stream-options sd-day-chips">
                                @foreach (var d in _sdDays)
                                {
                                    var day = d;
                                    <button class="chip @(day == _sdDate.Day ? "chip-active" : "")"
                                            title="List this day" @onclick="() => SetSdDayAsync(day)">@day</button>
                                }
                            </div>
                        </div>
                    }
                    @if (_sdRecs.Count == 0)
                    {
                        <div class="notice">No recordings on the camera's SD card for @DayLabel(_sdDate).ToLowerInvariant().</div>
                    }
                    else
                    {
                        <div class="ev-day">
                            <div class="ev-day-head">@DayLabel(_sdDate) <span class="event-day-count">@_sdRecs.Count</span></div>
                            @foreach (var r in _sdRecs)
                            {
                                <div class="event-row @(_sdSelected?.File == r.File ? "selected" : "")"
                                     @key="r.File" role="listitem" title="Play this recording"
                                     @onclick="() => SelectSdAsync(r)">
                                    <div class="event-row-main">
                                        <span class="event-title">@UiIcon.Render("film", 13) @r.TimeLabel</span>
                                        <span class="event-sub">@r.DurationLabel · @r.SizeLabel · @(r.StreamType == "sub" ? "SD" : "HD")</span>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    <div class="notice small">
                        Recorded by the <b>camera itself</b> onto its SD card — including anything from
                        while this server was off. Playback streams straight from the camera, so
                        loading can be slow (especially over Wi-Fi).
                    </div>
                }
            </div>

            <div class="ev-detail @(_sdSelected == null ? "empty" : "")">
                @if (_sdSelected is { } sr)
                {
                    <div class="event-player-head">
                        <button class="icon-btn ev-back" title="Back to the list" @onclick="() => _sdSelected = null">@UiIcon.Render("chev-left", 16)</button>
                        <div class="event-player-title">
                            <span class="event-title">@_sdCamera — @sr.TimeLabel</span>
                            <span class="event-sub">@sr.Start.ToString("ddd d MMM") · @sr.DurationLabel · @sr.SizeLabel</span>
                        </div>
                        <a class="chip" href="@SdUrl(sr, dl: true)" title="Save this recording as a file">
                            @UiIcon.Render("download", 13) Download
                        </a>
                    </div>
                    @* zoom-on: SD-card playback gets the same digital zoom as live views. *@
                    <div class="event-player-media zoom-on" @key="sr.File">
                        <video id="ev-video" controls autoplay playsinline></video>
                        @ZoomHud
                    </div>
                    <div class="notice small">
                        Streams as it loads; jumping ahead only works for the part that has
                        already arrived. Use Download for a local copy you can scrub freely.
                    </div>
                }
                else
                {
                    <div class="ev-detail-empty">
                        <span class="ev-detail-empty-icon">@UiIcon.Render("camera", 30)</span>
                        <span>Select a recording to play it</span>
                    </div>
                }
            </div>
        </div>
    }
    else if (_error != null)
    {
        <div class="notice error">@_error</div>
    }
    else if (!_supported)
    {
        <div class="notice">
            Recording is not enabled on this server — add a "recording" section to the config to capture events.
        </div>
    }
    else
    {
        <div class="ev-body">
            <div class="ev-list" role="list">
                @if (_loading)
                {
                    <div class="notice">Loading…</div>
                }
                else if (!Filtered.Any())
                {
                    <div class="notice">
                        @(_unreviewedOnly ? "Nothing awaiting review — all clear."
                            : _date != null ? "No events on this day."
                            : "No events in the last 24 hours.")
                    </div>
                }
                @foreach (var day in Filtered.GroupBy(e => e.Start.ToLocalTime().Date))
                {
                    <div class="ev-day">
                        <div class="ev-day-head">@DayLabel(day.Key) <span class="event-day-count">@day.Count()</span></div>
                        @foreach (var ev in day)
                        {
                            <div class="event-row @(ev.Reviewed ? "reviewed" : "") @(_selected?.Id == ev.Id ? "selected" : "") @(_selectMode && _selectedIds.Contains(ev.Id) ? "picked" : "")"
                                 @key="ev.Id" role="listitem"
                                 title="@(_selectMode ? "Click to select or deselect" : "Play this event")"
                                 @onclick="() => RowClickAsync(ev)">
                                @if (_selectMode)
                                {
                                    <input class="event-row-check" type="checkbox" checked="@_selectedIds.Contains(ev.Id)"
                                           @onclick:stopPropagation="true"
                                           @onchange="() => ToggleOne(ev.Id)" />
                                }
                                <div class="event-row-thumb">
                                    @if (ev.HasThumb)
                                    {
                                        <img src="@Artifact(ev, "thumb")" loading="lazy" alt="" />
                                    }
                                    else
                                    {
                                        <span class="event-thumb-icon">@ev.Icon</span>
                                    }
                                    <span class="event-row-dur">@DurationText(ev)</span>
                                    @if (ev.Ongoing)
                                    {
                                        <span class="event-live">● REC</span>
                                    }
                                </div>
                                <div class="event-row-main">
                                    <span class="event-title">@ev.Icon @ev.Title</span>
                                    <span class="event-sub">@ev.Camera · @ev.Start.ToLocalTime().ToString("HH:mm:ss") · @Ago(ev.Start)</span>
                                </div>
                                @if (!ev.Reviewed)
                                {
                                    <span class="event-new-dot" title="Unreviewed"></span>
                                }
                                <a class="icon-btn ev-row-live" href="@LiveHref(ev.Camera)"
                                   title="Watch @ev.Camera live" @onclick:stopPropagation="true">@UiIcon.Render("activity", 14)</a>
                            </div>
                        }
                    </div>
                }
            </div>

            <div class="ev-detail @(_selected == null ? "empty" : "")">
                @if (_selected is { } sel)
                {
                    <div class="event-player-head">
                        <button class="icon-btn ev-back" title="Back to the list" @onclick="CloseAsync">@UiIcon.Render("chev-left", 16)</button>
                        <div class="event-player-title">
                            <span class="event-title">@sel.Icon @sel.Title</span>
                            <span class="event-sub">@sel.Camera · @sel.Start.ToLocalTime().ToString("ddd d MMM HH:mm:ss") · @DurationText(sel)</span>
                        </div>
                        <a class="chip ev-golive" href="@LiveHref(sel.Camera)" title="Watch @sel.Camera live now">
                            @UiIcon.Render("activity", 13) Go live
                        </a>
                    </div>

                    @if (sel.HasClip)
                    {
                        @* zoom-on: the recorded clip gets the same digital zoom as live
                           views — wheel/pinch to zoom, drag to pan, HUD buttons at the side. *@
                        <div class="event-player-media zoom-on" @key="sel.Id">
                            <video id="ev-video" controls autoplay playsinline></video>
                            @ZoomHud
                        </div>
                        <div class="player-speed">
                            <span class="tool-label">SPEED</span>
                            @foreach (var s in Speeds)
                            {
                                <button class="chip @(_speed == s ? "chip-active" : "")" @onclick="() => SetSpeedAsync(s)">@FormatSpeed(s)</button>
                            }
                            @if (sel.HasPreview)
                            {
                                <span class="tool-label player-quality-label">QUALITY</span>
                                <button class="chip @(_sd ? "" : "chip-active")" title="Full-quality main-stream recording"
                                        @onclick="() => SetStreamAsync(sd: false)">HD</button>
                                <button class="chip @(_sd ? "chip-active" : "")"
                                        title="Low-res sub-stream recording — smoother fast-forward on slow storage"
                                        @onclick="() => SetStreamAsync(sd: true)">SD</button>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="notice">No clip was recorded for this event@(sel.Ongoing ? " yet — it is still being captured" : "").</div>
                    }

                    <div class="event-player-foot">
                        <button class="chip" disabled="@(Neighbor(1) == null)" @onclick="() => NavigateAsync(1)">← Older</button>
                        <button class="chip" disabled="@(Neighbor(-1) == null)" @onclick="() => NavigateAsync(-1)">Newer →</button>
                        <span class="tile-spacer"></span>
                        @if (sel.Reviewed)
                        {
                            <span class="event-sub">✓ reviewed</span>
                        }
                        else
                        {
                            <span class="event-sub">marking as reviewed…</span>
                        }
                    </div>
                }
                else
                {
                    <div class="ev-detail-empty">
                        <span class="ev-detail-empty-icon">@UiIcon.Render("clock", 30)</span>
                        <span>Select an event to play it</span>
                    </div>
                }
            </div>
        </div>
    }

    @if (_showDelete)
    {
        <div class="ev-del-backdrop" @onclick="CancelDelete">
            <div class="ev-del-dialog" @onclick:stopPropagation="true">
                <div class="ev-del-title">
                    <span>@UiIcon.Render("trash", 15) DELETE EVENTS</span>
                    <button class="icon-btn" title="Cancel" @onclick="CancelDelete" disabled="@_deleting">✕</button>
                </div>
                @if (_delBusy)
                {
                    <div class="ev-del-body">Working out what will be deleted…</div>
                }
                else if (_delError != null)
                {
                    <div class="ev-del-body ev-del-err">@_delError</div>
                }
                else
                {
                    <div class="ev-del-body">
                        <p class="ev-del-lead">
                            Permanently delete <b>@_delCount event@(_delCount == 1 ? "" : "s")</b>,
                            freeing about <b>@SizeText(_delBytes)</b> of disk?
                        </p>
                        <ul class="ev-del-facts">
                            @foreach (var c in _delCameras)
                            {
                                <li><span class="ev-del-cam">@c.Camera</span> <span class="ev-del-n">@c.Count</span></li>
                            }
                        </ul>
                        @if (_delEarliest != null && _delLatest != null)
                        {
                            <p class="event-sub">
                                @(_delEarliest.Value.Date == _delLatest.Value.Date
                                    ? _delEarliest.Value.ToString("ddd d MMM, HH:mm") + " – " + _delLatest.Value.ToString("HH:mm")
                                    : _delEarliest.Value.ToString("ddd d MMM HH:mm") + " – " + _delLatest.Value.ToString("ddd d MMM HH:mm"))
                            </p>
                        }
                        @if (_delSkipped > 0)
                        {
                            <p class="event-sub ev-del-skip">
                                @_delSkipped selected event@(_delSkipped == 1 ? " is" : "s are") still recording and will be kept.
                            </p>
                        }
                        <p class="ev-del-warn">This cannot be undone — the clips, thumbnails and previews are removed from disk.</p>
                    </div>
                }
                <div class="ev-del-actions">
                    <button class="chip" @onclick="CancelDelete" disabled="@_deleting">Cancel</button>
                    <button class="chip ev-del-confirm" disabled="@(_delBusy || _deleting || _delCount == 0 || _delError != null)"
                            @onclick="ConfirmDeleteAsync">
                        @if (_deleting)
                        {
                            <span>Deleting…</span>
                        }
                        else
                        {
                            <span>@UiIcon.Render("trash", 13) Delete @_delCount</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public string? Camera { get; set; }

    /// <summary>Deep link to one exact event: /events?event={id} auto-opens and plays it.</summary>
    [SupplyParameterFromQuery(Name = "event")] public string? EventId { get; set; }

    private string _server = "";
    private string _origin = "";
    private string? _token;

    private readonly List<ApiCamera> _cameras = new();
    private readonly List<ApiEvent> _events = new();     // rolling last 24h
    private List<ApiEvent> _eventsForDate = new();       // one selected day
    private ApiEvent? _selected;

    private string _cameraFilter = "";
    private bool _unreviewedOnly;
    private DateTime? _date;
    private bool _supported = true;
    private bool _loading = true;
    private string? _error;

    private double _speed = 1;
    private static readonly double[] Speeds = { 1, 2, 4, 8, 16 };

    // ---- multi-select delete ----
    private bool _selectMode;
    private readonly HashSet<string> _selectedIds = new();
    private bool _showDelete;
    private bool _delBusy;      // fetching the estimate
    private bool _deleting;     // the delete request is in flight
    private string? _delError;
    private int _delCount;
    private long _delBytes;
    private int _delSkipped;    // selected-but-ongoing, kept
    private DateTime? _delEarliest, _delLatest;
    private List<CameraCount> _delCameras = new();
    private sealed record CameraCount(string Camera, int Count);

    // ---- camera SD-card browser (beta) ----
    private bool _sdMode;
    private string _sdCamera = "";
    private DateTime _sdDate = DateTime.Today;
    private List<int> _sdDays = new();               // days with recordings in _sdDate's month
    private List<ApiSdRecording> _sdRecs = new();    // the selected day's recordings
    private ApiSdRecording? _sdSelected;
    private bool _sdLoading;
    private string? _sdError;

    /// <summary>The user's HD/SD pick: false = full main-stream clip (default at
    /// every speed — muted fast playback keeps it smooth), true = the low-res
    /// sub-stream twin, the escape hatch when storage or decoder can't keep up.
    /// Shared with the live view's popup player ("neolink.eventSd").</summary>
    private bool _sd;

    private string? _pendingVideoUrl; // set when a clip needs (re)attaching after render

    // Digital-zoom HUD, identical to the live view's: JS (neolink.zoomInit) owns
    // the clicks and the badge — Blazor only renders the shell once per surface.
    private RenderFragment ZoomHud => @<div class="zoom-hud" @onclick:stopPropagation="true" @ondblclick:stopPropagation="true">
        <button type="button" class="icon-btn zoom-btn" data-zoom="in" title="Zoom in (or mouse-wheel up on the video)">＋</button>
        <span class="zoom-badge" data-zoom-badge>100%</span>
        <button type="button" class="icon-btn zoom-btn" data-zoom="out" title="Zoom out (or mouse-wheel down)">−</button>
        <button type="button" class="icon-btn zoom-btn zoom-reset" data-zoom="reset" title="Restore 1:1 (or double-click the video)">1:1</button>
    </div>;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // The zoom engine is page-global and idempotent; a direct /events load
            // must arm it itself (the live view isn't necessarily visited first).
            try { await JS.InvokeVoidAsync("neolink.zoomInit"); } catch { }
            // Server + credentials come from the live view's persisted settings.
            try
            {
                var json = await JS.InvokeAsync<string?>("neolink.lsGet", "neolink.view");
                if (json != null)
                    _server = JsonSerializer.Deserialize<PersistedView>(json)?.Server ?? "";
                var auth = await JS.InvokeAsync<string?>("neolink.lsGet", "neolink.auth");
                if (!string.IsNullOrWhiteSpace(auth))
                {
                    var el = JsonSerializer.Deserialize<JsonElement>(auth);
                    if (el.TryGetProperty("token", out var t)) _token = t.GetString();
                }
            }
            catch { }
            try { _sd = await JS.InvokeAsync<string?>("neolink.lsGet", "neolink.eventSd") == "1"; } catch { }
            // Playback speed is a sticky preference (shared with the live view's
            // event popup): pick 2× once and every next event opens at 2×.
            try
            {
                if (double.TryParse(await JS.InvokeAsync<string?>("neolink.lsGet", "neolink.eventSpeed"),
                        System.Globalization.NumberStyles.Float,
                        System.Globalization.CultureInfo.InvariantCulture, out var sp)
                    && Speeds.Contains(sp))
                    _speed = sp;
            }
            catch { }
            try { _origin = await JS.InvokeAsync<string>("neolink.defaultServer"); } catch { }
            if (string.IsNullOrWhiteSpace(_server))
                _server = _origin;

            // Deep link: /events/{camera} pre-filters (HA notifications land here).
            if (!string.IsNullOrWhiteSpace(Camera))
                _cameraFilter = Camera;

            await LoadCamerasAsync();
            await RefreshAsync();

            // Deep link to one exact event (?event={id}): open and play it, even
            // when it is older than the rolling 24h window.
            if (!string.IsNullOrWhiteSpace(EventId))
                await OpenEventByIdAsync(EventId);

            // The push-notification flow: land straight on the newest event for
            // the deep-linked camera so the tap shows the clip immediately. A
            // quiet last-24h falls back to the camera's most recent stored event,
            // however old — a per-camera link must always land on footage.
            if (!string.IsNullOrWhiteSpace(Camera) && _selected == null)
            {
                var newest = Filtered.FirstOrDefault();
                if (newest != null)
                {
                    await SelectAsync(newest);
                }
                else
                {
                    var latest = await GetJsonAsync<List<ApiEvent>>(
                        $"/api/events?camera={Uri.EscapeDataString(Camera)}&limit=1");
                    if (latest is [{ } ev]) await OpenEventAsync(ev);
                }
            }

            StateHasChanged();
            return;
        }

        if (_pendingVideoUrl is { } url)
        {
            _pendingVideoUrl = null;
            await JS.InvokeVoidAsync("neolink.eventPlayer", "ev-video", url, _speed);
        }
    }

    // ------------------------------------------------------------ data plumbing

    private string Base => _server.TrimEnd('/');

    /// <summary>Server-side fetches resolve our own origin to loopback (reverse-proxy safe).</summary>
    private string ApiBase =>
        _origin.Length > 0 && string.Equals(Base, _origin.TrimEnd('/'), StringComparison.OrdinalIgnoreCase)
            ? Local.BaseUrl.TrimEnd('/')
            : Base;

    private string TokenQuery(char sep) =>
        string.IsNullOrEmpty(_token) ? "" : $"{sep}token={Uri.EscapeDataString(_token)}";

    private HttpRequestMessage Req(HttpMethod m, string path)
    {
        var r = new HttpRequestMessage(m, $"{ApiBase}{path}");
        if (!string.IsNullOrEmpty(_token))
            r.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", _token);
        return r;
    }

    /// <summary>The shared client's timeout is only a cap — each call brings its
    /// own budget. Server-state reads are fast (20s is generous); the SD-card
    /// FILE search is answered by the camera walking its card and legitimately
    /// runs long, so its caller passes a budget above the server's own 90s.</summary>
    private async Task<T?> GetJsonAsync<T>(string path, int timeoutSeconds = 20)
    {
        using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(timeoutSeconds));
        using var res = await Http.SendAsync(Req(HttpMethod.Get, path), cts.Token);
        if (res.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            _error = "Sign in on the live view first, then reopen Events.";
            return default;
        }
        if (!res.IsSuccessStatusCode) return default;
        return await res.Content.ReadFromJsonAsync<T>();
    }

    private async Task LoadCamerasAsync()
    {
        try
        {
            var cams = await GetJsonAsync<List<ApiCamera>>("/api/cameras");
            _cameras.Clear();
            if (cams != null) { _cameras.AddRange(cams); _error = null; }
        }
        catch (Exception ex) { _error = $"Cannot reach {_server}: {ex.Message}"; }
    }

    private async Task RefreshAsync()
    {
        _loading = _events.Count == 0 && _eventsForDate.Count == 0;
        try
        {
            var features = await GetJsonAsync<ApiFeaturesInfo>("/api/features");
            _supported = features?.Events == true;
            if (!_supported) { _loading = false; return; }

            var list = await GetJsonAsync<List<ApiEvent>>("/api/events?limit=500");
            if (list != null)
            {
                _events.Clear();
                _events.AddRange(list);
            }
            if (_date != null) await LoadDayAsync();

            // Keep the open player's metadata fresh (an ongoing clip finalizes).
            if (_selected != null)
                _selected = Source().FirstOrDefault(e => e.Id == _selected.Id) ?? _selected;
        }
        catch (Exception ex) { _error = $"Cannot reach {_server}: {ex.Message}"; }
        finally { _loading = false; }
    }

    private async Task LoadDayAsync()
    {
        if (_date is not { } day) return;
        var list = await GetJsonAsync<List<ApiEvent>>($"/api/events?limit=1000&date={day:yyyy-MM-dd}");
        _eventsForDate = list ?? new List<ApiEvent>();
    }

    private async Task SetDateAsync(string? raw)
    {
        if (string.IsNullOrWhiteSpace(raw) || !DateTime.TryParse(raw, out var day))
        {
            _date = null;
            _eventsForDate = new List<ApiEvent>();
            return;
        }
        _date = day.Date;
        _loading = true;
        await LoadDayAsync();
        _loading = false;
    }

    // ------------------------------------------------------------ camera SD card

    private Task RefreshCurrentAsync() => _sdMode ? LoadSdAsync() : RefreshAsync();

    private async Task SetSdModeAsync(bool on)
    {
        _sdMode = on;
        if (!on)
        {
            _sdSelected = null;
            return;
        }
        // A camera pick is required (the search is per-camera): the active filter
        // wins, else the first camera.
        if (_sdCamera.Length == 0 || _cameras.All(c => c.Name != _sdCamera))
            _sdCamera = (_cameraFilter.Length > 0 ? _cameraFilter : _cameras.FirstOrDefault()?.Name) ?? "";
        await LoadSdAsync();
    }

    /// <summary>One camera+day load: the month's recording calendar and the day's
    /// file list, both answered by the camera itself.</summary>
    private async Task LoadSdAsync()
    {
        _sdSelected = null;
        _sdRecs = new List<ApiSdRecording>();
        _sdDays = new List<int>();
        _sdError = null;
        if (_sdCamera.Length == 0)
        {
            _sdError = "No cameras are configured.";
            return;
        }
        _sdLoading = true;
        StateHasChanged();
        try
        {
            var cam = Uri.EscapeDataString(_sdCamera);
            var days = await GetJsonAsync<ApiSdDays>(
                $"/api/cameras/{cam}/sdcard/days?year={_sdDate.Year}&month={_sdDate.Month}",
                timeoutSeconds: 30);
            _sdDays = days?.Days ?? new List<int>();
            var recs = await GetJsonAsync<ApiSdRecordings>(
                $"/api/cameras/{cam}/sdcard/recordings?date={_sdDate:yyyy-MM-dd}",
                timeoutSeconds: 95);
            if (recs == null && days == null)
            {
                _sdError = "This camera's SD card can't be browsed — it needs a Reolink HTTP API " +
                           "(http_address / HTTP enabled on the camera) and a mounted SD card.";
            }
            else if (recs == null)
            {
                // The calendar answered but the FILE search didn't — that is a
                // failed query (the file search is much heavier and the camera
                // may be busy), NOT an empty day. Saying "no recordings" here
                // hid real failures behind an innocent-looking message.
                _sdError = "The camera answered the calendar but not the file search — it may be " +
                           "busy streaming. Hit refresh to retry; the server log has details.";
            }
            _sdRecs = recs?.Recordings ?? new List<ApiSdRecording>();
        }
        catch (OperationCanceledException)
        {
            _sdError = "The camera is taking too long to answer the SD-card search — it is likely " +
                       "busy recording or streaming. Hit refresh to retry.";
        }
        catch (Exception ex)
        {
            _sdError = $"Cannot reach {_server}: {ex.Message}";
        }
        finally
        {
            _sdLoading = false;
        }
    }

    private async Task SetSdDateAsync(string? raw)
    {
        if (string.IsNullOrWhiteSpace(raw) || !DateTime.TryParse(raw, out var day)) return;
        _sdDate = day.Date;
        await LoadSdAsync();
    }

    private async Task SetSdDayAsync(int day)
    {
        _sdDate = new DateTime(_sdDate.Year, _sdDate.Month, Math.Min(day, DateTime.DaysInMonth(_sdDate.Year, _sdDate.Month)));
        await LoadSdAsync();
    }

    private void SelectSdAsync(ApiSdRecording r)
    {
        _sdSelected = r;
        _pendingVideoUrl = SdUrl(r); // attach after the <video> renders
    }

    private string SdUrl(ApiSdRecording r, bool dl = false) =>
        $"{Base}/api/cameras/{Uri.EscapeDataString(_sdCamera)}/sdcard/download" +
        $"?file={Uri.EscapeDataString(r.File)}{(dl ? "&dl=1" : "")}{TokenQuery('&')}";

    private void OnFilterChanged()
    {
        // Keep the URL honest so a refresh / share preserves the camera view.
        var target = string.IsNullOrEmpty(_cameraFilter) ? "events" : $"events/{Uri.EscapeDataString(_cameraFilter)}";
        Nav.NavigateTo(target, replace: true);
    }

    // ------------------------------------------------------------ selection & playback

    private IEnumerable<ApiEvent> Source() =>
        _date == null ? _events.Where(e => e.Start >= DateTime.UtcNow.AddHours(-24)) : _eventsForDate;

    private IEnumerable<ApiEvent> Filtered =>
        Source()
            .Where(e => _cameraFilter.Length == 0 || string.Equals(e.Camera, _cameraFilter, StringComparison.OrdinalIgnoreCase))
            .Where(e => !_unreviewedOnly || !e.Reviewed)
            .OrderByDescending(e => e.Start);

    private string Artifact(ApiEvent ev, string kind) =>
        $"{Base}/api/events/{Uri.EscapeDataString(ev.Id)}/{kind}{TokenQuery('?')}";

    private string PlayerUrl(ApiEvent ev) =>
        _sd && ev.HasPreview ? Artifact(ev, "preview") : Artifact(ev, "clip");

    /// <summary>Resolve a ?event={id} deep link: find the event (the rolling list, or a
    /// direct lookup for older ones), bring its day into the list, and play it.</summary>
    private async Task OpenEventByIdAsync(string id)
    {
        var ev = Source().FirstOrDefault(e => e.Id == id)
                 ?? await GetJsonAsync<ApiEvent>($"/api/events/{Uri.EscapeDataString(id)}");
        if (ev == null)
        {
            _error = "That event no longer exists — it may have been cleaned up.";
            return;
        }
        await OpenEventAsync(ev);
    }

    /// <summary>Open a deep-linked event wherever it lives: fix up a hiding filter,
    /// pivot the list to its day when it's outside the 24h window, and play it.</summary>
    private async Task OpenEventAsync(ApiEvent ev)
    {
        // A camera filter that would hide the linked event loses to the link.
        if (_cameraFilter.Length > 0 && !string.Equals(_cameraFilter, ev.Camera, StringComparison.OrdinalIgnoreCase))
            _cameraFilter = ev.Camera;

        // Older than the 24h window: pivot the list to the event's day so the
        // context (and the Older/Newer buttons) line up with what's playing.
        if (!Source().Any(e => e.Id == ev.Id))
        {
            _date = ev.Start.ToLocalTime().Date;
            await LoadDayAsync();
        }
        await SelectAsync(ev);
    }

    private async Task SelectAsync(ApiEvent ev)
    {
        // _speed deliberately survives: the user's last pick applies to every event.
        _selected = ev;
        if (ev.HasClip) _pendingVideoUrl = PlayerUrl(ev); // attach after the <video> renders
        // Viewing an event is reviewing it: mark it the moment it's opened, not on close.
        if (!ev.Reviewed) await MarkReviewedAsync(ev);
    }

    // ------------------------------------------------------------ multi-select delete

    /// <summary>A row click plays the event normally, or toggles its selection
    /// while selection mode is on.</summary>
    private async Task RowClickAsync(ApiEvent ev)
    {
        if (_selectMode) ToggleOne(ev.Id);
        else await SelectAsync(ev);
    }

    private async Task ToggleSelectModeAsync()
    {
        _selectMode = !_selectMode;
        _selectedIds.Clear();
        // Leaving the list-and-detail split for selection: close any open player.
        if (_selectMode && _selected != null) await CloseAsync();
    }

    private void ToggleOne(string id)
    {
        if (!_selectedIds.Remove(id)) _selectedIds.Add(id);
    }

    private bool AllShownSelected
    {
        get
        {
            var shown = Filtered.ToList();
            return shown.Count > 0 && shown.All(e => _selectedIds.Contains(e.Id));
        }
    }

    private void ToggleSelectAll(bool select)
    {
        if (select) foreach (var e in Filtered) _selectedIds.Add(e.Id);
        else ClearSelection();
    }

    private void ClearSelection() => _selectedIds.Clear();

    /// <summary>Opens the confirmation and asks the server for the exact summary
    /// (count, size, per-camera, span) — computed server-side so it matches what
    /// deletion will actually remove.</summary>
    private async Task OpenDeleteAsync()
    {
        if (_selectedIds.Count == 0) return;
        _showDelete = true;
        _delBusy = true;
        _delError = null;
        StateHasChanged();
        try
        {
            var est = await PostDeleteAsync(estimate: true);
            if (est is { ValueKind: JsonValueKind.Object } o)
            {
                _delCount = o.GetProperty("count").GetInt32();
                _delBytes = o.GetProperty("bytes").GetInt64();
                _delSkipped = o.TryGetProperty("ongoing", out var og) ? og.GetInt32() : 0;
                _delEarliest = o.TryGetProperty("earliest", out var ea) && ea.ValueKind != JsonValueKind.Null
                    ? ea.GetDateTime().ToLocalTime() : null;
                _delLatest = o.TryGetProperty("latest", out var la) && la.ValueKind != JsonValueKind.Null
                    ? la.GetDateTime().ToLocalTime() : null;
                _delCameras = o.TryGetProperty("cameras", out var cams) && cams.ValueKind == JsonValueKind.Array
                    ? cams.EnumerateArray()
                        .Select(c => new CameraCount(c.GetProperty("camera").GetString() ?? "?", c.GetProperty("count").GetInt32()))
                        .ToList()
                    : new List<CameraCount>();
                if (_delCount == 0)
                    _delError = _delSkipped > 0
                        ? "Every selected event is still recording — nothing can be deleted yet."
                        : "Those events no longer exist.";
            }
            else
            {
                _delError = "Could not prepare the deletion — are you signed in as an admin?";
            }
        }
        catch
        {
            _delError = "Could not reach the server to prepare the deletion.";
        }
        finally
        {
            _delBusy = false;
            StateHasChanged();
        }
    }

    private void CancelDelete()
    {
        if (_deleting) return;
        _showDelete = false;
    }

    private async Task ConfirmDeleteAsync()
    {
        if (_delBusy || _deleting || _delCount == 0) return;
        _deleting = true;
        StateHasChanged();
        try
        {
            var res = await PostDeleteAsync(estimate: false);
            int deleted = res is { ValueKind: JsonValueKind.Object } o
                && o.TryGetProperty("deleted", out var d) ? d.GetInt32() : 0;
            // Drop the deleted events from the local lists so the UI updates without
            // a full round-trip; a refresh reconciles anything unexpected.
            var gone = _selectedIds.ToHashSet();
            _events.RemoveAll(e => gone.Contains(e.Id));
            _eventsForDate.RemoveAll(e => gone.Contains(e.Id));
            if (_selected != null && gone.Contains(_selected.Id)) _selected = null;
            _selectedIds.Clear();
            _showDelete = false;
            _deleting = false;
            _selectMode = false;
            await RefreshAsync();
        }
        catch
        {
            _deleting = false;
            _delError = "The deletion failed — nothing may have been removed. Try again.";
        }
        StateHasChanged();
    }

    private async Task<JsonElement?> PostDeleteAsync(bool estimate)
    {
        var req = Req(HttpMethod.Post, "/api/events/delete");
        req.Content = JsonContent.Create(new { ids = _selectedIds.ToList(), estimate });
        using var res = await Http.SendAsync(req);
        if (!res.IsSuccessStatusCode) return null;
        return await res.Content.ReadFromJsonAsync<JsonElement>();
    }

    private static string SizeText(long bytes) => bytes switch
    {
        >= 1024L * 1024 * 1024 => $"{bytes / (1024.0 * 1024 * 1024):0.0} GB",
        >= 1024L * 1024 => $"{bytes / (1024.0 * 1024):0} MB",
        _ => $"{bytes / 1024.0:0} KB",
    };

    private async Task SetSpeedAsync(double s)
    {
        _speed = s;
        try
        {
            await JS.InvokeVoidAsync("neolink.lsSet", "neolink.eventSpeed",
                s.ToString(System.Globalization.CultureInfo.InvariantCulture));
        }
        catch { }
        if (_selected is { HasClip: true } ev)
            await JS.InvokeVoidAsync("neolink.eventPlayer", "ev-video", PlayerUrl(ev), s);
    }

    private async Task SetStreamAsync(bool sd)
    {
        _sd = sd;
        try { await JS.InvokeVoidAsync("neolink.lsSet", "neolink.eventSd", sd ? "1" : "0"); } catch { }
        if (_selected is { HasClip: true } ev)
            await JS.InvokeVoidAsync("neolink.eventPlayer", "ev-video", PlayerUrl(ev), _speed);
    }

    /// <summary>Closing just clears the selection; the event was already marked
    /// reviewed when it was opened. The guard is a fallback if that POST failed.</summary>
    private async Task CloseAsync()
    {
        var ev = _selected;
        _selected = null;
        if (ev is { Reviewed: false }) await MarkReviewedAsync(ev);
    }

    private ApiEvent? Neighbor(int direction)
    {
        if (_selected == null) return null;
        var list = Filtered.ToList();
        int i = list.FindIndex(e => e.Id == _selected.Id);
        int target = i + direction;
        return i < 0 || target < 0 || target >= list.Count ? null : list[target];
    }

    private async Task NavigateAsync(int direction)
    {
        var watched = _selected;
        var next = Neighbor(direction);
        if (next == null) return;
        await SelectAsync(next);
        if (watched is { Reviewed: false }) await MarkReviewedAsync(watched);
    }

    private async Task MarkReviewedAsync(ApiEvent ev)
    {
        try
        {
            var req = Req(HttpMethod.Post, $"/api/events/{Uri.EscapeDataString(ev.Id)}/review");
            req.Content = JsonContent.Create(new { reviewed = true });
            using var res = await Http.SendAsync(req);
            if (!res.IsSuccessStatusCode) return;
        }
        catch { return; }
        Mark(_events, ev.Id);
        Mark(_eventsForDate, ev.Id);
        if (_selected?.Id == ev.Id) _selected = _selected with { Reviewed = true };
    }

    private static void Mark(List<ApiEvent> list, string id)
    {
        int i = list.FindIndex(e => e.Id == id);
        if (i >= 0) list[i] = list[i] with { Reviewed = true };
    }

    // ------------------------------------------------------------ helpers

    /// <summary>Live target: the camera's maximized view, or the wall.</summary>
    private string LiveHref(string? camera = null) =>
        string.IsNullOrEmpty(camera) ? "" : $"cameras/{Uri.EscapeDataString(camera)}";

    private static string FormatSpeed(double s) => s == 1 ? "1×" : $"{s:0}×";

    private static string DayLabel(DateTime day) =>
        day == DateTime.Now.Date ? "TODAY"
        : day == DateTime.Now.Date.AddDays(-1) ? "YESTERDAY"
        : day.ToString("dddd, d MMMM").ToUpperInvariant();

    private static string DurationText(ApiEvent ev) =>
        ev.Ongoing ? "recording…"
        : ev.Duration.TotalSeconds < 1 ? "<1s"
        : ev.Duration.TotalSeconds < 90 ? $"{(int)Math.Ceiling(ev.Duration.TotalSeconds)}s"
        : $"{(int)Math.Round(ev.Duration.TotalMinutes)} min";

    private static string Ago(DateTime utc)
    {
        var span = DateTime.UtcNow - utc.ToUniversalTime();
        if (span < TimeSpan.Zero) span = TimeSpan.Zero;
        return span.TotalSeconds < 60 ? "just now"
            : span.TotalMinutes < 60 ? $"{(int)span.TotalMinutes}m ago"
            : span.TotalHours < 24 ? $"{(int)span.TotalHours}h ago"
            : $"{(int)span.TotalDays}d ago";
    }

    public ValueTask DisposeAsync() => ValueTask.CompletedTask;
}
