    // ---- validation: live, field-by-field, mirroring the server's rules ----

    private string? CamNameError => _camEdit is not { } e ? null
        : string.IsNullOrWhiteSpace(e.Name) ? "A name is required."
        : e.Name.Trim().Length > 64 ? "Keep the name under 64 characters."
        : e.Name.IndexOfAny("/\\:*?\"<>|".ToCharArray()) >= 0 ? "The name must not contain / \\ : * ? \" < > |"
        : _adminCams?.Any(c => !string.Equals(c.Name, e.OriginalName, StringComparison.OrdinalIgnoreCase)
                            && string.Equals(c.Name, e.Name.Trim(), StringComparison.OrdinalIgnoreCase)) == true
            ? "A camera with this name already exists."
            : null;

    private string? CamAddressError =>
        _camEdit is { Type: "reolink" } e ? HostPortClientError(e.Address) : null;

    private static string? HostPortClientError(string address)
    {
        address = address.Trim();
        if (address.Length == 0) return "An address is required — the camera's IP or hostname.";
        if (address.Contains("://")) return "Enter a bare host or host:port, not a URL.";
        if (address.Any(char.IsWhiteSpace)) return "The address must not contain spaces.";
        int colon = address.LastIndexOf(':');
        if (colon > address.LastIndexOf(']')
            && (!int.TryParse(address[(colon + 1)..], out var p) || p is < 1 or > 65535))
            return "The port must be 1-65535.";
        return null;
    }

    private string? CamUsernameError =>
        _camEdit is { Type: "reolink" } e && string.IsNullOrWhiteSpace(e.Username)
            ? "A username is required (usually admin)." : null;

    private string? CamRtspError
    {
        get
        {
            if (_camEdit is not { Type: "rtsp" } e) return null;
            if (string.IsNullOrWhiteSpace(e.RtspMain) && string.IsNullOrWhiteSpace(e.RtspSub))
                return "Provide at least one rtsp:// URL.";
            foreach (var url in new[] { e.RtspMain, e.RtspSub })
            {
                if (!string.IsNullOrWhiteSpace(url) && !url.Contains("****")
                    && (!url.StartsWith("rtsp://", StringComparison.OrdinalIgnoreCase)
                        || !Uri.TryCreate(url.Trim(), UriKind.Absolute, out _)))
                    return "RTSP URLs must be valid and start with rtsp://";
            }
            return null;
        }
    }

    private string? CamFormError => CamNameError ?? CamAddressError ?? CamUsernameError ?? CamRtspError;

    private object CamRequestBody(CamEdit e, bool forSave) => new
    {
        originalName = forSave ? e.OriginalName : null,
        name = forSave ? e.Name.Trim() : e.OriginalName, // the test uses the stored entry for fallbacks
        type = e.Type,
        address = e.Type == "reolink" ? e.Address.Trim() : null,
        username = e.Type == "reolink" ? e.Username.Trim() : null,
        // Write-only: blank means "keep the stored password" (or none on a new camera).
        password = e.Type == "reolink" && e.Password.Length > 0 ? e.Password : null,
        channelId = e.Type == "reolink" ? e.ChannelId : (int?)null,
        httpAddress = forSave && e.Type == "reolink" ? e.HttpAddress.Trim() : null,
        rtspMain = e.Type == "rtsp" ? e.RtspMain.Trim() : null,
        rtspSub = e.Type == "rtsp" ? e.RtspSub.Trim() : null,
    };

    private async Task TestCameraAsync()
    {
        if (_camEdit is not { } e || _camTestBusy || CamFormError != null) return;
        _camTestBusy = true;
        _camTestResult = null;
        try
        {
            var req = ApiRequest(HttpMethod.Post, "/api/admin/cameras/test");
            req.Content = JsonContent.Create(CamRequestBody(e, forSave: false));
            using var res = await Http.SendAsync(req);
            var el = await res.Content.ReadFromJsonAsync<JsonElement>();
            _camTestOk = el.TryGetProperty("ok", out var ok) && ok.ValueKind == JsonValueKind.True;
            _camTestResult = el.TryGetProperty("message", out var msg) ? msg.GetString()
                : el.TryGetProperty("error", out var err) ? err.GetString()
                : $"no reply ({(int)res.StatusCode})";
        }
        catch (Exception ex)
        {
            _camTestOk = false;
            _camTestResult = ex.Message;
        }
        finally
        {
            _camTestBusy = false;
        }
    }

