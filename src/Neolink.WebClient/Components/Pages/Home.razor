    private string? _camDeleteConfirm;
    private bool _camTestBusy, _camSaveBusy, _camsNeedRestart;
    private string? _camTestResult;
    private bool _camTestOk;

    /// <summary>The add/edit form buffer. Password is write-only: blank keeps the
    /// stored one (or none); the server never sends passwords to the browser.</summary>
    private sealed class CamEdit
    {
