@page "/"
@page "/cameras/{Camera}"
@page "/cameras/{Camera}/{Stream}"
@using System.Text.Json
@inject HttpClient Http
@inject IJSRuntime JS
@inject LocalApiInfo Local
@inject NavigationManager Nav
@implements IAsyncDisposable

<div class="shell">

    @if (_sidebarOpen)
    {
        <div class="backdrop" @onclick="() => _sidebarOpen = false"></div>
    }

    <aside class="sidebar @(_sidebarOpen ? "open" : "")">
        <div class="brand">
            @* The logo doubles as "home": it restores the full wall, exactly like
               the toolbar's Restore view button (no-op when nothing is maximized). *@
            <span class="brand-home" role="button" title="Back to the full camera wall"
                  @onclick="RestoreView">
                <span class="brand-dot"></span> NEOLINK<span class="brand-net">.NET</span>
            </span>
            <button class="icon-btn" title="Server settings" @onclick="OpenServerSettingsAsync">@UiIcon.Render("gear", 18)</button>
        </div>

        @if (_setupRequired && !_secWarnDismissed)
        {
            <div class="sec-banner">
                <span class="sec-banner-text">⚠ This server has no sign-in — anyone who can reach it can watch and control your cameras.</span>
                <div class="sec-banner-actions">
                    <button class="chip" @onclick="() => { _loginError = null; _showSetupPrompt = true; }">Secure now</button>
                    <button class="icon-btn" title="Dismiss this warning" @onclick="DismissSecWarnAsync">✕</button>
                </div>
            </div>
        }

        @if (UpdateAvailable)
        {
            <div class="update-banner">
                <span class="update-banner-text">🎉 Neolink.NET @_latestVersion is available (you have @_version).</span>
                <div class="sec-banner-actions">
                    <a class="chip" href="@_repoUrl" target="_blank" rel="noopener">View release</a>
                    <button class="icon-btn" title="Dismiss" @onclick="DismissUpdateAsync">✕</button>
                </div>
            </div>
        }

        @if (_storage is { Full: true })
        {
            @* Not dismissible: recording is actually stopped until space is freed. *@
            <div class="storage-banner storage-banner-full">
                <span class="sec-banner-text">⛔ @_storage.Label storage is FULL — recording has stopped. Free up space or extend retention/archive settings.</span>
                <div class="sec-banner-actions">
                    <a class="chip" href="monitor">Monitor</a>
                </div>
            </div>
        }
        else if (_storage is { } sw && !_storageWarnDismissed)
        {
            <div class="storage-banner">
                <span class="sec-banner-text">⚠ @sw.Label storage is @sw.UsedPercent.ToString("0")% full — recording stops when it runs out.</span>
                <div class="sec-banner-actions">
                    <a class="chip" href="monitor">Monitor</a>
                    <button class="icon-btn" title="Dismiss for this session" @onclick="DismissStorageWarnAsync">✕</button>
                </div>
            </div>
        }


        <div class="section-title">
            CAMERAS
            <button class="icon-btn" title="Refresh" @onclick="RefreshCamerasAsync">@UiIcon.Render("refresh", 13)</button>
        </div>

        @if (_error != null)
        {
            <div class="notice error">@_error</div>
        }
        else if (_cameras.Count == 0)
        {
            <div class="notice">
                <b>No cameras yet.</b> Add them to <code>config.json</code> (the Docker
                <code>/config</code> mount), then restart the server.
                <a href="https://github.com/borexola/neolink.net#configuration" target="_blank" rel="noopener">Setup guide →</a>
            </div>
        }

        @foreach (var cam in _cameras)
        {
            @* The card is a drag source: drop it on any tile to show this camera there. *@
            <div class="cam @(cam.Online || cam.Asleep ? "" : "cam-offline") @(IsRouteCamera(cam.Name) ? "cam-active" : "")" draggable="true"
                 @ondragstart="() => _dragCamera = cam.Name"
                 @ondragend="ClearDragState">
                @* Stream readiness latches once video has flowed, so only the live
                   control connection (Online) is a truthful liveness signal. *@
                <div class="cam-head" title="@CamHeadTitle(cam)"
                     @onclick="() => OpenCameraMain(cam)">
                    <span class="dot @(cam.Online ? "on" : cam.Asleep ? "doze" : "off")"></span>
                    <span class="cam-name">@cam.Name</span>
                    @if (cam.Battery is { } bat)
                    {
                        @* Battery-powered camera: level + charging hint. *@
                        <span class="cam-battery @(bat.Percent <= 20 && !bat.Charging ? "battery-low" : "")"
                              title="Battery-powered camera: @(bat.Percent)%@(bat.Charging ? ", charging" : "")">
                            @UiIcon.Render(bat.Charging ? "bolt" : "battery", 11)@bat.Percent%
                        </span>
                    }
                    @if (cam.Suspended)
                    {
                        <span class="cam-doze-badge" title="Suspended in Neolink.NET — not viewed or recorded here until resumed (the camera itself keeps running). Resume from its settings (⚙).">
                            @UiIcon.Render("eye-off", 10) suspended
                        </span>
                    }
                    else if (cam.Privacy)
                    {
                        <span class="cam-privacy-badge" title="Privacy mode — the camera is dark on purpose (turn it off here or in the Reolink app)">
                            🔒 private
                        </span>
                    }
                    else if (cam.Asleep && !cam.Online)
                    {
                        <span class="cam-doze-badge" title="Battery camera sleeping — open its stream to reconnect">
                            @UiIcon.Render("moon", 10) asleep
                        </span>
                    }
                    else if (!cam.Online)
                    {
                        <span class="cam-offline-badge">offline</span>
                    }
                    else if (cam.Recording)
                    {
                        <span class="cam-rec-badge" title="Recording 24/7 to disk">● REC</span>
                    }
                    <button class="icon-btn solo-btn" title="Camera settings & controls"
                            @onclick="() => { _panelCamera = cam.Name; _sidebarOpen = false; }" @onclick:stopPropagation="true">@UiIcon.Render("gear", 16)</button>
                </div>
                <div class="cam-streams">
                    @* A stream chip is a LINK: it navigates to /cameras/{name}/{stream},
                       which shows that camera maximized on that exact stream. *@
                    @foreach (var s in cam.Streams)
                    {
                        <button class="chip @(s.Ready ? "" : "chip-off") @(IsRouteStream(cam.Name, s.Kind) ? "chip-active" : "")"
                                title="Open @cam.Name (@s.Label) full size — @s.Path @(s.Codec != null ? $"({s.Codec} {s.Width}x{s.Height})" : "")"
                                @onclick="() => { _sidebarOpen = false; Nav.NavigateTo(StreamUrl(cam.Name, s.Kind)); }">
                            @s.Label
                            @if (s.Codec == "H265")
                            {
                                <span class="badge">H265</span>
                            }
                        </button>
                    }
                </div>
            </div>
        }

        <div class="sidebar-foot">
            @if (_authUser != null)
            {
                <div class="sidebar-user">
                    <span class="sidebar-user-id" title="Signed in as @_authUser">
                        <span class="sidebar-user-icon">@UiIcon.Render(_authAdmin ? "shield" : "user", 14)</span>
                        <span class="sidebar-user-name">@_authUser</span>
                        <span class="sidebar-user-role">@(_authAdmin ? "admin" : "user")</span>
                    </span>
                    <button class="chip chip-off sidebar-signout" title="Sign out" @onclick="LogoutAsync">Sign out</button>
                </div>
            }
            else
            {
                <span>Neolink.NET web client</span>
            }
        </div>
    </aside>

    <main class="stage">
        @* Frigate-style review strip: unreviewed detection events, newest first.
           Disappears entirely once everything is dismissed (or recording is off) —
           and also when the filters hide everything, EXCEPT while the filter
           editor is open: collapsing mid-edit would strand the user with no way
           to undo the click that hid the last visible event. *@
        @if (_eventsSupported && (StripEvents.Any() || _showStripFilter))
        {
            <div class="events-bar" id="events-bar" style="height:@(_stripHeight)px">
                <div class="events-rail">
                    <span class="events-rail-label">Detected</span>
                    <span class="events-rail-count" title="Unreviewed events (after filters)">@StripEvents.Count()</span>
                    <div class="events-rail-actions">
                        <button class="rail-btn @(_showStripFilter ? "open" : "")"
                                title="Filter which events appear here" @onclick="() => _showStripFilter = !_showStripFilter">
                            <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor"
                                 stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <polygon points="22 3 2 3 10 12.5 10 19 14 21 14 12.5 22 3"/>
                            </svg>
                            @if (HasStripFilters)
                            {
                                <span class="rail-btn-dot" title="Filters active"></span>
                            }
                        </button>
                        <button class="rail-btn" title="Dismiss all events (mark everything reviewed)" @onclick="DismissAllAsync">
                            <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor"
                                 stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <path d="M18 6 7 17l-5-5"/><path d="m22 10-7.5 7.5L13 16"/>
                            </svg>
                        </button>
                    </div>
                </div>
                @* Wrapper anchors the edge scroll arrows; JS (stripNavInit) toggles
                   can-left/can-right on it from the real scroll state. *@
                <div class="events-scroll-wrap" id="events-scroll-wrap">
                <div class="events-bar-scroll">
                    @if (!StripEvents.Any())
                    {
                        <span class="event-sub">no unreviewed events match these filters — the strip hides itself when you close the filter editor</span>
                    }
                    @{ int trickleBudget = 8; }
                    @foreach (var ev in StripEvents.Take(30))
                    {
                        @* Ambient "trickle" preview: the newest few cards loop their clip
                           muted, so the strip shows what happened without any clicks.
                           Capped so a big backlog doesn't decode dozens of videos. *@
                        bool trickle = (ev.HasPreview || ev.HasClip) && !ev.Ongoing && trickleBudget-- > 0;
                        <div class="event-card @(ev.Ongoing ? "live" : "")" @key="ev.Id" style="@CardAspect(ev)"
                             title="@ev.Title — click to play" @onclick="() => OpenEvent(ev)">
                            <div class="event-thumb">
                                @if (trickle)
                                {
                                    @* Previews prefer the low-res sub-stream twin; the full
                                       main-stream clip only plays in the click-through player. *@
                                    <video data-trickle="1" muted loop playsinline preload="metadata"
                                           poster="@(ev.HasThumb ? EventArtifactUrl(ev, "thumb") : null)"
                                           src="@EventArtifactUrl(ev, ev.HasPreview ? "preview" : "clip")"></video>
                                }
                                else if (ev.HasThumb)
                                {
                                    <img src="@EventArtifactUrl(ev, "thumb")" loading="lazy" alt="" />
                                }
                                else
                                {
                                    <span class="event-thumb-icon">@ev.Icon</span>
                                }
                                @if (ev.Ongoing)
                                {
                                    <span class="event-live">● REC</span>
                                }
                                <button class="icon-btn event-dismiss" title="Dismiss (mark reviewed)"
                                        @onclick="() => DismissAsync(ev)" @onclick:stopPropagation="true">✕</button>
                            </div>
                            <div class="event-meta">
                                <span class="event-title">@ev.Icon @ev.Title</span>
                                <span class="event-sub">@ev.Camera · @Ago(ev.Start)</span>
                            </div>
                        </div>
                    }
                </div>
                <button type="button" class="strip-nav strip-nav-left" title="Scroll back">
                    <svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor"
                         stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <polyline points="15 18 9 12 15 6"/>
                    </svg>
                </button>
                <button type="button" class="strip-nav strip-nav-right" title="Scroll for more">
                    <svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor"
                         stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <polyline points="9 18 15 12 9 6"/>
                    </svg>
                </button>
                </div>
                <div class="strip-resize" title="Drag to resize the event strip"></div>
            </div>

            @if (_showStripFilter)
            {
                @* Real-time strip filters: lit chips show, dimmed chips hide.
                   Persisted with the view settings (per account when signed in). *@
                <div class="strip-filter">
                    <span class="tool-label">SHOW</span>
                    @foreach (var t in StripTypes)
                    {
                        <button class="chip @(_hiddenTypes.Contains(t) ? "chip-off" : "chip-active")"
                                title="@(_hiddenTypes.Contains(t) ? "Hidden — click to show" : "Shown — click to hide")"
                                @onclick="() => ToggleTypeFilterAsync(t)">@StripTypeIcon(t) @t</button>
                    }
                    <span class="tool-sep"></span>
                    <span class="tool-label">CAMERAS</span>
                    @foreach (var cam in _cameras)
                    {
                        var name = cam.Name;
                        <button class="chip @(_hiddenCams.Contains(name) ? "chip-off" : "chip-active")"
                                title="@(_hiddenCams.Contains(name) ? "Hidden — click to show" : "Shown — click to hide")"
                                @onclick="() => ToggleCamFilterAsync(name)">@name</button>
                    }
                    @if (HasStripFilters)
                    {
                        <span class="tile-spacer"></span>
                        <button class="chip" title="Show every event type and camera again"
                                @onclick="ResetStripFiltersAsync">↺ Reset filters</button>
                    }
                </div>
            }
        }

        <div class="toolbar">
            <button class="tool-btn menu-btn" title="Cameras" @onclick="() => _sidebarOpen = !_sidebarOpen">@UiIcon.Render("menu", 16)</button>

            @* Restore view leads the toolbar while a maximize is active: it's the
               one action the user is most likely after, so it must not hide behind
               a horizontal scroll on a phone. *@
            @if (_backup != null || _maxIndex != null)
            {
                <button class="tool-btn back" @onclick="RestoreView">@UiIcon.Render("collapse", 14) Restore view</button>
                <span class="tool-sep"></span>
            }

            @* Saved layouts sits next (right after the menu) so it stays reachable
               on a narrow phone toolbar without scrolling. Always says "Layout"; the
               loaded layout's name rides along as a value. *@
            <button class="tool-btn layouts-btn @(_showLayouts ? "active" : "")"
                    title="@(_activeLayout != null ? $"Saved layouts (current: {_activeLayout})" : "Saved layouts — save and reload camera arrangements")"
                    @onclick="() => _showLayouts = !_showLayouts">
                @UiIcon.Render("layout", 14) <span class="tool-name">Layout@(_activeLayout != null ? ":" : "s")</span>
                @if (_activeLayout != null)
                {
                    <span class="layout-cur">@_activeLayout</span>
                }
                <span class="tool-caret">@(_showLayouts ? "▴" : "▾")</span>
                @if (LayoutDirty)
                {
                    <span class="layout-dirty-dot" title="This layout has unsaved changes"></span>
                }
            </button>
            <span class="tool-sep"></span>

            <span class="tool-label">VIEW</span>
            @* One dropdown instead of five buttons: compact on desktop, and on
               phones it opens the platform's native picker. *@
            <select class="tool-select" title="How the camera wall is laid out"
                    value="@_mode" @onchange="e => SetMode((string)e.Value!)">
                @foreach (var (mode, name) in Modes)
                {
                    <option value="@mode">@name</option>
                }
            </select>

            @if (_mode != "theater")
            {
                <span class="tool-sep"></span>
                <span class="tool-label">TILES</span>
                <button class="tool-btn" @onclick="() => SetCount(_count - 1)">−</button>
                <span class="tool-count">@_count</span>
                <button class="tool-btn" @onclick="() => SetCount(_count + 1)">+</button>
            }


            @if (_eventsSupported)
            {
                <span class="tool-sep"></span>
                <a class="tool-btn" href="events" title="Recent detection events">@UiIcon.Render("clock", 14) <span class="tool-name">Events</span></a>
                @if (_continuousSupported)
                {
                    <a class="tool-btn" href="timeline" title="Scrub recorded footage across all cameras">@UiIcon.Render("film", 14) <span class="tool-name">Timeline</span></a>
                }
            }

            <span class="tool-sep"></span>
            <a class="tool-btn" href="monitor" title="Server & browser resource usage, live">@UiIcon.Render("activity", 14) <span class="tool-name">Monitor</span></a>

            @if (!string.IsNullOrEmpty(_version))
            {
                <span class="toolbar-version" title="Neolink.NET server version">v@(_version)</span>
            }
        </div>

        @if (_showLayouts)
        {
            @* Saved layouts drawer: click a name to load it exactly as saved;
               "Update" writes the current arrangement into the loaded layout,
               the name box saves it as a new one. *@
            <div class="layouts-bar">
                <span class="tool-label">SAVED LAYOUTS</span>
                @if (_layouts.Count == 0)
                {
                    <span class="event-sub">nothing saved yet — arrange your cameras, type a name and save</span>
                }
                @foreach (var l in _layouts)
                {
                    var layout = l;
                    bool active = string.Equals(layout.Name, _activeLayout, StringComparison.OrdinalIgnoreCase);
                    <span class="layout-chip @(active ? "layout-chip-active" : "")">
                        <button class="layout-chip-load" title="Load “@(layout.Name)” (@(layout.Mode), @(layout.Count) tiles)"
                                @onclick="() => LoadLayoutAsync(layout)">@(layout.Name)</button>
                        <button class="icon-btn layout-chip-del" title="Delete “@(layout.Name)”"
                                @onclick="() => DeleteLayoutAsync(layout)">✕</button>
                    </span>
                }
                <span class="tile-spacer"></span>
                @if (LayoutDirty)
                {
                    <button class="chip chip-active" title="Save the current arrangement into “@_activeLayout”"
                            @onclick="UpdateActiveLayoutAsync">Update “@_activeLayout”</button>
                }
                <input class="layout-name-input" placeholder="new layout name…" maxlength="40"
                       @bind="_layoutName" @bind:event="oninput"
                       @onkeydown='e => { if (e.Key == "Enter") _ = SaveLayoutAsAsync(); }' />
                <button class="chip" disabled="@(string.IsNullOrWhiteSpace(_layoutName))"
                        @onclick="SaveLayoutAsAsync">＋ Save as new</button>
            </div>
        }

        @if (_missingCamera != null)
        {
            <div class="perf-toast" role="status">
                <span>Camera “<b>@_missingCamera</b>” doesn't exist on this server — showing the camera wall instead.</span>
                <button class="chip" @onclick="() => _missingCamera = null">Got it</button>
            </div>
        }

        @if (_talkError != null)
        {
            <div class="perf-toast" role="status">
                <span><b>Two-way talk:</b> @_talkError</span>
                <button class="chip" @onclick="() => _talkError = null">Got it</button>
            </div>
        }

        @if (_showMainWarn)
        {
            <div class="perf-toast" role="status">
                <span>⚡ More than 4 <b>main</b> streams on screen — decoding several
                    high-res feeds can strain this device. Sub streams keep the wall
                    smooth; a maximized tile switches itself to main quality.</span>
                <button class="chip" @onclick="() => _showMainWarn = false">Got it</button>
            </div>
        }

        <div id="stage-grid" class="grid mode-@_mode @(_maxIndex != null ? "has-max" : "")" style="@ContainerStyle()">
            @for (int i = 0; i < _slots.Count; i++)
            {
                var index = i;
                var slot = _slots[index];
                var camera = slot.Camera == null ? null : _cameras.FirstOrDefault(c => c.Name == slot.Camera);

                @* Maximizing hides the other tiles (CSS display) instead of unmounting
                   them, so their players keep running and restore is instant.
                   zoom-on marks the surfaces where digital zoom is available
                   (theater layout / maximized tile; JS checks fullscreen itself). *@
                @* Tiles are drag-and-drop surfaces: drag one onto another to swap
                   them, drop a sidebar camera to load it, right-click to pick a
                   camera. Free mode keeps its own JS drag/resize; a maximized tile
                   is not draggable (dragging a full-screen card means nothing). *@
                <div class="tile @(index == 0 && (_mode is "focus" or "mosaic") ? "hero" : "") @(_mode == "theater" || _maxIndex == index ? "zoom-on" : "") @(_maxIndex == index ? "maxed" : "") @(_dropIndex == index ? "drop-target" : "")"
                     id="tile-@index" data-slot="@index" data-cols="@slot.Cols" data-rows="@slot.Rows"
                     style="@TileStyle(index)" @key="index"
                     draggable="@(TileDraggable(index) ? "true" : "false")"
                     @ondragstart="() => _dragTile = index"
                     @ondragend="ClearDragState"
                     @ondragenter="() => _dropIndex = index"
                     @ondragover:preventDefault="true"
                     @ondrop="() => DropOnTileAsync(index)" @ondrop:preventDefault="true"
                     @oncontextmenu="e => OpenTileMenu(index, e)" @oncontextmenu:preventDefault="true"
                     @ondblclick="() => ToggleMaximize(index)"
                     @onclick="e => OnTileClick(index, e)">
                    @if (_mode == "free")
                    {
                        <div class="tile-head">
                            <span class="tile-head-name">@(slot.Camera ?? "empty")</span>
                            <span class="tile-head-hint">drag</span>
                        </div>
                    }
                    @if (slot.Camera == null)
                    {
                        <div class="tile-empty" title="Click to choose a camera — or drag one from the sidebar">＋</div>
                    }
                    else
                    {
                        @* no autoplay: the JS player starts playback once its jitter buffer is filled *@
                        <video id="vid-@index" muted playsinline></video>
                        <div class="tile-status">connecting…</div>
                        @* Privacy is its own OPAQUE overlay: the player neither shows a
                           frozen last frame under it nor overwrites it (it rewrites
                           .tile-status with its own connecting/reconnect text). *@
                        @if (camera is { Suspended: true })
                        {
                            <div class="tile-privacy">
                                <span class="tile-privacy-icon">@UiIcon.Render("eye-off", 22)</span>
                                <span>suspended</span>
                                <small>not viewed or recorded in Neolink.NET</small>
                            </div>
                        }
                        else if (camera is { Privacy: true })
                        {
                            <div class="tile-privacy">
                                <span class="tile-privacy-icon">🔒</span>
                                <span>privacy mode</span>
                                <small>the camera is dark on purpose</small>
                            </div>
                        }
                        @* Phones: the camera name floats translucent over the feed's top-right
                           corner instead of sitting in the crowded bottom bar (CSS gates it). *@
                        <span class="tile-name-float">@slot.Camera</span>
                        <div class="tile-bar" @onclick:stopPropagation="true" @ondblclick:stopPropagation="true">
                            <span class="tile-name">@slot.Camera</span>
                            @if (camera is { Recording: true })
                            {
                                @* Phones show only the blinking dot (CSS hides .rec-text). *@
                                <span class="cam-rec-badge" title="Recording 24/7 to disk"><span class="rec-dot">●</span><span class="rec-text"> REC</span></span>
                            }
                            @if (camera != null && camera.Streams.Count > 1)
                            {
                                <select value="@slot.Path" @onchange="e => ChangeStream(index, camera, (string?)e.Value)">
                                    @foreach (var s in camera.Streams)
                                    {
                                        <option value="@s.Path">@s.Label</option>
                                    }
                                </select>
                            }
                            <span class="tile-spacer"></span>
                            @* JS-owned (neolink.audioInit): shown only when the stream has audio *@
                            <button type="button" class="icon-btn" data-audio-toggle style="display:none"></button>
                            @if (camera?.OnDemand != null)
                            {
                                @* On every tile, not just the maximized one — recording on
                                   demand shouldn't require blowing the camera up first. *@
                                <button class="icon-btn clip-btn @(ClipActive(camera.Name) ? "clip-live" : "")"
                                        title="@(ClipActive(camera.Name) ? "Stop clip recording" : $"Record a clip (stops by itself after {ClipMaxLabel(camera)})")"
                                        @onclick="() => ToggleClipAsync(camera)">@UiIcon.Render("rec", 14)</button>
                            }
                            @if (_maxIndex == index && TalkSupported(slot.Camera))
                            {
                                <button class="icon-btn talk-btn @TalkClass(slot.Camera!)" title="@TalkTitle(slot.Camera!)"
                                        @onclick="() => ToggleTalkAsync(slot.Camera!)">@UiIcon.Render("mic", 14)</button>
                            }
                            <button class="icon-btn" title="@(_maxIndex == index || (_backup != null && _mode == "theater") ? "Restore view" : "Maximize")"
                                    @onclick="() => ToggleMaximize(index)">@UiIcon.Render(_maxIndex == index || (_backup != null && _mode == "theater") ? "collapse" : "expand", 14)</button>
                            @* both states rendered; CSS shows the right one for the fullscreen state *@
                            <button class="icon-btn fs-toggle" title="Browser fullscreen (click again to exit)"
                                    @onclick="() => FullscreenAsync(index)"><span class="fs-enter">@UiIcon.Render("fs-enter", 14)</span><span class="fs-exit">@UiIcon.Render("fs-exit", 14)</span></button>
                            <button class="icon-btn" title="Remove" @onclick="() => CloseSlot(index)">✕</button>
                        </div>
                        @ZoomHud
                        @if (camera != null && ClipActive(camera.Name))
                        {
                            @* Always-on indicator while an on-demand clip records (any trigger:
                               UI button or HA switch). Counts down to the automatic stop; on the
                               maximized tile it doubles as the stop button (CSS gates clicks). *@
                            <div class="clip-overlay" role="button"
                                 title="Recording a clip — stops by itself; click to stop now"
                                 @onclick="() => ToggleClipAsync(camera!)"
                                 @onclick:stopPropagation="true" @ondblclick:stopPropagation="true">
                                <span class="clip-overlay-dot"></span>
                                <span class="clip-overlay-label"><span class="clip-overlay-word">REC </span>@ClipCountdown(camera.Name)</span>
                            </div>
                        }
                        @if (_maxIndex == index && TalkActive(slot.Camera!))
                        {
                            @* Big on-video indicator while the mic is live — also the stop button. *@
                            <div class="talk-overlay @(_talkPhase == "live" ? "live" : "connecting")"
                                 role="button" title="Click to stop talking"
                                 @onclick="() => ToggleTalkAsync(slot.Camera!)"
                                 @onclick:stopPropagation="true" @ondblclick:stopPropagation="true">
                                <span class="talk-overlay-mic">@UiIcon.Render("mic", 16)</span>
                                <span class="talk-overlay-label">@(_talkPhase == "live" ? "TALKING" : "CONNECTING…")</span>
                            </div>
                        }
                        @if (_mode == "grid" && _maxIndex != index)
                        {
                            @* Corner grip: drag to grow/shrink the tile in grid-cell steps
                               (JS previews live, .NET commits the span on release). *@
                            <div class="tile-size-handle" title="Drag to resize"></div>
                        }
                    }
                </div>
            }
        </div>
    </main>

    @if (_panelCamera != null)
    {
        <CameraPanel Server="@ApiBase" CameraName="@_panelCamera"
                     Camera="_cameras.FirstOrDefault(c => c.Name == _panelCamera)"
                     User="@_user" Pass="@_pass" Token="@_authToken"
                     CanEditRecording="@(!_authEnabled || _authAdmin)"
                     OnClose="() => _panelCamera = null" />
    }

    @if (_quickView is { Camera: not null } qv)
    {
        var qvCam = _cameras.FirstOrDefault(c => c.Name == qv.Camera);
        <div class="backdrop player-backdrop" @onclick="CloseQuickView"></div>
        <div class="quick-view" role="dialog" aria-label="Camera quick view">
            <div class="event-player-head">
                <div class="event-player-title">
                    <span class="event-title">@qv.Camera</span>
                    <span class="event-sub">quick view — your layout stays as it is</span>
                </div>
                @if (qvCam != null && qvCam.Streams.Count > 1)
                {
                    <select class="event-filter" value="@qv.Path" title="Stream"
                            @onchange="e => ChangeQuickStream(qvCam, (string?)e.Value)">
                        @foreach (var s in qvCam.Streams)
                        {
                            <option value="@s.Path">@s.Label</option>
                        }
                    </select>
                }
                @* JS-owned (neolink.audioInit): shown only when the stream has audio *@
                <button type="button" class="icon-btn" data-audio-toggle style="display:none"></button>
                @if (TalkSupported(qv.Camera))
                {
                    <button class="icon-btn talk-btn @TalkClass(qv.Camera!)" title="@TalkTitle(qv.Camera!)"
                            @onclick="() => ToggleTalkAsync(qv.Camera!)">@UiIcon.Render("mic", 14)</button>
                }
                <button class="icon-btn fs-toggle" title="Browser fullscreen (click again to exit)"
                        @onclick="QuickFullscreenAsync"><span class="fs-enter">@UiIcon.Render("fs-enter", 14)</span><span class="fs-exit">@UiIcon.Render("fs-exit", 14)</span></button>
                <button class="icon-btn" title="Close" @onclick="CloseQuickView">✕</button>
            </div>
            <div class="quick-view-media zoom-on" id="quick-view-media">
                <video id="vid-quick" muted playsinline></video>
                <div class="tile-status">connecting…</div>
                @if (_cameras.FirstOrDefault(c => c.Name == qv.Camera) is { Privacy: true })
                {
                    <div class="tile-privacy">
                        <span class="tile-privacy-icon">🔒</span>
                        <span>privacy mode</span>
                        <small>the camera is dark on purpose — switch it back in camera settings or the Reolink app</small>
                    </div>
                }
                @ZoomHud
                @if (TalkActive(qv.Camera!))
                {
                    <div class="talk-overlay @(_talkPhase == "live" ? "live" : "connecting")"
                         role="button" title="Click to stop talking"
                         @onclick="() => ToggleTalkAsync(qv.Camera!)" @onclick:stopPropagation="true">
                        <span class="talk-overlay-mic">@UiIcon.Render("mic", 16)</span>
                        <span class="talk-overlay-label">@(_talkPhase == "live" ? "TALKING" : "CONNECTING…")</span>
                    </div>
                }
            </div>
        </div>
    }

    @if (_ctxIndex is int ctxIdx)
    {
        @* Right-click camera picker for a tile. *@
        <div class="ctx-backdrop" @onclick="CloseTileMenu" @oncontextmenu="CloseTileMenu" @oncontextmenu:preventDefault="true"></div>
        <div class="ctx-menu" style="left:@(_ctxX)px; top:@(_ctxY)px" role="menu">
            <div class="ctx-title">Show camera</div>
            @foreach (var cam in _cameras)
            {
                var c = cam;
                bool current = _slots[ctxIdx].Camera == c.Name;
                <button class="ctx-item @(current ? "ctx-item-active" : "")" role="menuitem"
                        @onclick="() => PickTileCameraAsync(ctxIdx, c)">
                    <span class="dot @(c.Online ? "on" : "off")"></span> @c.Name
                    @if (current)
                    {
                        <span class="ctx-check">✓</span>
                    }
                </button>
            }
            @if (_slots[ctxIdx].Camera != null)
            {
                <div class="ctx-sep"></div>
                <button class="ctx-item ctx-danger" role="menuitem"
                        @onclick="() => { CloseSlot(ctxIdx); CloseTileMenu(); }">✕ Clear tile</button>
            }
        </div>
    }

    @if (_showSetupPrompt && !_showLogin)
    {
        <div class="backdrop panel-backdrop"></div>
        <aside class="campanel auth-panel" role="dialog" aria-label="Create admin account">
            <div class="campanel-head"><span class="campanel-title">🔐 SECURE THIS SERVER</span></div>
            <div class="notice">
                No accounts exist yet, so the UI is open to anyone who can reach this address.
                Create the admin account to require sign-in — you can add more users afterwards.
                Your layout and filters will be saved per account.
            </div>
            <div class="settings">
                <label>Admin username</label>
                <input @bind="_loginUser" autocomplete="off" />
                <label>Password (min 8 characters)</label>
                <input type="password" @bind="_loginPass" autocomplete="new-password" />
            </div>
            @if (_loginError != null)
            {
                <div class="notice error">@_loginError</div>
            }
            <div class="event-player-foot">
                <button class="chip" @onclick="SetupAdminAsync">Create admin &amp; enable login</button>
                <span class="tile-spacer"></span>
                <button class="chip chip-off" @onclick="DismissSetupAsync">Not now</button>
            </div>
        </aside>
    }

    @if (_showLogin)
    {
        <div class="auth-overlay">
            <div class="auth-box">
                <div class="brand"><span class="brand-dot"></span> NEOLINK<span class="brand-net">.NET</span></div>
                @if (!_resetMode)
                {
                    <label>Username</label>
                    <input @bind="_loginUser" autocomplete="username" />
                    <label>Password</label>
                    <input type="password" @bind="_loginPass" autocomplete="current-password"
                           @onkeydown='e => { if (e.Key == "Enter") _ = LoginAsync(); }' />
                    @if (_loginError != null)
                    {
                        <div class="notice error">@_loginError</div>
                    }
                    <button class="chip auth-btn" @onclick="LoginAsync">Sign in</button>
                    @if (_resetAvailable)
                    {
                        <button class="chip chip-off" @onclick="() => { _resetMode = true; _loginError = null; }">Reset admin password…</button>
                    }
                }
                else
                {
                    <div class="notice">
                        reset_admin_password is enabled in config.json. Set a new admin password below,
                        sign in with it, then turn the flag back off.
                    </div>
                    <label>New admin password</label>
                    <input type="password" @bind="_resetPass" autocomplete="new-password" />
                    @if (_loginError != null)
                    {
                        <div class="notice error">@_loginError</div>
                    }
                    <button class="chip auth-btn" @onclick="ResetAdminAsync">Set new password</button>
                    <button class="chip chip-off" @onclick="() => { _resetMode = false; _loginError = null; }">Back to sign in</button>
                }
            </div>
        </div>
    }

    @if (_showServerSettings)
    {
        @* No @onclick on the dim wall (and Esc is ignored — escInit only targets
           .quick-view): staged edits must not be lost to a stray click, so only
           the header ✕ closes this panel. *@
        <div class="backdrop panel-backdrop"></div>
        @* Head and foot are pinned; only the sections scroll. The unsaved state
           lives in BOTH: a badge in the header and the save bar in the footer,
           so it can never scroll out of sight. *@
        <aside class="campanel auth-panel settings-panel settings-wide" role="dialog" aria-label="Server settings">
            <div class="campanel-head">
                <span class="campanel-title">🛠 SERVER SETTINGS</span>
                @if (_adminConfig != null && AdminPendingCount is var pend and > 0)
                {
                    <span class="unsaved-badge"
                          title="Nothing is written until you click Save to config.json below. Closing this panel discards the changes.">
                        ● @pend unsaved
                    </span>
                }
                <span class="tile-spacer"></span>
                <button class="icon-btn" title="Close" @onclick="() => _showServerSettings = false">✕</button>
            </div>

                <div class="settings-tabs" role="tablist">
                    @if (_authAdmin)
                    {
                        <button class="settings-tab @(_settingsTab == "general" ? "active" : "")" role="tab"
                                @onclick='() => _settingsTab = "general"'>@UiIcon.Render("gear", 13) General</button>
                        <button class="settings-tab @(_settingsTab == "cameras" ? "active" : "")" role="tab"
                                @onclick="OpenCamerasTabAsync">@UiIcon.Render("film", 13) Cameras</button>
                        <button class="settings-tab @(_settingsTab == "users" ? "active" : "")" role="tab"
                                @onclick="SelectUsersTabAsync">@UiIcon.Render("user", 13) Users</button>
                    }
                    <button class="settings-tab @(_settingsTab == "connection" ? "active" : "")" role="tab"
                            @onclick='() => _settingsTab = "connection"'>@UiIcon.Render("activity", 13) Connection</button>
                    @if (_adminHasRecording)
                    {
                        <button class="settings-tab @(_settingsTab == "recording" ? "active" : "")" role="tab"
                                @onclick='() => _settingsTab = "recording"'>@UiIcon.Render("rec", 13) Recording</button>
                    }
                    @if (_adminHasMqtt)
                    {
                        <button class="settings-tab @(_settingsTab == "mqtt" ? "active" : "")" role="tab"
                                @onclick='() => _settingsTab = "mqtt"'>@UiIcon.Render("activity", 13) Home Assistant</button>
                    }
                    @if (_notif != null)
                    {
                        <button class="settings-tab @(_settingsTab == "notifications" ? "active" : "")" role="tab"
                                @onclick='() => _settingsTab = "notifications"'>
                            @UiIcon.Render("bell", 13) Notifications
                            @if (NotifDirty)
                            {
                                <span class="tab-dot" title="Unsaved changes">●</span>
                            }
                        </button>
                    }
                </div>
                <div class="settings-body">
                    @if (_settingsTab == "connection")
                    {
                        <div class="campanel-section">
                            <div class="campanel-section-title">@UiIcon.Render("activity", 13) SERVER CONNECTION</div>
                            <div class="notice small">
                                These settings belong to <b>this browser</b> — they are stored locally
                                (per device, per profile) and never written to the server's config.json.
                            </div>
                            <div class="control-row"><span>Server API URL</span>
                                <input class="notif-input" placeholder="blank = this server"
                                       @bind="_server" @bind:after="OnServerChangedAsync" /></div>
                            <div class="notice small">
                                Where this page sends its API calls and pulls video from.
                                <b>Leave it blank in normal setups</b> — the UI automatically talks to
                                the server that served it. Set it only when this UI runs somewhere else
                                than the Neolink.NET server (a dev build, a separately hosted copy) or you
                                want this browser to control a <i>different</i> Neolink.NET instance, e.g.
                                <code>http://192.168.1.10:8655</code>.
                            </div>
                            <div class="campanel-divider"></div>
                            <div class="campanel-subtitle">CONTROL CREDENTIALS (LEGACY)</div>
                            <div class="control-row"><span>Username</span>
                                <input class="notif-input" placeholder="username" autocomplete="off"
                                       @bind="_user" @bind:after="SaveAsync" /></div>
                            <div class="control-row"><span>Password</span>
                                <input class="notif-input" type="password" placeholder="password" autocomplete="off"
                                       @bind="_pass" @bind:after="SaveAsync" /></div>
                            <div class="notice small">
                                Only for servers <b>without web sign-in</b> that define an RTSP
                                <code>"users"</code> list in config.json: control actions (PTZ, camera
                                settings, reboot) then need these credentials — the same
                                username/password as the RTSP streams, sent as HTTP Basic. Once you are
                                <b>signed in to the web UI, your session covers control actions and
                                these fields are ignored</b> — leave them blank. The password is stored
                                in this browser's local storage, so don't fill it on a shared machine.
                            </div>
                            @if (_setupRequired)
                            {
                                <div class="campanel-divider"></div>
                                <div class="control-row">
                                    <span>Web sign-in is currently disabled</span>
                                    <button class="chip" title="Create the admin account and require sign-in"
                                            @onclick="() => { _loginError = null; _showSetupPrompt = true; _showServerSettings = false; }">Enable login…</button>
                                </div>
                            }
                        </div>
                    }

                    @if (_settingsTab == "users")
                    {
                        <div class="campanel-section">
                            <div class="campanel-section-title">@UiIcon.Render("user", 13) USERS</div>
                            <div class="notice small">
                                Web-UI accounts (users.json) — separate from the RTSP
                                <code>"users"</code> list in config.json. Changes apply immediately.
                            </div>
                            @if (_usersError != null)
                            {
                                <div class="notice error">@_usersError</div>
                            }
                            @foreach (var u in _uiUsers)
                            {
                                <div class="control-row user-row" @key="u.Name">
                                    <span>@UiIcon.Render(u.Admin ? "shield" : "user", 12) @u.Name@(u.Admin ? " · admin" : "")</span>
                                    <span class="row-actions">
                                        @if (_pwEditUser == u.Name)
                                        {
                                            <input class="user-pass-input" type="password" placeholder="new password (min 8)"
                                                   @bind="_pwEditPass" autocomplete="new-password" />
                                            <button class="chip" @onclick="() => SetUserPasswordAsync(u.Name)">save</button>
                                            <button class="chip chip-off" @onclick="() => _pwEditUser = null">cancel</button>
                                        }
                                        else
                                        {
                                            <button class="chip" @onclick="() => { _pwEditUser = u.Name; _pwEditPass = string.Empty; }">password…</button>
                                            @if (!u.Admin)
                                            {
                                                <button class="chip chip-danger" @onclick="() => DeleteUserAsync(u.Name)">delete</button>
                                            }
                                        }
                                    </span>
                                </div>
                            }
                            <div class="campanel-divider"></div>
                            <div class="campanel-subtitle">ADD USER</div>
                            <div class="user-add-row">
                                <input class="user-pass-input" placeholder="username" @bind="_newUserName" autocomplete="off" />
                                <input class="user-pass-input" type="password" placeholder="password (min 8)"
                                       @bind="_newUserPass" autocomplete="new-password" />
                                <button class="chip" @onclick="AddUserAsync">add</button>
                            </div>
                            <div class="notice small">
                                New accounts are normal users: they can view and control cameras and review events,
                                but cannot manage users or server settings. Each account keeps its own layout and filters.
                            </div>
                        </div>
                    }

                    @if (_settingsTab is not ("connection" or "users") && _adminConfig == null)
                    {
                        @if (_adminError != null)
                        {
                            <div class="notice error">@_adminError</div>
                        }
                        else
                        {
                            <div class="notice">Loading…</div>
                        }
                    }

                    @if (_adminConfig != null && _settingsTab is not ("notifications" or "connection" or "users"))
                    {
                        <div class="notice small">
                            Editing <code>@_adminConfigPath</code>.
                            @if (!_adminWritable)
                            {
                                <b> Read-only — the file cannot be written (check the mount).</b>
                            }
                            Changes are saved to the file and take effect after a restart. Comments in the file are not preserved.
                        </div>
                    }

                    @if (_settingsTab == "general" && _adminConfig != null)
                    {
                    <div class="campanel-section">
                        <div class="campanel-section-title">NETWORK</div>
                        @AdminField("Bind address", "bind", "text")
                        @AdminField("RTSP port", "bindPort", "number")
                        @AdminField("Web port", "webPort", "number")
                        @AdminField("Web bind (blank = same as bind)", "webBind", "text")
                        @AdminToggle("Serve the web UI", "webUi")
                    </div>

                    <div class="campanel-section">
                        <div class="campanel-section-title">WEB UI</div>
                        @AdminField("Preview playback speed (×)", "ui.trickleSpeed", "number")
                        @AdminField("State directory (accounts/settings)", "ui.stateDir", "text")
                        @AdminToggle("Allow admin-password reset on login", "ui.resetAdminPassword")
                        <div class="control-row">
                            <span>Two-way talk</span>
                            <button class="chip @(AdminBool("ui.talk") ? "" : "chip-off")"
                                    @onclick=@(() => _adminEdits["ui.talk"] = (!AdminBool("ui.talk")).ToString().ToLowerInvariant())>
                                @(AdminBool("ui.talk") ? "on" : "off")</button>
                        </div>
                        <div class="notice small">
                            Streams your microphone to the camera's speaker (doorbells and other
                            cameras that support talk). Browsers only allow microphone access on
                            <b>HTTPS</b> or <b>localhost</b> pages — on a plain http:// address the
                            mic button will report that a secure connection is required.
                        </div>
                    </div>
                    }

                    @if (_settingsTab == "cameras")
                    {
                        <div class="campanel-section">
                            <div class="campanel-section-title">@UiIcon.Render("film", 13) CAMERAS <span class="beta-tag">BETA</span></div>
                            @if (_adminCams == null)
                            {
                                <div class="notice small">Loading cameras…</div>
                            }
                            else if (_camEdit == null)
                            {
                                @foreach (var cam in _adminCams)
                                {
                                    <div class="control-row">
                                        <span><b>@cam.Name</b>&nbsp;<span class="event-sub">@(cam.Type == "rtsp" ? "generic RTSP" : $"Reolink · {cam.Address}")</span></span>
                                        <span class="row-actions">
                                            <button class="chip" disabled="@(!_adminCamsWritable)" @onclick="() => EditCamera(cam)">Edit</button>
                                            @if (_camDeleteConfirm == cam.Name)
                                            {
                                                <button class="chip chip-danger" @onclick="() => DeleteCameraAsync(cam.Name)">Confirm delete</button>
                                                <button class="chip" @onclick="() => _camDeleteConfirm = null">Cancel</button>
                                            }
                                            else
                                            {
                                                <button class="chip" disabled="@(!_adminCamsWritable)"
                                                        @onclick="() => _camDeleteConfirm = cam.Name">Delete…</button>
                                            }
                                        </span>
                                    </div>
                                }
                                @if (_adminCams.Count == 0)
                                {
                                    <div class="notice small">No cameras configured yet — add your first one below.</div>
                                }
                                <div class="settings-foot-btns">
                                    <span class="tile-spacer"></span>
                                    <button class="chip chip-active" disabled="@(!_adminCamsWritable)" @onclick="AddCamera">Add camera…</button>
                                </div>
                            }
                            else
                            {
                                var e = _camEdit;
                                <div class="campanel-subtitle">@(e.OriginalName == null ? "ADD CAMERA" : $"EDIT \"{e.OriginalName}\"")</div>
                                <div class="control-row"><span>Type</span>
                                    <select class="event-filter" value="@e.Type"
                                            @onchange='ev => { e.Type = (string?)ev.Value ?? "reolink"; _camTestResult = null; }'>
                                        <option value="reolink">Reolink (Baichuan)</option>
                                        <option value="rtsp">Generic RTSP</option>
                                    </select></div>
                                <div class="control-row"><span>Name</span>
                                    <input class="notif-input @(CamNameError != null ? "input-error" : "")" maxlength="64"
                                           placeholder="Driveway" @bind="e.Name" @bind:event="oninput" /></div>
                                @if (CamNameError != null) { <div class="field-error">@CamNameError</div> }
                                @if (e.Type == "reolink")
                                {
                                    <div class="control-row"><span>Address</span>
                                        <input class="notif-input @(CamAddressError != null ? "input-error" : "")"
                                               placeholder="192.168.1.50 (port 9000 assumed)" @bind="e.Address" @bind:event="oninput" /></div>
                                    @if (CamAddressError != null) { <div class="field-error">@CamAddressError</div> }
                                    <div class="control-row"><span>Username</span>
                                        <input class="notif-input @(CamUsernameError != null ? "input-error" : "")" autocomplete="off"
                                               placeholder="admin" @bind="e.Username" @bind:event="oninput" /></div>
                                    @if (CamUsernameError != null) { <div class="field-error">@CamUsernameError</div> }
                                    <div class="control-row"><span>Password</span>
                                        <input class="notif-input" type="password" autocomplete="new-password"
                                               placeholder="@(e.HasPassword ? "•••• stored — blank keeps it" : "camera password")"
                                               @bind="e.Password" /></div>
                                    <div class="control-row"><span>HTTP address (blank = derived)</span>
                                        <input class="notif-input" placeholder="usually blank" @bind="e.HttpAddress" /></div>
                                    <div class="control-row"><span>Channel (NVR only; 0 = standalone)</span>
                                        <input class="ret-input" type="number" min="0" max="255" @bind="e.ChannelId" /></div>
                                }
                                else
                                {
                                    <div class="control-row"><span>Main RTSP URL</span>
                                        <input class="notif-input @(CamRtspError != null ? "input-error" : "")"
                                               placeholder="rtsp://user:pass@host:554/path" @bind="e.RtspMain" @bind:event="oninput" /></div>
                                    <div class="control-row"><span>Sub RTSP URL (optional)</span>
                                        <input class="notif-input" placeholder="rtsp://…" @bind="e.RtspSub" @bind:event="oninput" /></div>
                                    @if (CamRtspError != null) { <div class="field-error">@CamRtspError</div> }
                                    <div class="notice small">
                                        Put credentials inside the URL (rtsp://user:pass@host/path). A stored
                                        password shows as <b>****</b> — leave the URL untouched to keep it.
                                    </div>
                                }
                                <div class="settings-foot-btns">
                                    <button class="chip" disabled="@(_camTestBusy || CamFormError != null)" @onclick="TestCameraAsync">
                                        @(_camTestBusy ? "Testing…" : "Test connection")</button>
                                    <span class="tile-spacer"></span>
                                    <button class="chip" @onclick="CancelCameraEdit">Cancel</button>
                                    <button class="chip chip-active" disabled="@(_camSaveBusy || CamFormError != null || !_adminCamsWritable)"
                                            @onclick="SaveCameraAsync">@(_camSaveBusy ? "Saving…" : "Save camera")</button>
                                </div>
                            }
                            @if (_camTestResult != null)
                            {
                                <div class="notice small @(_camTestOk ? "" : "error")">@_camTestResult</div>
                            }
                            @if (_camsNeedRestart)
                            {
                                <div class="notice warn small">
                                    Camera changes are saved to <code>config.json</code> — <b>restart the
                                    service</b> (button below) to apply them.
                                </div>
                            }
                        </div>
                    }

                    @if (_settingsTab == "recording" && _adminHasRecording)
                    {
                        <div class="campanel-section">
                            <div class="campanel-section-title">RECORDING</div>
                            @AdminField("Storage path", "recording.path", "text")
                            @AdminField("Event retention (days, 0 = forever)", "recording.retentionDays", "number")
                            @AdminField("Pre-roll (seconds)", "recording.preSeconds", "number")
                            @AdminField("Post-roll (seconds)", "recording.postSeconds", "number")
                            @AdminField("Max clip length (seconds)", "recording.maxClipSeconds", "number")
                            @AdminSelect("Record stream", "recording.stream", "auto", "mainStream", "subStream", "externStream")
                            @AdminField("Segment length (minutes)", "recording.segmentMinutes", "number")
                            @AdminField("Continuous retention (days, blank = event value)", "recording.continuousRetentionDays", "number")
                        </div>
                    }

                    @if (_settingsTab == "mqtt" && _adminHasMqtt)
                    {
                        <div class="campanel-section">
                            <div class="campanel-section-title">MQTT / HOME ASSISTANT</div>
                            @AdminField("Server health interval (seconds, 0 = off)", "mqtt.statsInterval", "number")
                            <div class="notice small">
                                How often the server publishes its own health — CPU, memory, disk,
                                recording rate, viewers — as a <b>Neolink.NET Server</b> device in
                                Home Assistant. 60 s suits dashboards; lower it for near-live gauges
                                (minimum 5). Broker details are edited in the file directly.
                            </div>
                        </div>
                    }

                    @if (_settingsTab == "notifications" && _notif != null)
                    {
                        <div class="campanel-section">
                            <div class="campanel-section-title">@UiIcon.Render("bell", 13) NOTIFICATIONS</div>
                            <div class="notice small">
                                Email alerts for critical events — saved here and applied immediately (no restart).
                                The SMTP password is <b>encrypted at rest</b>, but anyone with full access to the
                                server's files could still decrypt it (unavoidable for sending email), so prefer a
                                provider <b>app password</b> over your main account password.
                            </div>
                            <div class="control-row">
                                <span>Send email alerts</span>
                                <button class="chip @(_notif.Enabled ? "" : "chip-off")"
                                        @onclick="() => _notif.Enabled = !_notif.Enabled">@(_notif.Enabled ? "on" : "off")</button>
                            </div>
                            @if (_notif.Enabled)
                            {
                                <div class="control-row"><span>Send alerts to</span>
                                    <input class="notif-input @(NotifRecipientInvalid ? "input-error" : "")" type="email"
                                           placeholder="you@example.com" @bind="_notif.Recipient" @bind:event="oninput" /></div>
                                @if (NotifRecipientInvalid)
                                {
                                    <div class="field-error">Enter a valid email address for alerts (e.g. you@example.com).</div>
                                }

                                <div class="campanel-subtitle">SMTP SERVER</div>
                                <div class="control-row"><span>Host</span>
                                    <input class="notif-input" placeholder="smtp.gmail.com" @bind="_notif.SmtpHost" /></div>
                                <div class="control-row"><span>Port</span>
                                    <input class="ret-input" type="number" min="1" max="65535" @bind="_notif.SmtpPort" /></div>
                                <div class="control-row"><span>Security</span>
                                    <select class="event-filter" @bind="_notif.Security">
                                        <option value="starttls">STARTTLS (587)</option>
                                        <option value="ssl">SSL/TLS (465)</option>
                                        <option value="none">None</option>
                                    </select></div>
                                <div class="control-row"><span>Username</span>
                                    <input class="notif-input @(NotifUsernameInvalid ? "input-error" : "")" autocomplete="off"
                                           @bind="_notif.Username" @bind:event="oninput" /></div>
                                @if (NotifUsernameInvalid)
                                {
                                    <div class="field-error">This looks like an email address but isn't a valid one.</div>
                                }
                                <div class="control-row"><span>Password</span>
                                    <input class="notif-input" type="password" autocomplete="new-password"
                                           placeholder="@(_notif.HasPassword ? "•••• stored — blank keeps it" : "app password")"
                                           @bind="_notifPassword" /></div>
                                <div class="control-row"><span>From (blank = username)</span>
                                    <input class="notif-input @(NotifFromInvalid ? "input-error" : "")"
                                           @bind="_notif.From" @bind:event="oninput" /></div>
                                @if (NotifFromInvalid)
                                {
                                    <div class="field-error">Enter a valid email address, or leave blank to use the username.</div>
                                }
                                <div class="control-row"><span>From name</span>
                                    <input class="notif-input" @bind="_notif.FromName" /></div>

                                <div class="campanel-divider"></div>
                                <div class="campanel-subtitle">ALERTS</div>
                                @NotifToggle("Storage full / recovered", _notif.AlertStorage, v => _notif.AlertStorage = v)
                                @NotifToggle("Server overload", _notif.AlertOverload, v => _notif.AlertOverload = v)
                                @NotifToggle("Recording write failures", _notif.AlertWriteFailure, v => _notif.AlertWriteFailure = v)
                                @NotifToggle("Camera offline / back online", _notif.AlertCameraOffline, v => _notif.AlertCameraOffline = v)
                                @if (_notif.AlertCameraOffline)
                                {
                                    <div class="control-row"><span>Camera offline after (minutes)</span>
                                        <input class="ret-input" type="number" min="1" max="1440" @bind="_notif.OfflineThresholdMinutes" /></div>
                                    @if (_notif.Cameras.Count > 0)
                                    {
                                        <div class="notice small">Per-camera override — blank uses the default above, <b>0</b> never alerts for that camera:</div>
                                        <div class="cam-override-list">
                                            @foreach (var cam in _notif.Cameras)
                                            {
                                                <div class="control-row"><span>@cam</span>
                                                    <input class="ret-input" type="number" min="0" max="1440"
                                                           placeholder="@_notif.OfflineThresholdMinutes"
                                                           value="@(_notif.CameraOfflineOverrides.TryGetValue(cam, out var ov) ? ov.ToString() : "")"
                                                           @onchange="e => SetCameraOverride(cam, (string?)e.Value)" /></div>
                                            }
                                        </div>
                                    }
                                }

                            }
                        </div>
                    }

                    @if (_adminConfig != null && _settingsTab is not ("notifications" or "connection" or "users"))
                    {
                        <div class="notice small">
                            Restart stops the service; your container/systemd restart policy brings it back within seconds
                            (needed to apply saved changes). The UI reconnects automatically.
                        </div>
                    }
                </div>

                <div class="settings-foot">
                    @if (_settingsTab == "notifications" && _notif != null)
                    {
                        @* Notifications save to notifications.json — pinned here so the
                           buttons stay in view no matter how long the camera list gets. *@
                        @if (_notifStatus != null)
                        {
                            <div class="notice small @(_notifError ? "error" : "")">@_notifStatus</div>
                        }
                        @if (NotifDirty)
                        {
                            <div class="notice pending">Unsaved changes — click <b>@(_notif.Enabled ? "Save notifications" : "Save")</b> to apply them.</div>
                        }
                        <div class="settings-foot-btns">
                            @if (_notif.Enabled)
                            {
                                <button class="chip" disabled="@(_notifBusy || NotifHasErrors)" @onclick="SendTestNotificationAsync">
                                    @(_notifTesting ? "Sending…" : "Send test email")</button>
                            }
                            <span class="tile-spacer"></span>
                            <button class="chip @(NotifDirty ? "chip-active" : "")" disabled="@(_notifBusy || NotifHasErrors)" @onclick="SaveNotificationsAsync">
                                @(_notifSaving ? "Saving…" : (_notif.Enabled ? "Save notifications" : "Save"))</button>
                        </div>
                    }
                    else if (_settingsTab is "connection" or "users")
                    {
                        <div class="settings-foot-btns">
                            <span class="event-sub">
                                @(_settingsTab == "connection"
                                    ? "Saved instantly — these settings live in this browser only."
                                    : "User changes apply immediately; no restart needed.")
                            </span>
                            <span class="tile-spacer"></span>
                            @if (_authUser != null)
                            {
                                <button class="chip chip-off" @onclick="LogoutAsync">Sign out</button>
                            }
                        </div>
                    }
                    else if (_adminConfig != null)
                    {
                        @if (_adminError != null)
                        {
                            <div class="notice error">@_adminError</div>
                        }
                        @if (_adminStatus != null)
                        {
                            <div class="notice">@_adminStatus</div>
                        }
                        @if (AdminPendingCount is var pending and > 0)
                        {
                            <div class="notice pending">
                                @pending unsaved change@(pending == 1 ? "" : "s") — nothing is written until
                                you click <b>Save to config.json</b>. Closing this panel discards them.
                            </div>
                        }
                        <div class="settings-foot-btns">
                            @if (_settingsTab != "cameras")
                            {
                                @* Cameras save themselves (their own Save button above);
                                   this button only writes the field edits. *@
                                <button class="chip @(AdminPendingCount > 0 ? "chip-active" : "")" disabled="@(!_adminWritable)"
                                        @onclick="SaveServerSettingsAsync">Save to config.json</button>
                            }
                            <span class="tile-spacer"></span>
                            @if (!_confirmRestart)
                            {
                                <button class="chip chip-danger" title="Stop the service so the restart policy brings it back — needed to apply saved changes"
                                        @onclick="() => _confirmRestart = true">Restart service…</button>
                            }
                            else
                            {
                                <button class="chip chip-danger" @onclick="RestartServiceAsync">Confirm restart</button>
                                <button class="chip" @onclick="() => _confirmRestart = false">Cancel</button>
                            }
                        </div>
                    }
                </div>
        </aside>
    }

    @if (_playEvent != null)
    {
        @* No @onclick: closing marks the event reviewed, so a stray click on the
           dim wall (or Esc — see escInit) must never dismiss it. Only ✕ closes. *@
        <div class="backdrop player-backdrop"></div>
        <div class="event-player" role="dialog" aria-label="Event playback">
            <div class="event-player-head">
                <div class="event-player-title">
                    <span class="event-title">@_playEvent.Icon @_playEvent.Title</span>
                    <span class="event-sub">
                        @_playEvent.Camera · @_playEvent.Start.ToLocalTime().ToString("ddd d MMM HH:mm:ss") · @DurationText(_playEvent)
                    </span>
                </div>
                <button class="icon-btn" title="Close" @onclick="ClosePlayerAsync">✕</button>
            </div>
            @if (_playEvent.HasClip)
            {
                @* @key forces a fresh <video> when navigating between events.
                   JS owns the source (preserving position across an HD↔SD swap)
                   and mutes the audio pipeline above 1× — the timeline's recipe,
                   which is what lets full-res clips fast-forward smoothly. *@
                @* zoom-on: the recorded clip gets the same digital zoom as live
                   tiles (wheel at the cursor, drag to pan, HUD, dbl-click 1:1).
                   Keyed per event so zoom resets when navigating between events
                   but survives the HD↔SD swap. *@
                <div class="event-player-media zoom-on" @key="_playEvent.Id">
                    <video id="event-player-video" controls autoplay playsinline></video>
                    @ZoomHud
                </div>
                <div class="player-speed">
                    <span class="tool-label">SPEED</span>
                    @foreach (var s in PlaybackSpeeds)
                    {
                        <button class="chip @(_playSpeed == s ? "chip-active" : "")"
                                @onclick="() => SetPlaySpeedAsync(s)">@FormatSpeed(s)</button>
                    }
                    @if (_playEvent.HasPreview)
                    {
                        <span class="tool-label player-quality-label">QUALITY</span>
                        <button class="chip @(_playSd ? "" : "chip-active")" title="Full-quality main-stream recording"
                                @onclick="() => SetPlayStreamAsync(sd: false)">HD</button>
                        <button class="chip @(_playSd ? "chip-active" : "")"
                                title="Low-res sub-stream recording — smoother fast-forward on slow storage"
                                @onclick="() => SetPlayStreamAsync(sd: true)">SD</button>
                    }
                </div>
            }
            else
            {
                <div class="notice">No clip was recorded for this event@(_playEvent.Ongoing ? " yet — it is still being captured" : "").</div>
            }
            <div class="event-player-foot">
                <button class="chip" disabled="@(NeighborEvent(1) == null)"
                        @onclick="() => NavigatePlayerAsync(1)">← Older</button>
                <button class="chip" disabled="@(NeighborEvent(-1) == null)"
                        @onclick="() => NavigatePlayerAsync(-1)">Newer →</button>
                <span class="tile-spacer"></span>
                @if (_playEvent.Reviewed)
                {
                    <span class="event-sub">✓ reviewed</span>
                }
                else
                {
                    <span class="event-sub">will be marked reviewed on close</span>
                }
                <button class="chip chip-active" title="Close this event" @onclick="ClosePlayerAsync">Close</button>
            </div>
        </div>
    }

</div>

@code {
    private static readonly (string Mode, string Name)[] Modes =
    {
        ("grid", "Grid"),
        ("focus", "Focus"),
        ("mosaic", "Mosaic"),
        ("theater", "Theater"),
        ("free", "Free"),
    };

    private const string StorageKey = "neolink.view";

    private readonly List<ApiCamera> _cameras = new();
    private List<ViewSlot> _slots = new();
    private string _mode = "grid";
    private int _count = 4;
    private ViewSnapshot? _backup; // legacy theater-detour maximize (old persisted states)

    // In-place maximize: the tile at _maxIndex fills the stage while the OTHER
    // tiles stay mounted (CSS-hidden) so their players keep running — restoring
    // never reconnects the background feeds. _maxPrev* remembers the stream the
    // card showed before the automatic sub→main switch.
    private int? _maxIndex;
    private string? _maxPrevKind;
    private string? _maxPrevPath;
    private string? _maxPrevCamera;
    /// <summary>The stream kind the maximize flow itself put on the card (auto main
    /// or the URL's explicit choice) — only that exact kind is reverted on restore,
    /// so a stream picked by hand in the dropdown is respected.</summary>
    private string? _maxSetKind;
    private string _server = "";
    private string? _user;
    private string? _pass;
    private string? _error;
    private bool _loaded;
    private bool _sidebarOpen;
    private string? _panelCamera;

    // Quick view: temporary pop-up player opened from the sidebar (⛶)
    private ViewSlot? _quickView;
    /// <summary>Touch-first device (phone/tablet): drives stream defaults.</summary>
    private bool _coarsePointer;
    private string? _quickAttached;
    private const string QuickVideoId = "vid-quick";

    // Named layouts: save/reload exact camera arrangements
    private List<SavedLayout> _layouts = new();
    private string? _activeLayout;
    private string _layoutName = "";
    private bool _showLayouts;

    private readonly Dictionary<int, string> _attached = new();
    private PeriodicTimer? _pollTimer;

    // Recorded events (populated when the server has recording enabled)
    private readonly List<ApiEvent> _events = new();
    private bool _eventsSupported;
    private bool _continuousSupported;
    private double _trickleSpeed = 4;

    // Update banner + admin server settings
    private string? _version;
    private string? _latestVersion;
    private string _repoUrl = "https://github.com/borexola/neolink.net";
    private bool _showServerSettings;
    private JsonElement? _adminConfig;
    private bool _adminWritable;
    private string _adminConfigPath = "";
    private string? _adminError;
    private string? _adminStatus;
    private bool _confirmRestart;
    private string _settingsTab = "general";
    private readonly Dictionary<string, string> _adminEdits = new();
    private ApiEvent? _playEvent;

    // Email notifications (loaded with the server-settings panel; saved separately).
    private ApiNotifications? _notif;
    private string _notifPassword = "";
    private string? _notifStatus;
    private bool _notifError, _notifSaving, _notifTesting;
    private bool _notifBusy => _notifSaving || _notifTesting;

    // Email-shape check (local@domain.tld) so a typo in an address field is caught
    // before a save silently ships alerts nowhere.
    private static readonly System.Text.RegularExpressions.Regex EmailRx =
        new(@"^[^@\s]+@[^@\s]+\.[^@\s]+$", System.Text.RegularExpressions.RegexOptions.Compiled);
    private static bool IsEmail(string? s) =>
        !string.IsNullOrWhiteSpace(s) && EmailRx.IsMatch(s.Trim());

    // Recipient is required (every alert goes there); From is optional but must be
    // an address when set; Username is only email-checked when it looks like one —
    // many providers use a plain login or an API token instead.
    private bool NotifRecipientInvalid => _notif is { Enabled: true } && !IsEmail(_notif.Recipient);
    private bool NotifFromInvalid => _notif is { Enabled: true }
        && !string.IsNullOrWhiteSpace(_notif.From) && !IsEmail(_notif.From);
    private bool NotifUsernameInvalid => _notif is { Enabled: true }
        && _notif.Username.Contains('@') && !IsEmail(_notif.Username);
    private bool NotifHasErrors => NotifRecipientInvalid || NotifFromInvalid || NotifUsernameInvalid;

    // Unsaved-change tracking for the notifications tab (it saves to notifications.json
    // separately, so it has its own signal rather than the config badge). The signature
    // is a fingerprint of the editable state, taken on load and after each save; a
    // freshly-typed password counts as a change too.
    private string _notifSignature = "";
    private string NotifSig() => _notif == null ? "" : System.Text.Json.JsonSerializer.Serialize(NotifBody());
    private bool NotifDirty => _notif != null && NotifSig() != _notifSignature;

    private RenderFragment NotifToggle(string label, bool value, Action<bool> set) => __b =>
    {
        __b.OpenElement(0, "div");
        __b.AddAttribute(1, "class", "control-row");
        __b.OpenElement(2, "span");
        __b.AddContent(3, label);
        __b.CloseElement();
        __b.OpenElement(4, "button");
        __b.AddAttribute(5, "class", "chip " + (value ? "" : "chip-off"));
        __b.AddAttribute(6, "onclick", EventCallback.Factory.Create(this, () => set(!value)));
        __b.AddContent(7, value ? "on" : "off");
        __b.CloseElement();
        __b.CloseElement();
    };

    private object NotifBody() => new
    {
        enabled = _notif!.Enabled,
        recipient = _notif.Recipient,
        smtpHost = _notif.SmtpHost,
        smtpPort = _notif.SmtpPort,
        security = _notif.Security,
        username = _notif.Username,
        // Write-only: send the typed value, else null to keep the stored one.
        password = string.IsNullOrEmpty(_notifPassword) ? null : _notifPassword,
        from = _notif.From,
        fromName = _notif.FromName,
        alertStorage = _notif.AlertStorage,
        alertOverload = _notif.AlertOverload,
        alertCameraOffline = _notif.AlertCameraOffline,
        alertWriteFailure = _notif.AlertWriteFailure,
        offlineThresholdMinutes = _notif.OfflineThresholdMinutes,
        cameraOfflineOverrides = _notif.CameraOfflineOverrides,
    };

    private void SetCameraOverride(string cam, string? raw)
    {
        if (_notif == null) return;
        if (int.TryParse(raw?.Trim(), out var m) && m >= 0) _notif.CameraOfflineOverrides[cam] = m;
        else _notif.CameraOfflineOverrides.Remove(cam); // blank = use the default
    }

    private async Task SaveNotificationsAsync()
    {
        if (_notif == null || _notifBusy) return;
        if (_notif.Enabled && NotifHasErrors)
        {
            _notifError = true; _notifStatus = "Fix the highlighted email address first.";
            return;
        }
        _notifSaving = true; _notifStatus = null;
        try
        {
            var req = ApiRequest(HttpMethod.Put, "/api/admin/notifications");
            req.Content = JsonContent.Create(NotifBody());
            using var res = await Http.SendAsync(req);
            if (res.IsSuccessStatusCode)
            {
                _notif = await res.Content.ReadFromJsonAsync<ApiNotifications>();
                _notifPassword = "";
                _notifSignature = NotifSig(); // saved state is the new baseline
                _notifError = false;
                _notifStatus = "Notification settings saved.";
            }
            else
            {
                _notifError = true;
                _notifStatus = "Save failed (" + (int)res.StatusCode + ").";
            }
        }
        catch (Exception ex) { _notifError = true; _notifStatus = ex.Message; }
        finally { _notifSaving = false; }
    }

    private async Task SendTestNotificationAsync()
    {
        if (_notif == null || _notifBusy) return;
        if (_notif.Enabled && NotifHasErrors)
        {
            _notifError = true; _notifStatus = "Fix the highlighted email address first.";
            return;
        }
        _notifTesting = true; _notifStatus = null;
        try
        {
            var req = ApiRequest(HttpMethod.Post, "/api/admin/notifications/test");
            req.Content = JsonContent.Create(NotifBody());
            using var res = await Http.SendAsync(req);
            if (res.IsSuccessStatusCode)
            {
                _notifError = false;
                _notifStatus = "Test email sent — check the recipient inbox.";
            }
            else
            {
                _notifError = true;
                var err = await res.Content.ReadFromJsonAsync<JsonElement>();
                _notifStatus = "Test failed: " +
                    (err.TryGetProperty("error", out var e) ? e.GetString() : "the mail server rejected it.");
            }
        }
        catch (Exception ex) { _notifError = true; _notifStatus = "Test failed: " + ex.Message; }
        finally { _notifTesting = false; }
    }

    // Web-UI authentication (enabled once the first account exists server-side)
    private string? _authToken;
    private string? _authUser;
    private bool _authAdmin;
    private bool _authEnabled;
    private bool _setupRequired;
    private bool _resetAvailable;
    private bool _setupDismissed;
    private bool _showLogin;
    private bool _showSetupPrompt;
    private bool _resetMode;
    private string _loginUser = "";
    private string _loginPass = "";
    private string _resetPass = "";
    private string? _loginError;

    // Admin user management (the Users tab in the server-settings panel)
    private readonly List<ApiUserInfo> _uiUsers = new();
    private string _newUserName = "";
    private string _newUserPass = "";
    private string? _usersError;
    private string? _pwEditUser;
    private string _pwEditPass = "";

    // Review-strip filters (persisted with the view settings, per user when logged in)
    private static readonly string[] StripTypes =
        { "person", "vehicle", "animal", "package", "doorbell", "line-crossing", "intrusion", "motion" };
    private HashSet<string> _hiddenTypes = new(StringComparer.OrdinalIgnoreCase);
    private HashSet<string> _hiddenCams = new(StringComparer.OrdinalIgnoreCase);
    private bool _showStripFilter;
    private int _stripHeight = 160;
    private bool _secWarnDismissed;
    private DotNetObjectReference<Home>? _selfRef;

    protected override void OnInitialized() => EnsureSlots();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try { _coarsePointer = await JS.InvokeAsync<bool>("neolink.isCoarse"); } catch { }
            await LoadPersistedAsync();
            _loaded = true;
            await RefreshAuthAsync();
            await RefreshCamerasAsync();
            await RefreshEventsAsync();
            ApplyRoute(); // deep links (/cameras/{name}) need the camera list first
            StateHasChanged();
            _ = PollLoopAsync();
            return;
        }
        await ReconcilePlayersAsync();
        StopTalkIfOrphaned(); // talk ends when its surface (maximize/quick view) goes away
        if (_mode == "free")
            await JS.InvokeVoidAsync("neolink.freeInit", "stage-grid");
        // Digital zoom (theater/fullscreen/quick view). Re-invoked per render so
        // zoom resets when a surface stops being zoomable (e.g. un-maximized).
        await JS.InvokeVoidAsync("neolink.zoomInit");
        // Phones: pause the hidden tiles while one is maximized (resume on restore).
        await JS.InvokeVoidAsync("neolink.maxSync");
        // Speaker toggles: re-sync glyphs/visibility after every render.
        await JS.InvokeVoidAsync("neolink.audioInit");
        // Esc closes the event player / quick view pop-ups (and the tile menu).
        await JS.InvokeVoidAsync("neolink.escInit");
        // Drag & drop shim (Firefox needs dataTransfer payloads) + grid resize grips.
        _selfRef ??= DotNetObjectReference.Create(this);
        await JS.InvokeVoidAsync("neolink.dndInit");
        await JS.InvokeVoidAsync("neolink.tileResizeInit", _selfRef);
        // Blazor's `muted` attribute only sets defaultMuted on dynamically created
        // elements, which blocks autoplay — the helper mutes for real and plays.
        if (_eventsSupported && _events.Any(e => !e.Reviewed))
        {
            await JS.InvokeVoidAsync("neolink.trickle", _trickleSpeed);
            _selfRef ??= DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("neolink.stripResizeInit", "events-bar", _selfRef);
            await JS.InvokeVoidAsync("neolink.stripNavInit", "events-scroll-wrap");
        }
        // Drive the event player from JS: pick the source for the current speed,
        // preserve position across a clip↔preview swap, and apply the rate.
        if (_playEvent is { HasClip: true })
            await JS.InvokeVoidAsync("neolink.eventPlayer", "event-player-video", PlayerUrl, _playSpeed);
    }

    /// <summary>Called from JS when the strip's resize-handle drag ends.</summary>
    [JSInvokable]
    public async Task OnStripResized(double height)
    {
        _stripHeight = (int)Math.Clamp(height, 96, 640);
        await InvokeAsync(async () =>
        {
            await SaveAsync();
            StateHasChanged();
        });
    }

    // ------------------------------------------------------------ persistence

    private async Task LoadPersistedAsync()
    {
        try
        {
            var json = await JS.InvokeAsync<string?>("neolink.lsGet", StorageKey);
            if (json != null)
            {
                var v = JsonSerializer.Deserialize<PersistedView>(json);
                if (v != null)
                {
                    _server = v.Server ?? "";
                    _user = v.User;
                    _pass = v.Pass;
                    _mode = Modes.Any(m => m.Mode == v.Mode) ? v.Mode : "grid";
                    _count = v.Count;
                    _slots = v.Slots;
                    _backup = v.Backup;
                    ApplyMaxState(v);
                    _hiddenTypes = new HashSet<string>(v.HiddenTypes, StringComparer.OrdinalIgnoreCase);
                    _hiddenCams = new HashSet<string>(v.HiddenCams, StringComparer.OrdinalIgnoreCase);
                    if (v.StripHeight > 0) _stripHeight = Math.Clamp(v.StripHeight, 96, 640);
                    _layouts = v.Layouts;
                    _activeLayout = v.ActiveLayout;
                }
            }
        }
        catch { /* corrupted/old state: start fresh */ }

        _count = ClampCount(_mode, _count == 0 ? 4 : _count);
        EnsureSlots();

        // Heal a bad saved default: the API is plain HTTP, https://host:8555 can never work.
        if (_server.StartsWith("https://", StringComparison.OrdinalIgnoreCase) &&
            _server.TrimEnd('/').EndsWith(":8555", StringComparison.Ordinal))
        {
            _server = "http://" + _server["https://".Length..];
            await SaveAsync();
        }

        try { _origin = await JS.InvokeAsync<string>("neolink.defaultServer"); } catch { }
        if (string.IsNullOrWhiteSpace(_server))
            _server = _origin;

        // Session + one-time flags
        try
        {
            var auth = await JS.InvokeAsync<string?>("neolink.lsGet", "neolink.auth");
            if (!string.IsNullOrWhiteSpace(auth))
            {
                var el = JsonSerializer.Deserialize<JsonElement>(auth);
                if (el.TryGetProperty("token", out var t)) _authToken = t.GetString();
            }
            // Dismissals are scoped to the server (a new/redeployed open server must
            // warn again), and the sidebar banner only stays hidden for this browsing
            // session — an unsecured server re-warns on every fresh visit.
            _setupDismissed = await JS.InvokeAsync<string?>("neolink.lsGet", SetupDismissKey) == "1";
            _secWarnDismissed = await JS.InvokeAsync<string?>("neolink.ssGet", SecWarnDismissKey) == "1";
            _storageWarnDismissed = await JS.InvokeAsync<string?>("neolink.ssGet", StorageWarnDismissKey) == "1";
            _mainWarned = await JS.InvokeAsync<string?>("neolink.lsGet", MainWarnKey) == "1";
            _updateDismissedVersion = await JS.InvokeAsync<string?>("neolink.lsGet", "neolink.updateDismissed");
            _playSd = await JS.InvokeAsync<string?>("neolink.lsGet", "neolink.eventSd") == "1";
            if (double.TryParse(await JS.InvokeAsync<string?>("neolink.lsGet", "neolink.eventSpeed"),
                    System.Globalization.NumberStyles.Float,
                    System.Globalization.CultureInfo.InvariantCulture, out var evSpeed)
                && PlaybackSpeeds.Contains(evSpeed))
                _playSpeed = evSpeed;
        }
        catch { }
    }

    /// <summary>Which version's update banner the user dismissed (a newer one re-shows it).</summary>
    private string? _updateDismissedVersion;

    /// <summary>Dismissal keys carry the server address: another deployment warns afresh.</summary>
    private string SetupDismissKey => $"neolink.setupDismissed:{_server.TrimEnd('/')}";
    private string SecWarnDismissKey => $"neolink.secWarnDismissed:{_server.TrimEnd('/')}";

    private async Task DismissSecWarnAsync()
    {
        // Session-scoped on purpose: hiding a security warning forever defeats it.
        _secWarnDismissed = true;
        await JS.InvokeVoidAsync("neolink.ssSet", SecWarnDismissKey, "1");
    }

    // ---------------------------------------------------------------- storage banners

    /// <summary>Worst storage tier's state from /api/features; null = healthy.</summary>
    private ApiStorageState? _storage;
    private bool _storageWarnDismissed;
    private string StorageWarnDismissKey => $"neolink.storageWarnDismissed:{_server.TrimEnd('/')}";

    private async Task DismissStorageWarnAsync()
    {
        // Session-scoped: a nearly-full disk should re-warn on the next visit.
        _storageWarnDismissed = true;
        await JS.InvokeVoidAsync("neolink.ssSet", StorageWarnDismissKey, "1");
    }

    // One-time performance nudge, shown the first time the wall holds more than
    // four MAIN streams (each is a full-resolution decode). Once ever per browser.
    private const string MainWarnKey = "neolink.mainStreamWarned";
    private bool _showMainWarn;
    private bool _mainWarned;

    /// <summary>Call after anything that can put another main stream on the wall.</summary>
    private void MaybeWarnMainStreams()
    {
        if (_mainWarned || _slots.Count(s => s.Kind == "mainStream") <= 4) return;
        _mainWarned = true;
        _showMainWarn = true;
        _ = JS.InvokeVoidAsync("neolink.lsSet", MainWarnKey, "1");
        _ = AutoHideMainWarnAsync();
    }

    private async Task AutoHideMainWarnAsync()
    {
        await Task.Delay(TimeSpan.FromSeconds(15)); // brief: it fades on its own
        if (!_showMainWarn) return;
        _showMainWarn = false;
        await InvokeAsync(StateHasChanged);
    }

    /// <summary>The default same-origin server is re-derived from the page on every
    /// load, so it is never persisted — that keeps a rotating reverse-proxy prefix
    /// (e.g. a Home Assistant ingress token) out of saved state, where it would go
    /// stale. Only an explicitly chosen remote server is stored.</summary>
    private bool ServerIsDefault =>
        string.IsNullOrWhiteSpace(_server) ||
        string.Equals(_server.TrimEnd('/'), _origin.TrimEnd('/'), StringComparison.OrdinalIgnoreCase);

    private PersistedView SnapshotView() => new()
    {
        Server = ServerIsDefault ? "" : _server, User = _user, Pass = _pass,
        Mode = _mode, Count = _count, Slots = _slots, Backup = _backup,
        MaxIndex = _maxIndex, MaxPrevKind = _maxPrevKind, MaxPrevPath = _maxPrevPath,
        MaxPrevCamera = _maxPrevCamera, MaxSetKind = _maxSetKind,
        HiddenTypes = _hiddenTypes.ToList(), HiddenCams = _hiddenCams.ToList(),
        StripHeight = _stripHeight,
        Layouts = _layouts, ActiveLayout = _activeLayout,
    };

    private async Task SaveAsync()
    {
        if (!_loaded) return;
        var json = JsonSerializer.Serialize(SnapshotView());
        await JS.InvokeVoidAsync("neolink.lsSet", StorageKey, json);
        // Logged-in users own their settings server-side (per account).
        if (_authUser != null)
        {
            try
            {
                var req = ApiRequest(HttpMethod.Put, "/api/me/settings");
                req.Content = new StringContent(json, System.Text.Encoding.UTF8, "application/json");
                using var _ = await Http.SendAsync(req);
            }
            catch { /* transient: localStorage still has it */ }
        }
    }

    /// <summary>Restores the in-place maximize state, ignoring an index the current slots can't satisfy.</summary>
    private void ApplyMaxState(PersistedView v)
    {
        _maxIndex = v.MaxIndex is int i && i >= 0 && i < _slots.Count && _slots[i].Camera != null ? i : null;
        _maxPrevKind = _maxIndex != null ? v.MaxPrevKind : null;
        _maxPrevPath = _maxIndex != null ? v.MaxPrevPath : null;
        _maxPrevCamera = _maxIndex != null ? v.MaxPrevCamera : null;
        _maxSetKind = _maxIndex != null ? v.MaxSetKind : null;
    }

    /// <summary>Applies the server-stored per-user view (everything except the server address).</summary>
    private void ApplyView(PersistedView v)
    {
        _mode = Modes.Any(m => m.Mode == v.Mode) ? v.Mode : _mode;
        if (v.Count > 0) _count = ClampCount(_mode, v.Count);
        if (v.Slots.Count > 0) _slots = v.Slots;
        _backup = v.Backup;
        ApplyMaxState(v);
        _user = v.User;
        _pass = v.Pass;
        _hiddenTypes = new HashSet<string>(v.HiddenTypes, StringComparer.OrdinalIgnoreCase);
        _hiddenCams = new HashSet<string>(v.HiddenCams, StringComparer.OrdinalIgnoreCase);
        if (v.StripHeight > 0) _stripHeight = Math.Clamp(v.StripHeight, 96, 640);
        // Account settings that predate saved layouts keep whatever localStorage had.
        if (v.Layouts.Count > 0) _layouts = v.Layouts;
        if (v.ActiveLayout != null) _activeLayout = v.ActiveLayout;
        EnsureSlots();
    }

    // ------------------------------------------------------------ authentication

    private string _origin = "";

    /// <summary>
    /// Where SERVER-side fetches go. Blazor circuits run in this very process, so
    /// when the configured server is the page's own origin, calls go to loopback
    /// instead of back out through a reverse proxy's public URL (which the host
    /// often can't reach, or rejects for its internal TLS cert). A genuinely
    /// remote server address is used as-is. Browser-side URLs (video WS, media
    /// elements) intentionally keep <see cref="_server"/> so they traverse the proxy.
    /// </summary>
    private string ResolveApi(string server)
    {
        var s = server.TrimEnd('/');
        return _origin.Length > 0 && string.Equals(s, _origin.TrimEnd('/'), StringComparison.OrdinalIgnoreCase)
            ? Local.BaseUrl.TrimEnd('/')
            : s;
    }

    private string ApiBase => ResolveApi(_server);

    private HttpRequestMessage ApiRequest(HttpMethod method, string path)
    {
        var req = new HttpRequestMessage(method, $"{ApiBase}{path}");
        if (!string.IsNullOrEmpty(_authToken))
            req.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", _authToken);
        return req;
    }

    /// <summary>Token as a query parameter, for URLs headers can't reach (video/img/WS).</summary>
    private string TokenQuery(char sep) =>
        string.IsNullOrEmpty(_authToken) ? "" : $"{sep}token={Uri.EscapeDataString(_authToken)}";

    private async Task RefreshAuthAsync()
    {
        if (string.IsNullOrWhiteSpace(_server)) return;
        try
        {
            using var res = await Http.SendAsync(ApiRequest(HttpMethod.Get, "/api/auth/status"));
            var st = await res.Content.ReadFromJsonAsync<ApiAuthStatus>();
            if (st == null) return;
            _authEnabled = st.Enabled;
            _setupRequired = st.SetupRequired;
            _resetAvailable = st.ResetAvailable;
            _authUser = st.User;
            _authAdmin = st.Admin;
            _showLogin = _authEnabled && _authUser == null;
            if (_authUser != null)
                await LoadUserSettingsAsync();
            if (_setupRequired && !_setupDismissed)
                _showSetupPrompt = true;
        }
        catch { /* unreachable server: the camera fetch reports it */ }
    }

    private async Task LoadUserSettingsAsync()
    {
        try
        {
            using var res = await Http.SendAsync(ApiRequest(HttpMethod.Get, "/api/me/settings"));
            if (!res.IsSuccessStatusCode) return;
            var json = await res.Content.ReadAsStringAsync();
            if (string.IsNullOrWhiteSpace(json) || json.Trim() == "{}") return;
            var v = JsonSerializer.Deserialize<PersistedView>(json);
            if (v != null) ApplyView(v);
        }
        catch { }
    }

    private async Task AcceptTokenAsync(ApiAuthToken? tok)
    {
        if (tok == null) return;
        _authToken = tok.Token;
        _authUser = tok.User;
        _authAdmin = tok.Admin;
        _authEnabled = true;
        _setupRequired = false;
        _showLogin = false;
        _showSetupPrompt = false;
        _resetMode = false;
        _loginPass = "";
        _loginError = null;
        await JS.InvokeVoidAsync("neolink.lsSet", "neolink.auth",
            JsonSerializer.Serialize(new { token = _authToken, user = _authUser, admin = _authAdmin }));
        // Auth works here now — re-arm the setup prompt so a future regression
        // to an open server (e.g. a redeploy losing users.json) warns loudly again.
        _setupDismissed = false;
        await JS.InvokeVoidAsync("neolink.lsSet", SetupDismissKey, "");
        await LoadUserSettingsAsync();
        await RefreshCamerasAsync();
        await RefreshEventsAsync();
        // A deep link (/cameras/{name}) opened on an auth-enabled server could
        // not resolve until now — the camera list needed the session token.
        ApplyRoute();
    }

    private async Task LoginAsync()
    {
        _loginError = null;
        try
        {
            var req = ApiRequest(HttpMethod.Post, "/api/auth/login");
            req.Content = JsonContent.Create(new { username = _loginUser.Trim(), password = _loginPass });
            using var res = await Http.SendAsync(req);
            if (!res.IsSuccessStatusCode)
            {
                _loginError = await ApiErrorAsync(res) ?? "sign-in failed";
                return;
            }
            await AcceptTokenAsync(await res.Content.ReadFromJsonAsync<ApiAuthToken>());
        }
        catch (Exception ex)
        {
            _loginError = $"Cannot reach {_server}: {ex.Message}";
        }
    }

    private async Task SetupAdminAsync()
    {
        _loginError = null;
        try
        {
            var req = ApiRequest(HttpMethod.Post, "/api/auth/setup");
            req.Content = JsonContent.Create(new { username = _loginUser.Trim(), password = _loginPass });
            using var res = await Http.SendAsync(req);
            if (!res.IsSuccessStatusCode)
            {
                _loginError = await ApiErrorAsync(res) ?? "setup failed";
                return;
            }
            await AcceptTokenAsync(await res.Content.ReadFromJsonAsync<ApiAuthToken>());
        }
        catch (Exception ex)
        {
            _loginError = $"Cannot reach {_server}: {ex.Message}";
        }
    }

    private async Task ResetAdminAsync()
    {
        _loginError = null;
        try
        {
            var req = ApiRequest(HttpMethod.Post, "/api/auth/reset-admin");
            req.Content = JsonContent.Create(new { password = _resetPass });
            using var res = await Http.SendAsync(req);
            if (!res.IsSuccessStatusCode)
            {
                _loginError = await ApiErrorAsync(res) ?? "reset failed";
                return;
            }
            _resetMode = false;
            _resetPass = "";
            _loginError = "Password updated — sign in with it now, then set reset_admin_password back to false.";
        }
        catch (Exception ex)
        {
            _loginError = $"Cannot reach {_server}: {ex.Message}";
        }
    }

    private async Task LogoutAsync()
    {
        _authToken = null;
        _authUser = null;
        _authAdmin = false;
        _showServerSettings = false; // admin tabs are gone with the session
        await JS.InvokeVoidAsync("neolink.lsSet", "neolink.auth", "");
        _showLogin = _authEnabled;
    }

    private async Task DismissSetupAsync()
    {
        _showSetupPrompt = false;
        _setupDismissed = true;
        await JS.InvokeVoidAsync("neolink.lsSet", SetupDismissKey, "1");
    }

    private static async Task<string?> ApiErrorAsync(HttpResponseMessage res)
    {
        try
        {
            var el = await res.Content.ReadFromJsonAsync<JsonElement>();
            return el.TryGetProperty("error", out var err) ? err.GetString() : null;
        }
        catch
        {
            return null;
        }
    }

