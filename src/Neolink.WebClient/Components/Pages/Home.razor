    // ------------------------------------------------------------ data

    private async Task RefreshCamerasAsync()
    {
        if (await TryFetchCamerasAsync(_server)) return;

        // The UI is served by Neolink.Server itself, so the page origin is almost
        // always the right API address. Heal stale/typo'd saved values automatically.
        try
        {
            var origin = await JS.InvokeAsync<string>("neolink.defaultServer");
            if (!string.Equals(origin, _server, StringComparison.OrdinalIgnoreCase)
                && await TryFetchCamerasAsync(origin))
            {
                _server = origin;
                await SaveAsync();
            }
        }
        catch { /* JS unavailable (prerender/disconnect): keep the original error */ }
    }

    private async Task<bool> TryFetchCamerasAsync(string server)
    {
        if (string.IsNullOrWhiteSpace(server)) return false;
        try
        {
            var req = new HttpRequestMessage(HttpMethod.Get, $"{ResolveApi(server)}/api/cameras");
            if (!string.IsNullOrEmpty(_authToken))
                req.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", _authToken);
            using var res = await Http.SendAsync(req);
            if (res.StatusCode == System.Net.HttpStatusCode.Unauthorized)
            {
                // Reachable, but a session is required (or ours expired).
                _authEnabled = true;
                _showLogin = true;
                _cameras.Clear();
                _error = null;
                return true;
            }
            if (!res.IsSuccessStatusCode)
            {
                _error = $"Cannot reach {server}: HTTP {(int)res.StatusCode}";
                return false;
            }
            var cams = await res.Content.ReadFromJsonAsync<List<ApiCamera>>();
            _cameras.Clear();
            if (cams != null) _cameras.AddRange(cams);
            SyncClipStates();
            _error = null;
            _camerasFetched = true;
            return true;
        }
        catch (Exception ex)
        {
            _error = $"Cannot reach {server}: {ex.Message}";
            return false;
        }
    }

    private async Task PollLoopAsync()
    {
        _pollTimer = new PeriodicTimer(TimeSpan.FromSeconds(10));
        try
        {
            while (await _pollTimer.WaitForNextTickAsync())
            {
                await RefreshCamerasAsync();
                await RefreshEventsAsync();
                StateHasChanged();
            }
        }
        catch (OperationCanceledException) { }
        catch (ObjectDisposedException) { }
    }

    private async Task OnServerChangedAsync()
    {
        await RefreshCamerasAsync();
        await RefreshEventsAsync();
        await SaveAsync();
    }

    // ------------------------------------------------------------ on-demand clip recording

    /// <summary>Camera → UTC instant its on-demand recording auto-stops. Drives the
    /// on-video indicator and countdown between polls (the poll re-syncs it, so a
    /// recording started from Home Assistant shows up here too).</summary>
    private readonly Dictionary<string, DateTime> _clipEnds = new();
    private Task? _clipTicker;

    private bool ClipActive(string cameraName) =>
        _clipEnds.TryGetValue(cameraName, out var end) && end > DateTime.UtcNow;

    private string ClipCountdown(string cameraName)
    {
        if (!_clipEnds.TryGetValue(cameraName, out var end)) return "";
        var left = end - DateTime.UtcNow;
        if (left < TimeSpan.Zero) left = TimeSpan.Zero;
        return $"{(int)left.TotalMinutes}:{left.Seconds:00}";
    }

    private static string ClipMaxLabel(ApiCamera cam) =>
        cam.OnDemand is { } od && od.MaxSeconds >= 120 && od.MaxSeconds % 60 == 0
            ? $"{od.MaxSeconds / 60} min"
            : $"{cam.OnDemand?.MaxSeconds ?? 0}s";

    /// <summary>Adopts the server's view after every camera poll — the server owns
    /// the session (it also runs it for MQTT triggers), this map only bridges the
    /// seconds between polls.</summary>
    private void SyncClipStates()
    {
        foreach (var cam in _cameras)
        {
            if (cam.OnDemand is { Active: true } od)
                _clipEnds[cam.Name] = DateTime.UtcNow.AddSeconds(od.RemainingSeconds);
            else
                _clipEnds.Remove(cam.Name);
        }
        EnsureClipTicker();
    }

    /// <summary>A 1-second re-render loop while any countdown runs (the regular poll
    /// is too coarse for a ticking timer). Ends itself when the last one expires.</summary>
    private void EnsureClipTicker()
    {
        if (_clipEnds.Count == 0 || _clipTicker is { IsCompleted: false }) return;
        _clipTicker = Task.Run(async () =>
        {
            try
            {
                while (true)
                {
                    await Task.Delay(1000);
                    bool any = false;
                    await InvokeAsync(() =>
                    {
                        // An expired entry means the cap landed: drop it now instead
                        // of showing a frozen 0:00 until the next poll confirms.
                        foreach (var done in _clipEnds.Where(kv => kv.Value <= DateTime.UtcNow)
                                     .Select(kv => kv.Key).ToList())
                            _clipEnds.Remove(done);
                        any = _clipEnds.Count > 0;
                        StateHasChanged();
                    });
                    if (!any) break;
                }
            }
            catch
            {
                // Circuit gone (page closed) — nothing left to tick for.
            }
        });
    }

    private async Task ToggleClipAsync(ApiCamera cam)
    {
        bool start = !ClipActive(cam.Name);
        // Optimistic flip so the button answers instantly; the response corrects it.
        if (start && cam.OnDemand is { } od)
            _clipEnds[cam.Name] = DateTime.UtcNow.AddSeconds(od.MaxSeconds);
        else
            _clipEnds.Remove(cam.Name);
        try
        {
            var req = ApiRequest(HttpMethod.Post, $"/api/cameras/{Uri.EscapeDataString(cam.Name)}/record");
            req.Content = JsonContent.Create(new { active = start });
            using var res = await Http.SendAsync(req);
            if (res.IsSuccessStatusCode
                && await res.Content.ReadFromJsonAsync<ApiOnDemand>() is { } state && state.Active)
                _clipEnds[cam.Name] = DateTime.UtcNow.AddSeconds(state.RemainingSeconds);
            else
                _clipEnds.Remove(cam.Name);
        }
        catch
        {
            _clipEnds.Remove(cam.Name);
        }
        EnsureClipTicker();
    }

    // ------------------------------------------------------------ recorded events

    private string EventArtifactUrl(ApiEvent ev, string kind) =>
        $"{_server.TrimEnd('/')}/api/events/{Uri.EscapeDataString(ev.Id)}/{kind}{TokenQuery('?')}";

    /// <summary>
    /// A strip card takes the exact shape of its camera (the meta text overlays
    /// the clip, so the whole card is media): ultrawide footage gets a wide card,
    /// nothing is cropped and nothing is padded. Falls back to 16:9 when the
    /// camera (or its resolution) is unknown; contain-fit absorbs that rare
    /// mismatch as bars.
    /// </summary>
    private string CardAspect(ApiEvent ev)
    {
        var cam = _cameras.FirstOrDefault(c => string.Equals(c.Name, ev.Camera, StringComparison.OrdinalIgnoreCase));
        var s = cam?.Streams.FirstOrDefault(x => x.Width > 0 && x.Height > 0);
        double aspect = s != null ? (double)s.Width / s.Height : 16.0 / 9;
        aspect = Math.Clamp(aspect, 1.0, 4.0);
        return $"aspect-ratio: {aspect.ToString("0.###", System.Globalization.CultureInfo.InvariantCulture)}";
    }

    private async Task RefreshEventsAsync()
    {
        if (string.IsNullOrWhiteSpace(_server)) return;
        try
        {
            using var fres = await Http.SendAsync(ApiRequest(HttpMethod.Get, "/api/features"));
            var features = fres.IsSuccessStatusCode ? await fres.Content.ReadFromJsonAsync<ApiFeaturesInfo>() : null;
            _continuousSupported = features?.Continuous == true;
            if (features != null && features.TrickleSpeed > 0) _trickleSpeed = features.TrickleSpeed;
            if (features != null)
            {
                _version = features.Version;
                _latestVersion = features.LatestVersion;
                if (!string.IsNullOrEmpty(features.RepoUrl)) _repoUrl = features.RepoUrl;
                _storage = features.Storage;
            }
        }
        catch
        {
            _continuousSupported = false;
        }
        try
        {
            // 500 covers a full busy day, so the panel's rolling 24h view is honest.
            using var res = await Http.SendAsync(ApiRequest(HttpMethod.Get, "/api/events?limit=500"));
            if (res.StatusCode == System.Net.HttpStatusCode.Unauthorized)
            {
                _authEnabled = true;
                _showLogin = true;
                return;
            }
            if (!res.IsSuccessStatusCode)
            {
                _eventsSupported = false; // recording disabled on the server: hide the UI
                return;
            }
            var list = await res.Content.ReadFromJsonAsync<List<ApiEvent>>();
            _eventsSupported = true;
            _events.Clear();
            if (list != null) _events.AddRange(list);
            // Keep an open player in sync (the clip appears once an ongoing event closes).
            if (_playEvent != null)
                _playEvent = _events.FirstOrDefault(e => e.Id == _playEvent.Id) ?? _playEvent;
        }
        catch
        {
            _eventsSupported = false;
        }
    }

    private static readonly double[] PlaybackSpeeds = { 1, 2, 4, 8, 16 };
    private double _playSpeed = 1;

    /// <summary>The user's HD/SD pick: false = full main-stream clip (default at
    /// every speed — muted fast playback keeps it smooth), true = the low-res
    /// sub-stream twin, the escape hatch when storage or decoder can't keep up.
    /// Persisted browser-side ("neolink.eventSd") — a deliberate choice sticks.</summary>
    private bool _playSd;

    private static string FormatSpeed(double s) => s == 1 ? "1×" : $"{s:0}×";

    private string PlayerUrl => _playEvent == null ? "" :
        (_playSd && _playEvent.HasPreview)
            ? EventArtifactUrl(_playEvent, "preview")
            : EventArtifactUrl(_playEvent, "clip");

    private async Task SetPlaySpeedAsync(double s)
    {
        _playSpeed = s;
        // Sticky preference, shared with the Events page ("neolink.eventSpeed"):
        // the next event opened — here or there — starts at this speed.
        try
        {
            await JS.InvokeVoidAsync("neolink.lsSet", "neolink.eventSpeed",
                s.ToString(System.Globalization.CultureInfo.InvariantCulture));
        }
        catch { }
        await JS.InvokeVoidAsync("neolink.eventPlayer", "event-player-video", PlayerUrl, s);
    }

    private async Task SetPlayStreamAsync(bool sd)
    {
        _playSd = sd;
        try { await JS.InvokeVoidAsync("neolink.lsSet", "neolink.eventSd", sd ? "1" : "0"); } catch { }
        await JS.InvokeVoidAsync("neolink.eventPlayer", "event-player-video", PlayerUrl, _playSpeed);
    }

    // _playSpeed deliberately survives across events (loaded once per session).
    private void OpenEvent(ApiEvent ev) => _playEvent = ev;

    /// <summary>Closing the player counts as reviewing: the event leaves the top strip.</summary>
    private async Task ClosePlayerAsync()
    {
        var ev = _playEvent;
        _playEvent = null;
        if (ev is { Reviewed: false })
            await DismissAsync(ev);
    }

    /// <summary>Older/newer navigation: the event being left behind was watched too.</summary>
    private async Task NavigatePlayerAsync(int direction)
    {
        var watched = _playEvent;
        var next = NeighborEvent(direction);
        if (next == null) return;
        _playEvent = next;
        if (watched is { Reviewed: false })
            await DismissAsync(watched);
    }

    /// <summary>The adjacent event in the newest-first list (+1 = older, -1 = newer).</summary>
    private ApiEvent? NeighborEvent(int direction)
    {
        if (_playEvent == null) return null;
        int i = _events.FindIndex(e => e.Id == _playEvent.Id);
        int target = i + direction;
        return i < 0 || target < 0 || target >= _events.Count ? null : _events[target];
    }

    private async Task DismissAsync(ApiEvent ev)
    {
        if (!await PostEventReviewAsync(ev, reviewed: true)) return;
        int i = _events.FindIndex(e => e.Id == ev.Id);
        if (i >= 0) _events[i] = _events[i] with { Reviewed = true };
        if (_playEvent?.Id == ev.Id) _playEvent = _playEvent with { Reviewed = true };
    }

    private async Task DismissAllAsync()
    {
        foreach (var ev in _events.Where(e => !e.Reviewed).ToList())
        {
            if (!await PostEventReviewAsync(ev, reviewed: true)) return; // e.g. auth failed: stop
            int i = _events.FindIndex(e => e.Id == ev.Id);
            if (i >= 0) _events[i] = _events[i] with { Reviewed = true };
        }
    }

    private async Task<bool> PostEventReviewAsync(ApiEvent ev, bool reviewed)
    {
        try
        {
            var req = new HttpRequestMessage(HttpMethod.Post,
                $"{ApiBase}/api/events/{Uri.EscapeDataString(ev.Id)}/review");
            if (!string.IsNullOrEmpty(_authToken))
            {
                req.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", _authToken);
            }
            else if (!string.IsNullOrEmpty(_user))
            {
                var token = Convert.ToBase64String(System.Text.Encoding.UTF8.GetBytes($"{_user}:{_pass}"));
                req.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Basic", token);
            }
            req.Content = JsonContent.Create(new { reviewed });
            using var res = await Http.SendAsync(req);
            if (res.StatusCode == System.Net.HttpStatusCode.Unauthorized)
            {
                _error = "Not authorized — set your credentials under server settings (⚙).";
                return false;
            }
            return res.IsSuccessStatusCode;
        }
        catch (Exception ex)
        {
            _error = $"Cannot reach {_server}: {ex.Message}";
            return false;
        }
    }

    private static string Ago(DateTime utc)
    {
        var span = DateTime.UtcNow - utc.ToUniversalTime();
        if (span < TimeSpan.Zero) span = TimeSpan.Zero;
        return span.TotalSeconds < 60 ? "just now"
            : span.TotalMinutes < 60 ? $"{(int)span.TotalMinutes}m ago"
            : span.TotalHours < 24 ? $"{(int)span.TotalHours}h ago"
            : $"{(int)span.TotalDays}d ago";
    }

    private static string DurationText(ApiEvent ev) =>
        ev.Ongoing ? "recording…"
        : ev.Duration.TotalSeconds < 1 ? "<1s"
        : ev.Duration.TotalSeconds < 90 ? $"{(int)Math.Ceiling(ev.Duration.TotalSeconds)}s"
        : $"{(int)Math.Round(ev.Duration.TotalMinutes)} min";

    // ------------------------------------------------------------ layout

    private static int ClampCount(string mode, int n) => mode switch
    {
        "theater" => 1,
        "focus" => Math.Clamp(n, 2, 9),
        "mosaic" => Math.Clamp(n, 2, 8),
        _ => Math.Clamp(n, 1, 16),
    };

    private void EnsureSlots()
    {
        while (_slots.Count < _count) _slots.Add(new ViewSlot());
        if (_slots.Count > _count) _slots = _slots.Take(_count).ToList();
    }

    private void SetMode(string mode)
    {
        ExitMaximize();
        _mode = mode;
        _count = ClampCount(mode, _count);
        EnsureSlots();
        _ = SaveAsync();
    }

    private void SetCount(int n)
    {
        ExitMaximize();
        int target = ClampCount(_mode, n);
        // Shrinking drops EMPTY tiles first (newest empty first): a running feed
        // only disappears when every remaining tile is occupied.
        while (_slots.Count > target)
        {
            int drop = _slots.FindLastIndex(s => s.Camera == null);
            _slots.RemoveAt(drop >= 0 ? drop : _slots.Count - 1);
        }
        _count = target;
        EnsureSlots();
        _ = SaveAsync();
    }

    /// <summary>Layout/count changes end the maximized detour (stream reverted).</summary>
    private void ExitMaximize()
    {
        if (_maxIndex == null) return;
        RevertAutoMainSwitch();
        _maxIndex = null;
        if (Camera != null) Nav.NavigateTo(""); // keep the URL honest
    }

    private static int GridColumns(int n) => (int)Math.Ceiling(Math.Sqrt(n));

    private string? ContainerStyle() => _mode switch
    {
        "grid" => $"grid-template-columns: repeat({GridColumns(_count)}, 1fr); grid-auto-rows: 1fr;",
        "focus" => $"grid-template-columns: 4fr 1fr; grid-template-rows: repeat({Math.Max(1, _count - 1)}, 1fr);",
        "mosaic" when _count <= 6 => "grid-template-columns: repeat(3, 1fr); grid-template-rows: repeat(3, 1fr);",
        "mosaic" => "grid-template-columns: repeat(4, 1fr); grid-template-rows: repeat(4, 1fr);",
        _ => null,
    };

    // Mosaic: hero in the top-left corner, small tiles wrap around it (classic CCTV wall).
    private static readonly (int Row, int Col)[] MosaicCells3 = { (1, 3), (2, 3), (3, 1), (3, 2), (3, 3) };
    private static readonly (int Row, int Col)[] MosaicCells4 = { (1, 4), (2, 4), (3, 4), (4, 1), (4, 2), (4, 3), (4, 4) };

    private string? TileStyle(int i)
    {
        switch (_mode)
        {
            case "focus":
                return i == 0
                    ? $"grid-area: 1 / 1 / span {Math.Max(1, _count - 1)} / 2;"
                    : $"grid-area: {i} / 2 / span 1 / 3;";
            case "mosaic":
            {
                if (i == 0)
                    return _count <= 6 ? "grid-area: 1 / 1 / span 2 / span 2;" : "grid-area: 1 / 1 / span 3 / span 3;";
                var cells = _count <= 6 ? MosaicCells3 : MosaicCells4;
                var (r, c) = cells[Math.Min(i - 1, cells.Length - 1)];
                return $"grid-area: {r} / {c} / span 1 / span 1;";
            }
            case "free":
                return null; // geometry is owned by JS (drag/resize, persisted separately)
            case "grid":
            {
                // User-resized tiles span whole grid cells (corner grip).
                var s = _slots[i];
                return s.Cols > 1 || s.Rows > 1
                    ? $"grid-column: span {Math.Min(s.Cols, GridColumns(_count))}; grid-row: span {s.Rows};"
                    : "";
            }
            default:
                return "";   // explicit empty: clears leftover free-mode geometry on mode switch
        }
    }

    // ------------------------------------------------------------ drag & drop, context menu, resize

    private int? _dragTile;      // tile being dragged (drop = swap)
    private string? _dragCamera; // sidebar camera being dragged onto a tile
    private int? _dropIndex;     // hovered drop target (highlight)
    private int? _ctxIndex;      // tile whose right-click menu is open
    private double _ctxX, _ctxY;

    private bool TileDraggable(int index) =>
        _mode != "free" && _maxIndex == null && _slots[index].Camera != null;

    private void ClearDragState()
    {
        _dragTile = null;
        _dragCamera = null;
        _dropIndex = null;
    }

    private async Task DropOnTileAsync(int index)
    {
        var fromCamera = _dragCamera;
        var fromTile = _dragTile;
        ClearDragState();
        if (fromCamera != null)
        {
            var cam = _cameras.FirstOrDefault(c => c.Name == fromCamera);
            if (cam != null) await SetTileCameraAsync(index, cam);
        }
        else if (fromTile is int from && from != index && from < _slots.Count)
        {
            // Swap the whole slots — the camera moves together with its size.
            (_slots[from], _slots[index]) = (_slots[index], _slots[from]);
            await SaveAsync();
        }
    }

    /// <summary>Drops and right-click picks put the SUB stream on the tile (wall duty);
    /// if the camera already lives on another tile it MOVES here instead of duplicating.</summary>
    private async Task SetTileCameraAsync(int index, ApiCamera cam)
    {
        var s = DefaultStream(cam);
        if (s == null) return;
        int existing = _slots.FindIndex(x => x.Camera == cam.Name);
        var slot = _slots[index];
        slot.Camera = cam.Name;
        slot.Kind = s.Kind;
        slot.Path = s.Path;
        if (existing >= 0 && existing != index)
            _slots[existing].Clear();
        MaybeWarnMainStreams();
        await SaveAsync();
    }

    private void OpenTileMenu(int index, MouseEventArgs e)
    {
        _ctxIndex = index;
        _ctxX = e.ClientX;
        _ctxY = e.ClientY;
    }

    private void CloseTileMenu() => _ctxIndex = null;

    private async Task PickTileCameraAsync(int index, ApiCamera cam)
    {
        CloseTileMenu();
        await SetTileCameraAsync(index, cam);
    }

    /// <summary>Called from JS when a grid tile's corner grip is released.</summary>
    [JSInvokable]
    public async Task OnTileSpan(int index, int cols, int rows)
    {
        if (_mode != "grid" || index < 0 || index >= _slots.Count) return;
        int maxCols = GridColumns(_count);
        int maxRows = Math.Max(1, (int)Math.Ceiling((double)_count / maxCols));
        _slots[index].Cols = Math.Clamp(cols, 1, maxCols);
        _slots[index].Rows = Math.Clamp(rows, 1, maxRows);
        await InvokeAsync(async () =>
        {
            await SaveAsync();
            StateHasChanged();
        });
    }

    // ------------------------------------------------------------ slot actions

    private static ApiStream? DefaultStream(ApiCamera cam) =>
        cam.Streams.FirstOrDefault(s => s.Kind == "subStream") ?? cam.Streams.FirstOrDefault();

    /// <summary>Sidebar camera-name click: open it full size on the MAIN stream.
    /// (Putting a camera on a tile is drag-and-drop or the tile's right-click menu.)</summary>
    private void OpenCameraMain(ApiCamera cam)
    {
        // Phones open the SUB stream: a 1440p+ main stream decoded on a phone
        // screen is what made previews stutter on iOS, and the panel can't show
        // those pixels anyway. The sidebar's Main chip still opens Main explicitly.
        var preferred = _coarsePointer ? "subStream" : "mainStream";
        var pick = cam.Streams.FirstOrDefault(s => s.Kind == preferred)
            ?? cam.Streams.FirstOrDefault(s => s.Kind == "mainStream");
        _sidebarOpen = false; // mobile drawer: close after picking
        Nav.NavigateTo(pick != null ? StreamUrl(cam.Name, pick.Kind) : CameraUrl(cam.Name));
    }

    private static string CamHeadTitle(ApiCamera cam) =>
        cam.Suspended
            ? "Suspended in Neolink.NET — not viewed or recorded here until resumed (the camera itself keeps running)"
            : cam.Privacy
            ? "Privacy mode is on — the camera is dark on purpose until it is switched back"
            : cam.Online
                ? "Open full view (main stream) — drag the card onto a tile to add it to the wall"
                : cam.Asleep
                    ? "Battery camera sleeping to save power — opening a stream reconnects (it must be awake to answer)"
                    : "Camera unreachable — reconnecting";

    private void ChangeStream(int index, ApiCamera camera, string? path)
    {
        var stream = camera.Streams.FirstOrDefault(s => s.Path == path);
        if (stream == null) return;
        _slots[index].Kind = stream.Kind;
        _slots[index].Path = stream.Path;
        MaybeWarnMainStreams();
        _ = SaveAsync();
    }

    private void CloseSlot(int index)
    {
        _ = JS.InvokeVoidAsync("neolink.exitFullscreen");
        if (_maxIndex == index)
        {
            // Closing the maximized feed also leaves the maximized view — an
            // empty full-screen card helps nobody.
            _maxIndex = null;
            _maxPrevKind = _maxPrevPath = _maxPrevCamera = _maxSetKind = null;
            if (Camera != null) Nav.NavigateTo("");
        }
        _slots[index].Clear();
        _ = SaveAsync();
    }

    // Digital-zoom HUD: JS (neolink.zoomInit) owns the clicks and the badge —
    // no Blazor handlers, so wheel/drag/click stay off the circuit entirely.
    private RenderFragment ZoomHud => @<div class="zoom-hud" @onclick:stopPropagation="true" @ondblclick:stopPropagation="true">
        <button type="button" class="icon-btn zoom-btn" data-zoom="in" title="Zoom in (or mouse-wheel up on the video)">＋</button>
        <span class="zoom-badge" data-zoom-badge>100%</span>
        <button type="button" class="icon-btn zoom-btn" data-zoom="out" title="Zoom out (or mouse-wheel down)">−</button>
        <button type="button" class="icon-btn zoom-btn zoom-reset" data-zoom="reset" title="Restore 1:1 (or double-click the video)">1:1</button>
    </div>;

    private void OnTileClick(int index, MouseEventArgs e)
    {
        // An empty tile invites a click: open the camera picker right there
        // (same menu as right-click, friendlier for touch and discovery).
        if (_slots[index].Camera == null)
        {
            OpenTileMenu(index, e);
            return;
        }
        // In focus mode, clicking a thumbnail promotes it to the hero pane.
        if (_mode == "focus" && index > 0)
        {
            (_slots[0], _slots[index]) = (_slots[index], _slots[0]);
            _ = SaveAsync();
        }
    }

    // ------------------------------------------------------------ named layouts

    private SavedLayout? ActiveLayoutDef =>
        _layouts.FirstOrDefault(l => string.Equals(l.Name, _activeLayout, StringComparison.OrdinalIgnoreCase));

    /// <summary>The loaded layout no longer matches the screen — offer "update or save as new".</summary>
    private bool LayoutDirty
    {
        get
        {
            // A maximized tile is a temporary detour, not an edit of the layout.
            if (_backup != null || _maxIndex != null) return false;
            var l = ActiveLayoutDef;
            if (l == null) return false;
            if (l.Mode != _mode || l.Count != _count || l.Slots.Count != _slots.Count) return true;
            for (int i = 0; i < _slots.Count; i++)
            {
                if (l.Slots[i].Camera != _slots[i].Camera || l.Slots[i].Path != _slots[i].Path)
                    return true;
            }
            return false;
        }
    }

    private async Task<SavedLayout> CaptureLayoutAsync(string name) => new()
    {
        Name = name,
        Mode = _mode,
        Count = _count,
        Slots = _slots.Select(s => s.Clone()).ToList(),
        // Freeform tiles keep their exact pixel geometry (owned by JS in localStorage).
        FreeGeometry = _mode == "free"
            ? await JS.InvokeAsync<string?>("neolink.freeGeometry")
            : null,
    };

    /// <summary>Saves the current view under the typed name (same name = overwrite).</summary>
    private async Task SaveLayoutAsAsync()
    {
        var name = _layoutName.Trim();
        if (name.Length == 0) return;
        _layouts.RemoveAll(l => string.Equals(l.Name, name, StringComparison.OrdinalIgnoreCase));
        _layouts.Add(await CaptureLayoutAsync(name));
        _activeLayout = name;
        _layoutName = "";
        await SaveAsync();
    }

    private async Task UpdateActiveLayoutAsync()
    {
        var l = ActiveLayoutDef;
        if (l == null) return;
        _layouts[_layouts.IndexOf(l)] = await CaptureLayoutAsync(l.Name);
        await SaveAsync();
    }

    private async Task LoadLayoutAsync(SavedLayout l)
    {
        if (l.FreeGeometry != null)
            await JS.InvokeVoidAsync("neolink.freeSetGeometry", l.FreeGeometry);
        _mode = Modes.Any(m => m.Mode == l.Mode) ? l.Mode : "grid";
        _count = ClampCount(_mode, l.Count);
        _slots = l.Slots.Select(s => s.Clone()).ToList();
        EnsureSlots();
        _backup = null; // loading a layout replaces any maximize detour
        _activeLayout = l.Name;
        await SaveAsync();
    }

    private Task DeleteLayoutAsync(SavedLayout l)
    {
        _layouts.Remove(l);
        if (string.Equals(_activeLayout, l.Name, StringComparison.OrdinalIgnoreCase))
            _activeLayout = null;
        return SaveAsync();
    }

    // ------------------------------------------------------------ maximize / restore

    private ViewSnapshot Snapshot() => new()
    {
        Mode = _mode,
        Count = _count,
        Slots = _slots.Select(s => s.Clone()).ToList(),
    };

    /// <summary>The camera named in the URL (/cameras/{name}) — it owns the maximized state.</summary>
    [Parameter] public string? Camera { get; set; }

    /// <summary>Optional stream segment (/cameras/{name}/main|sub|ext) pinning the shown stream.</summary>
    [Parameter] public string? Stream { get; set; }

    /// <summary>A deep link named a camera the server doesn't have — shown as a notice on the wall.</summary>
    private string? _missingCamera;

    /// <summary>True once the camera list has been fetched successfully at least once.</summary>
    private bool _camerasFetched;

    /// <summary>True when this sidebar camera is the one named in the URL — its card gets the highlight.</summary>
    private bool IsRouteCamera(string name) =>
        Camera != null && string.Equals(name, Camera, StringComparison.OrdinalIgnoreCase);

    /// <summary>True when the URL pins this exact camera + stream (/cameras/{name}/{stream}).</summary>
    private bool IsRouteStream(string name, string kind) =>
        IsRouteCamera(name) && KindFromSegment(Stream) == kind;

    private static string CameraUrl(string name) => $"cameras/{Uri.EscapeDataString(name)}";

    private static string StreamUrl(string name, string kind) =>
        $"cameras/{Uri.EscapeDataString(name)}/{SegmentFromKind(kind)}";

    private static string? KindFromSegment(string? seg) => seg?.ToLowerInvariant() switch
    {
        "main" => "mainStream",
        "sub" => "subStream",
        "ext" or "extern" => "externStream",
        _ => null,
    };

    private static string SegmentFromKind(string kind) => kind switch
    {
        "mainStream" => "main",
        "subStream" => "sub",
        "externStream" => "ext",
        _ => kind,
    };

    protected override void OnParametersSet()
    {
        // Route changes re-enter the SAME component instance (both pages map here),
        // so the background players survive URL navigation untouched.
        if (_loaded) ApplyRoute();
    }

    /// <summary>
    /// The URL owns the maximized state: /cameras/{name} shows that camera big
    /// (adding it to the wall first when needed), plain / restores the wall.
    /// Browser Back/Forward therefore walk between the two naturally, and every
    /// camera is deep-linkable.
    /// </summary>
    private void ApplyRoute()
    {
        if (string.IsNullOrEmpty(Camera))
        {
            if (_maxIndex != null) RestoreMaximized();
            return;
        }
        var cam = _cameras.FirstOrDefault(c => string.Equals(c.Name, Camera, StringComparison.OrdinalIgnoreCase));
        if (cam == null)
        {
            // Only a successfully fetched camera list can prove a deep link is bad —
            // fetch errors and the login gate leave the wall alone (the route is
            // re-applied once the list arrives). A truly unknown camera falls back
            // to the wall with a notice instead of silently rendering under the
            // bogus /cameras/... URL.
            if (_camerasFetched && _error == null && !_showLogin)
            {
                _missingCamera = Camera;
                Nav.NavigateTo("", replace: true);
            }
            return;
        }
        _missingCamera = null;
        _ = EnsureTalkCapAsync(cam.Name); // decides whether the mic button shows

        // An explicit /main|/sub|/ext segment pins the stream; without one the
        // maximize auto-main logic decides (and restores) as usual.
        var wantKind = KindFromSegment(Stream);
        var want = wantKind != null ? cam.Streams.FirstOrDefault(s => s.Kind == wantKind) : null;

        int index = _slots.FindIndex(s => string.Equals(s.Camera, cam.Name, StringComparison.OrdinalIgnoreCase));
        if (index < 0)
        {
            // Not on the wall yet: reuse the currently maximized card if any,
            // else the first free tile (growing the layout when possible).
            var stream = want ?? DefaultStream(cam);
            if (stream == null) return;
            var slot = _maxIndex is int m ? _slots[m] : _slots.FirstOrDefault(s => s.Camera == null);
            if (slot == null)
            {
                int grown = ClampCount(_mode, _count + 1);
                if (grown > _count) { _count = grown; EnsureSlots(); }
                slot = _slots.FirstOrDefault(s => s.Camera == null) ?? _slots[^1];
            }
            slot.Camera = cam.Name;
            slot.Kind = stream.Kind;
            slot.Path = stream.Path;
            index = _slots.IndexOf(slot);
        }

        bool changed = false;
        if (_maxIndex != index)
        {
            RevertAutoMainSwitch(); // the outgoing card gets its stream back first
            _maxIndex = index;
            changed = true;
        }
        var target = _slots[index];
        if (want != null)
        {
            if (target.Kind != want.Kind)
            {
                // The maximized view is a DETOUR: whatever stream it shows — the
                // URL's explicit choice included — Restore view must put the tile
                // back exactly as the wall had it. Record the original once; later
                // chip switches (main↔sub) keep that first value.
                if (_maxPrevKind == null)
                {
                    _maxPrevKind = target.Kind;
                    _maxPrevPath = target.Path;
                    _maxPrevCamera = target.Camera;
                }
                target.Kind = want.Kind;
                target.Path = want.Path;
                changed = true;
            }
            _maxSetKind = want.Kind;
        }
        else if (changed)
        {
            AutoMainStream(index); // no stream in the URL: the usual sub→main upgrade
        }
        if (changed)
        {
            MaybeWarnMainStreams(); // route-driven maximize can add a main stream too
            _ = SaveAsync();
        }
    }

    private void ToggleMaximize(int index)
    {
        // Layout changes are invisible while the browser is fullscreened on a
        // tile — leave fullscreen so the action has a visible effect.
        _ = JS.InvokeVoidAsync("neolink.exitFullscreen");
        if (_backup != null && _mode == "theater")
        {
            RestoreFromBackup(); // legacy persisted maximize from older versions
            return;
        }
        // Maximize is a NAVIGATION: the URL flips to /cameras/{name} and back, so
        // the browser's Back button undoes it like any other page.
        if (_maxIndex == index)
        {
            Nav.NavigateTo("");
            return;
        }
        var name = _slots[index].Camera;
        if (name == null) return;
        Nav.NavigateTo(CameraUrl(name));
    }

    /// <summary>
    /// A maximized card deserves the pixels: a sub-stream card switches to the
    /// camera's main stream when it serves one. The previous choice is remembered
    /// so restoring the view puts the sub stream back. Phones skip the upgrade —
    /// a 1440p+ main stream is more than a phone screen shows and enough to make
    /// iOS playback stutter; the tile's stream picker still offers Main.
    /// </summary>
    private void AutoMainStream(int index)
    {
        _maxPrevKind = _maxPrevPath = _maxPrevCamera = _maxSetKind = null;
        if (_coarsePointer) return;
        var slot = _slots[index];
        var cam = _cameras.FirstOrDefault(c => c.Name == slot.Camera);
        var main = cam?.Streams.FirstOrDefault(s => s.Kind == "mainStream");
        if (main == null || slot.Kind == main.Kind) return;
        _maxPrevKind = slot.Kind;
        _maxPrevPath = slot.Path;
        _maxPrevCamera = slot.Camera;
        _maxSetKind = main.Kind;
        slot.Kind = main.Kind;
        slot.Path = main.Path;
    }

    /// <summary>Undoes the automatic main-stream switch — but only while the card
    /// still shows the same camera on the auto-chosen main stream. A camera or
    /// stream the user picked by hand while maximized is respected.</summary>
    private void RevertAutoMainSwitch()
    {
        if (_maxIndex is int i && _maxPrevKind != null)
        {
            var slot = _slots.ElementAtOrDefault(i);
            if (slot != null && slot.Camera == _maxPrevCamera
                && slot.Kind == (_maxSetKind ?? "mainStream"))
            {
                slot.Kind = _maxPrevKind;
                slot.Path = _maxPrevPath;
            }
        }
        _maxPrevKind = _maxPrevPath = _maxPrevCamera = _maxSetKind = null;
    }

    private void RestoreMaximized()
    {
        RevertAutoMainSwitch();
        _maxIndex = null;
        _ = SaveAsync();
    }

    /// <summary>Toolbar "Restore view": whichever maximize flavor is active.</summary>
    private void RestoreView()
    {
        if (_maxIndex != null) Nav.NavigateTo("");
        else RestoreFromBackup();
    }

    // ------------------------------------------------------------ quick view (pop-up)

    /// <summary>Temporary pop-up player for one camera — the layout underneath is untouched.</summary>
    private void OpenQuickView(ApiCamera cam)
    {
        // Phones default to the sub stream: a 1440p+ main stream decoded into a
        // small popup is what made iOS previews stutter, and the popup can't
        // show that many pixels anyway. The stream picker still offers Main.
        var preferred = _coarsePointer ? "subStream" : "mainStream";
        var s = cam.Streams.FirstOrDefault(x => x.Kind == preferred)
            ?? cam.Streams.FirstOrDefault(x => x.Kind == "mainStream")
            ?? DefaultStream(cam);
        if (s == null) return;
        _quickView = new ViewSlot { Camera = cam.Name, Kind = s.Kind, Path = s.Path };
        _sidebarOpen = false;
        _ = EnsureTalkCapAsync(cam.Name); // decides whether the mic button shows
    }

    private void CloseQuickView()
    {
        _ = JS.InvokeVoidAsync("neolink.exitFullscreen");
        _quickView = null;
    }

    private void ChangeQuickStream(ApiCamera camera, string? path)
    {
        var stream = camera.Streams.FirstOrDefault(s => s.Path == path);
        if (stream == null || _quickView == null) return;
        _quickView.Kind = stream.Kind;
        _quickView.Path = stream.Path;
    }

    private async Task QuickFullscreenAsync() =>
        await JS.InvokeVoidAsync("neolink.fullscreen", "quick-view-media");

    // ------------------------------------------------------------ two-way talk

    // The mic button lives on the single-camera surfaces (maximized tile, quick
    // view) and only on cameras whose capabilities advertise talk support.
    private string? _talkCamera;        // camera with an active/starting session
    private string _talkPhase = "off";  // connecting | live | off
    private string? _talkError;         // one-shot toast text
    private readonly Dictionary<string, bool> _talkCaps = new(StringComparer.OrdinalIgnoreCase);

    private bool TalkSupported(string? cam) =>
        cam != null && _talkCaps.TryGetValue(cam, out var t) && t;

    private bool TalkActive(string cam) =>
        _talkCamera != null && string.Equals(_talkCamera, cam, StringComparison.OrdinalIgnoreCase);

    private string TalkClass(string cam) =>
        TalkActive(cam) ? (_talkPhase == "live" ? "talk-live" : "talk-connecting") : "";

    private string TalkTitle(string cam) =>
        TalkActive(cam) ? "Stop talking" : "Talk through the camera's speaker";

    /// <summary>
    /// Looks up (once per camera) whether it supports two-way talk. Offline
    /// cameras are re-probed on the next surface open instead of being cached.
    /// </summary>
    private async Task EnsureTalkCapAsync(string? cam)
    {
        if (cam == null || Locked || _talkCaps.ContainsKey(cam)) return;
        _talkCaps[cam] = false; // placeholder: one probe in flight per camera
        try
        {
            using var res = await Http.SendAsync(ApiRequest(HttpMethod.Get,
                $"/api/cameras/{Uri.EscapeDataString(cam)}/capabilities"));
            if (!res.IsSuccessStatusCode)
            {
                _talkCaps.Remove(cam);
                return;
            }
            var json = await res.Content.ReadFromJsonAsync<JsonElement>();
            if (!json.TryGetProperty("online", out var on) || !on.GetBoolean())
            {
                _talkCaps.Remove(cam);
                return;
            }
            if (json.TryGetProperty("features", out var f)
                && f.TryGetProperty("talk", out var t) && t.ValueKind == JsonValueKind.True)
            {
                _talkCaps[cam] = true;
                await InvokeAsync(StateHasChanged);
            }
        }
        catch
        {
            _talkCaps.Remove(cam);
        }
    }

    private async Task ToggleTalkAsync(string cam)
    {
        if (_talkCamera != null)
        {
            bool same = TalkActive(cam);
            await JS.InvokeVoidAsync("neolink.talkStop"); // JS reports "off" back
            if (same) return;
        }
        _talkCamera = cam;
        _talkPhase = "connecting";
        _talkError = null;
        _selfRef ??= DotNetObjectReference.Create(this);
        await JS.InvokeVoidAsync("neolink.talkStart", TalkUrl(cam), _selfRef);
    }

    private void StopTalk()
    {
        if (_talkCamera == null) return;
        _ = JS.InvokeVoidAsync("neolink.talkStop");
    }

    /// <summary>Ends the talk session once its camera no longer has a talk surface
    /// (view restored, quick view closed, tile cleared...). One chokepoint, called
    /// after every render, instead of hooks in each state mutation.</summary>
    private void StopTalkIfOrphaned()
    {
        if (_talkCamera == null) return;
        bool maxed = _maxIndex is int m && string.Equals(
            _slots.ElementAtOrDefault(m)?.Camera, _talkCamera, StringComparison.OrdinalIgnoreCase);
        bool quick = string.Equals(_quickView?.Camera, _talkCamera, StringComparison.OrdinalIgnoreCase);
        if (!maxed && !quick) StopTalk();
    }

    private string? TalkUrl(string cam)
    {
        if (string.IsNullOrWhiteSpace(_server)) return null;
        var baseUrl = _server.TrimEnd('/');
        baseUrl = baseUrl.StartsWith("https", StringComparison.OrdinalIgnoreCase)
            ? "wss" + baseUrl["https".Length..]
            : "ws" + baseUrl["http".Length..];
        return $"{baseUrl}/api/talk?camera={Uri.EscapeDataString(cam)}{TokenQuery('&')}";
    }

    /// <summary>The video element showing the talk camera (its surface), if any.</summary>
    private string? TalkVideoId()
    {
        if (_talkCamera == null) return null;
        if (string.Equals(_quickView?.Camera, _talkCamera, StringComparison.OrdinalIgnoreCase))
            return QuickVideoId;
        if (_maxIndex is int m && string.Equals(
                _slots.ElementAtOrDefault(m)?.Camera, _talkCamera, StringComparison.OrdinalIgnoreCase))
            return $"vid-{m}";
        return null;
    }

    /// <summary>Called from JS as the talk session changes state.</summary>
    [JSInvokable]
    public Task OnTalkState(string state, string? detail) => InvokeAsync(() =>
    {
        switch (state)
        {
            case "live":
                _talkPhase = "live";
                // A conversation is two-way: make the camera audible too. The
                // speaker toggle still mutes it again if the user prefers.
                if (TalkVideoId() is { } videoId)
                    _ = JS.InvokeVoidAsync("neolink.unmute", videoId);
                break;
            case "error":
                _talkError = string.IsNullOrWhiteSpace(detail) ? "could not start" : detail;
                _talkCamera = null;
                _talkPhase = "off";
                break;
            default: // "off"
                _talkCamera = null;
                _talkPhase = "off";
                break;
        }
        StateHasChanged();
    });

    private void RestoreFromBackup()
    {
        if (_backup == null) return;
        _mode = Modes.Any(m => m.Mode == _backup.Mode) ? _backup.Mode : "grid";
        _count = ClampCount(_mode, _backup.Count);
        _slots = _backup.Slots;
        _backup = null;
        EnsureSlots();
        _ = SaveAsync();
    }

    // Browser fullscreen gets the same treatment as maximize: a sub-stream card
    // switches to the camera's main stream while fullscreen, reverted on exit.
    // Exit can happen without us (Esc, browser UI), so JS watches fullscreenchange
    // and calls OnFullscreenExit.
    private int? _fsIndex;
    private string? _fsPrevKind;
    private string? _fsPrevPath;
    private string? _fsPrevCamera;

    private async Task FullscreenAsync(int index)
    {
        // Entering only — the same button while fullscreen exits (JS toggles), and
        // a maximized tile already runs its main stream.
        if (_fsIndex == null && _maxIndex != index)
        {
            var slot = _slots[index];
            var cam = _cameras.FirstOrDefault(c => c.Name == slot.Camera);
            var main = cam?.Streams.FirstOrDefault(s => s.Kind == "mainStream");
            if (main != null && slot.Kind != main.Kind)
            {
                _fsIndex = index;
                _fsPrevKind = slot.Kind;
                _fsPrevPath = slot.Path;
                _fsPrevCamera = slot.Camera;
                slot.Kind = main.Kind;
                slot.Path = main.Path;
                _ = SaveAsync();
            }
        }
        _selfRef ??= DotNetObjectReference.Create(this);
        await JS.InvokeVoidAsync("neolink.fsWatch", _selfRef);
        await JS.InvokeVoidAsync("neolink.fullscreen", $"tile-{index}");
    }

    /// <summary>Called from JS whenever browser fullscreen ends, however it ends.</summary>
    [JSInvokable]
    public async Task OnFullscreenExit()
    {
        if (_fsIndex is not int i) return;
        var slot = _slots.ElementAtOrDefault(i);
        // Same rule as maximize: only the automatic switch is undone; a stream or
        // camera the user picked by hand while fullscreen is respected.
        if (slot != null && slot.Camera == _fsPrevCamera && slot.Kind == "mainStream")
        {
            slot.Kind = _fsPrevKind;
            slot.Path = _fsPrevPath;
        }
        _fsIndex = null;
        _fsPrevKind = _fsPrevPath = _fsPrevCamera = null;
        await InvokeAsync(async () =>
        {
            await SaveAsync();
            StateHasChanged();
        });
    }

    // ------------------------------------------------------------ player reconciliation

    private string? WsUrl(ViewSlot slot)
    {
        if (slot.Path == null || string.IsNullOrWhiteSpace(_server)) return null;
        var baseUrl = _server.TrimEnd('/');
        baseUrl = baseUrl.StartsWith("https", StringComparison.OrdinalIgnoreCase)
            ? "wss" + baseUrl["https".Length..]
            : "ws" + baseUrl["http".Length..];
        return $"{baseUrl}/api/stream?path={Uri.EscapeDataString(slot.Path)}{TokenQuery('&')}";
    }

    /// <summary>
    /// Sign-in is required but not satisfied. While locked, NO stream is attached —
    /// belt-and-braces with the server, which already rejects the stream WebSocket
    /// (and every /api call) without a valid session token.
    /// </summary>
    private bool Locked => _authEnabled && _authUser == null;

    private async Task ReconcilePlayersAsync()
    {
        int upper = Math.Max(_slots.Count, _attached.Count == 0 ? 0 : _attached.Keys.Max() + 1);
        for (int i = 0; i < upper; i++)
        {
            // Locked: force every tile to detach — a signed-out user sees no video.
            string? desired = (!Locked && i < _slots.Count) ? WsUrl(_slots[i]) : null;
            _attached.TryGetValue(i, out var current);
            if (desired == current) continue;

            if (current != null)
            {
                await JS.InvokeVoidAsync("neolink.detach", $"vid-{i}");
                _attached.Remove(i);
            }
            if (desired != null)
            {
                await JS.InvokeVoidAsync("neolink.attach", $"vid-{i}", desired);
                _attached[i] = desired;
            }
        }

        // The quick-view pop-up has its own player, independent of the grid slots.
        string? quick = (!Locked && _quickView != null) ? WsUrl(_quickView) : null;
        if (quick != _quickAttached)
        {
            if (_quickAttached != null)
            {
                await JS.InvokeVoidAsync("neolink.detach", QuickVideoId);
                _quickAttached = null;
            }
            if (quick != null)
            {
                await JS.InvokeVoidAsync("neolink.attach", QuickVideoId, quick);
                _quickAttached = quick;
            }
        }
    }

    public async ValueTask DisposeAsync()
    {
        _pollTimer?.Dispose();
        if (_talkCamera != null)
        {
            try { await JS.InvokeVoidAsync("neolink.talkStop"); }
            catch { /* circuit already gone */ }
        }
        _selfRef?.Dispose();
        foreach (var i in _attached.Keys.ToList())
        {
            try { await JS.InvokeVoidAsync("neolink.detach", $"vid-{i}"); }
            catch { /* circuit already gone */ }
        }
        _attached.Clear();
        if (_quickAttached != null)
        {
            try { await JS.InvokeVoidAsync("neolink.detach", QuickVideoId); }
            catch { /* circuit already gone */ }
            _quickAttached = null;
        }
    }
}
