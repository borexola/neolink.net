    // ------------------------------------------------------------ data

    private async Task RefreshCamerasAsync()
    {
        if (await TryFetchCamerasAsync(_server)) return;

        // The UI is served by Neolink.Server itself, so the page origin is almost
        // always the right API address. Heal stale/typo'd saved values automatically.
        try
        {
            var origin = await JS.InvokeAsync<string>("neolink.defaultServer");
            if (!string.Equals(origin, _server, StringComparison.OrdinalIgnoreCase)
                && await TryFetchCamerasAsync(origin))
            {
                _server = origin;
                await SaveAsync();
            }
        }
        catch { /* JS unavailable (prerender/disconnect): keep the original error */ }
    }

    private async Task<bool> TryFetchCamerasAsync(string server)
    {
        if (string.IsNullOrWhiteSpace(server)) return false;
        try
        {
            var req = new HttpRequestMessage(HttpMethod.Get, $"{ResolveApi(server)}/api/cameras");
            if (!string.IsNullOrEmpty(_authToken))
                req.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", _authToken);
            using var res = await Http.SendAsync(req);
            if (res.StatusCode == System.Net.HttpStatusCode.Unauthorized)
            {
                // Reachable, but a session is required (or ours expired).
                _authEnabled = true;
                _showLogin = true;
                _cameras.Clear();
                _error = null;
                return true;
            }
            if (!res.IsSuccessStatusCode)
            {
                _error = $"Cannot reach {server}: HTTP {(int)res.StatusCode}";
                return false;
            }
            var cams = await res.Content.ReadFromJsonAsync<List<ApiCamera>>();
            _cameras.Clear();
            if (cams != null) _cameras.AddRange(cams);
            _error = null;
            return true;
        }
        catch (Exception ex)
        {
            _error = $"Cannot reach {server}: {ex.Message}";
            return false;
        }
    }

    private async Task PollLoopAsync()
    {
        _pollTimer = new PeriodicTimer(TimeSpan.FromSeconds(10));
        try
        {
            while (await _pollTimer.WaitForNextTickAsync())
            {
                await RefreshCamerasAsync();
                await RefreshEventsAsync();
                StateHasChanged();
            }
        }
        catch (OperationCanceledException) { }
        catch (ObjectDisposedException) { }
    }

    private async Task OnServerChangedAsync()
    {
        await RefreshCamerasAsync();
        await RefreshEventsAsync();
        await SaveAsync();
    }

