<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Neolink.NET</title>
    <base href="@BaseHref" />
    <link rel="stylesheet" href="_content/Neolink.WebClient/css/app.css" />
    @* App icon: SVG for modern browsers, PNG for Safari/iOS and the home-screen
       shortcut. Relative hrefs resolve against <base href="/"> so they work on
       every route (like the stylesheet above). *@
    <link rel="icon" type="image/svg+xml" href="_content/Neolink.WebClient/favicon.svg" />
    <link rel="icon" type="image/png" sizes="256x256" href="_content/Neolink.WebClient/favicon.png" />
    <link rel="apple-touch-icon" href="_content/Neolink.WebClient/favicon.png" />
    <HeadOutlet @rendermode="InteractiveServer" />
</head>

<body>
    <Routes @rendermode="InteractiveServer" />

    @* Custom reconnect overlay: when this element exists, Blazor toggles its
       state classes (components-reconnect-show/failed/rejected) here instead
       of injecting its unthemed white default dialog. *@
    <div id="components-reconnect-modal" class="reconnect-modal">
        <div class="reconnect-box">
            <div class="reconnect-spinner" aria-hidden="true"></div>
            <div class="reconnect-when-show">
                <div class="reconnect-title">Connection lost</div>
                <div class="reconnect-sub">
                    Reconnecting to the server…
                    <span class="reconnect-attempts">(attempt
                        <span id="components-reconnect-current-attempt"></span> of
                        <span id="components-reconnect-max-retries"></span>)</span>
                </div>
            </div>
            <div class="reconnect-when-failed">
                <div class="reconnect-title">Server unreachable</div>
                <div class="reconnect-sub">The connection could not be re-established.</div>
                <button class="chip chip-active" onclick="(window.Blazor &amp;&amp; Blazor.reconnect) ? Blazor.reconnect() : location.reload()">Try again</button>
                <button class="chip" onclick="location.reload()">Reload page</button>
            </div>
            <div class="reconnect-when-rejected">
                <div class="reconnect-title">Session expired</div>
                <div class="reconnect-sub">The server restarted — the page needs a reload.</div>
                <button class="chip chip-active" onclick="location.reload()">Reload page</button>
            </div>
        </div>
    </div>

    <script src="_framework/blazor.web.js"></script>
    <script src="_content/Neolink.WebClient/js/neolink.js"></script>
</body>

</html>

@code {
    // A reverse proxy that serves the UI under a path prefix (notably Home Assistant
    // ingress, which puts a per-session token in the path) sends that prefix in
    // X-Ingress-Path. The <base href> must carry it so every relative asset, the
    // Blazor SignalR endpoint and the API calls resolve inside the proxied scope.
    // Absent the header we serve from the root, unchanged.
    [CascadingParameter] public Microsoft.AspNetCore.Http.HttpContext? HttpContext { get; set; }

    private string BaseHref
    {
        get
        {
            var prefix = HttpContext?.Request.Headers["X-Ingress-Path"].ToString();
            // Only trust a plain absolute path (HA ingress sends /api/hassio_ingress/<token>).
            // Reject anything that could retarget <base> to another origin — a
            // protocol-relative //host, a scheme (contains ':'), or CR/LF — and fall
            // back to the root, so a spoofed header on a directly-exposed instance
            // can't hijack where the browser loads assets and the API from.
            if (string.IsNullOrEmpty(prefix) || prefix[0] != '/' || prefix.StartsWith("//")
                || prefix.Contains(':') || prefix.Contains('\r') || prefix.Contains('\n'))
                return "/";
            return $"{prefix.TrimEnd('/')}/";
        }
    }
}
