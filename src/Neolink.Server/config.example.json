{
  // Neolink.NET configuration.
  // Copy this file to config.json and edit it — comments and trailing commas are allowed.

  // Address to serve on. "0.0.0.0" = all networks, "127.0.0.1" = this computer only.
  "bind": "0.0.0.0",

  // RTSP port (for VLC, ffmpeg, Frigate, Blue Iris, Home Assistant, ...).
  "bind_port": 8554,

  // HTTP/WebSocket port: the web UI and the JSON/fMP4 API. 0 disables both.
  "web_port": 8555,

  // Serve the browser UI on web_port. Set false for API-only / headless setups.
  "webui": true,

  // Optional: password-protect the RTSP server. Remove entries for open access.
  // Connect with e.g. rtsp://me:mepass@192.168.1.100:8554/driveway
  "users": [
    // { "name": "me", "pass": "mepass" }
  ],

  // One entry per camera.
  "cameras": [
    {
      // Name used in the RTSP URL and the web UI: rtsp://<host>:8554/driveway
      "name": "driveway",

      // Camera login (the same credentials as the Reolink app).
      "username": "admin",
      "password": "CHANGE-ME",

      // IP or hostname of the camera. Port defaults to 9000 if omitted.
      "address": "192.168.1.187:9000",

      // Which streams to serve: "mainStream", "subStream", "externStream", "both", or "all".
      // "both" serves /driveway (+ /driveway/mainStream) and /driveway/subStream.
      "stream": "both",

      // Only needed when connecting through a Reolink NVR: camera channel, starting at 0.
      "channel_id": 0

      // Optional: restrict this camera to specific users from "users" above.
      // "permitted_users": [ "me" ]
    }
  ]
}
