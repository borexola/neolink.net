<?xml version="1.0" encoding="utf-8"?>
<!--
  Neolink.NET has no third-party package dependencies, but .NET 10 delivers the
  Blazor framework static assets (blazor.web.js) via the NuGet package
  Microsoft.AspNetCore.App.Internal.Assets, so nuget.org must be reachable for a
  cold restore (e.g. Docker builds). Machines with a warm NuGet cache still build
  offline.
-->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
