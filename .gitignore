bin/
obj/
.vs/
*.user
publish/

# Local test images exported with `docker save` (see the README's developer note)
/neolink.net-*.tar

# Real camera credentials live in config.json — never commit it.
# Copy config.example.json to config.json to get started.
config.json
src/Neolink.Server/config.json

# Editor/assistant local state + leftover pre-rename folder
.claude/
src/Neolink/

# ---------------------------------------------------------------- runtime state
# Everything the server writes into its state directory. The state dir DEFAULTS
# to the config file's own directory, so running a dev build from the repo drops
# these anywhere in the tree — every entry is therefore unanchored on purpose.
# Rule for anything added here later: if a file can hold credentials, keys,
# tokens, hashes, camera identity or anyone's personal setup, it is ignored
# BEFORE the feature that writes it ships. Never commit one "just as an example".
#   secret.key         AES key — decrypts every other stored secret
#   users.json         web-UI accounts: password hashes, session tokens
#   notifications.json SMTP settings incl. the encrypted password
#   ai.json            LLM endpoints + encrypted API keys, instruction prompt
#   settings.json      per-camera recording/AI settings
#   camera-state.json  per-camera suspend flags
#   storage-trend.json disk-usage history
secret.key
users.json
notifications.json
ai.json
settings.json
camera-state.json
storage-trend.json
# ...but the editor's own settings are not ours to hide.
!.vscode/settings.json

# local docker test images (docker save output)
neolink-*.tar

# editor/backup leftovers
*.bak

# Local dev tools, not shipped
/devtools/
